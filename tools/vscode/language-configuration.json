{
  "comments": {
    "lineComment": "//",
    "blockComment": ["//[", "//]"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(def|val|var|if|then|else|while|do|for|match|case|class|object|interface|extension|union|section|begin)\\b",
    "decreaseIndentPattern": "^\\s*(end|else|case)\\b"
  }
}
