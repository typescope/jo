//[ AgentRuntime.jo
  !
  ! Trusted runtime for the sandbox agent framework (Python backend)
  !
  ! Provides implementations for all AgentAPI interfaces.
  ! Reads configuration from command-line arguments.
//]

namespace AgentRuntime

import jo.IO.stdout
import AgentAPI.*

private def builtins: py.Dynamic = py.module("builtins")

// ============================================
// Implementation Section
// ============================================

//[ All operations enforce sandbox boundary by resolving paths
  ! and checking they remain under the root directory.
//]
section Impl
  // Context parameter for root directory
  param rootDir: String

  //[ Resolve and validate a user-provided path
    !
    ! Returns Some(absolutePath) if the path is within the workspace,
    ! or None if it escapes the workspace root
  //]
  def resolvePath(userPath: String): Option[String] receives rootDir =
    val rootPath = os.path.abspath(rootDir)
    val resolved = os.path.abspath(os.path.join(rootPath, userPath))
    // Ensure the resolved path is under the sandbox root
    val isSafe: Bool =
      if resolved.startsWith(rootPath) then
        if rootPath.size == resolved.size then true
        else
          resolved.get(rootPath.size) == '/'
      else false

    if isSafe then Some(resolved)
    else None

  // Read file content with sandbox enforcement
  def readFileImpl(userPath: String): ReadResult receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        if os.path.isfile(safePath) then
          FileContent(py.open(safePath, "r").read().asString)
        else
          NotFound
      case None =>
        AccessDenied("Path outside sandbox: " + userPath)

  // Write file content with sandbox enforcement
  def writeFileImpl(userPath: String, content: String): WriteResult receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        py.open(safePath, "w").write(content)
        WriteOk
      case None =>
        WriteNotAllowed("Path outside sandbox: " + userPath)

  // Append to file with sandbox enforcement
  def appendFileImpl(userPath: String, content: String): WriteResult receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        py.open(safePath, "a").write(content)
        WriteOk
      case None =>
        WriteNotAllowed("Path outside sandbox: " + userPath)

  // List directory contents with sandbox enforcement
  def listDirImpl(userPath: String): ListResult receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        if !os.path.isdir(safePath) then return DirNotFound

        val entries: py.List = builtins.sorted(os.listdir(safePath)).cast[py.List]
        val count = entries.size

        var result: List[FileEntry] = []
        var i = count - 1
        while i >= 0 do
          val name: String = entries.get(i).asString
          val fullPath = os.path.join(safePath, name)
          val isDir    = os.path.isdir(fullPath)
          var size = 0
          if !isDir then
            size = os.path.getsize(fullPath)
          result = result.prepend(new FileEntry(name, isDir, size))
          i = i - 1

        DirEntries(result)

      case None =>
        DirAccessDenied("Path outside sandbox: " + userPath)

  // Delete file with sandbox enforcement
  def deleteFileImpl(userPath: String): WriteResult receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        os.unlink(safePath)
        WriteOk
      case None =>
        WriteNotAllowed("Path outside sandbox: " + userPath)

  // Check if path exists within sandbox
  def existsImpl(userPath: String): Bool receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        os.path.exists(safePath)
      case None =>
        false

  // Create directory within sandbox
  def mkdirImpl(userPath: String): WriteResult receives rootDir =
    match resolvePath(userPath)
      case Some(safePath) =>
        os.makedirs(safePath)
        WriteOk
      case None =>
        WriteNotAllowed("Path outside sandbox: " + userPath)

  // Rename/move within sandbox
  def renameImpl(fromPath: String, toPath: String): WriteResult receives rootDir =
    match resolvePath(fromPath)
      case Some(safeFrom) =>
        match resolvePath(toPath)
          case Some(safeTo) =>
            os.rename(safeFrom, safeTo)
            WriteOk
          case None =>
            WriteNotAllowed("Destination outside sandbox: " + toPath)
      case None =>
        WriteNotAllowed("Source outside sandbox: " + fromPath)
end

// ============================================
// Implementation Classes
// ============================================

//[ Sandboxed file system implementation
  !
  ! All paths are resolved and validated against the workspace root.
//]
class SandboxedFS(rootDir: String)
  def readFile(path: String): ReadResult =
    with Impl.rootDir = rootDir in Impl.readFileImpl(path)

  def writeFile(path: String, content: String): WriteResult =
    with Impl.rootDir = rootDir in Impl.writeFileImpl(path, content)

  def appendFile(path: String, content: String): WriteResult =
    with Impl.rootDir = rootDir in Impl.appendFileImpl(path, content)

  def listDir(path: String): ListResult =
    with Impl.rootDir = rootDir in Impl.listDirImpl(path)

  def deleteFile(path: String): WriteResult =
    with Impl.rootDir = rootDir in Impl.deleteFileImpl(path)

  def exists(path: String): Bool =
    with Impl.rootDir = rootDir in Impl.existsImpl(path)

  def mkdir(path: String): WriteResult =
    with Impl.rootDir = rootDir in Impl.mkdirImpl(path)

  def rename(from: String, to: String): WriteResult =
    with Impl.rootDir = rootDir in Impl.renameImpl(from, to)

  view AgentAPI.ReadableFS
  view AgentAPI.WritableFS
end

//[ Skills implementation - read-only access to a hierarchy of .md files
  !
  ! Skills can be organized in subdirectories, e.g.:
  !   skills/
  !     overview.md          → skill name: "overview"
  !     cooking/
  !       pasta.md           → skill name: "cooking/pasta"
  !       sushi.md           → skill name: "cooking/sushi"
  !
  ! Provides listing, reading, and recursive grep.
//]
class SkillsImpl(skillsDir: String)
  view AgentAPI.Skills

  // Collect all .md files recursively as (skillName, fullPath) pairs
  private def collectFiles(): List[String ~ String] =
    val sd = skillsDir
    if !os.path.isdir(sd) then return []

    var files: List[String ~ String] = []
    val walkIter = os.walk(sd)
    var nextEntry: py.Dynamic = builtins.next(walkIter, py.none)

    while !py.isNone(nextEntry) do
      val entry: os.WalkEntry = nextEntry.cast[os.WalkEntry]
      val dirpath = entry.dirpath
      val filenames = entry.filenames
      var i = 0
      while i < filenames.size do
        val filename: String = filenames.get(i).asString
        if filename.endsWith(".md") then
          val fullPath = os.path.join(dirpath, filename)
          val relPath = os.path.relpath(fullPath, sd)
          val skillName = relPath.substring(0, relPath.size - 3)
          files = files + (skillName ~ fullPath)
        i = i + 1
      end
      nextEntry = builtins.next(walkIter, py.none)

    files.sortBy(pair => pair.fst)

  // List all skill names recursively (relative paths without .md extension)
  def list(): List[String] =
    collectFiles().map(pair => pair.fst)

  // Read a skill by name (e.g. "cooking/pasta" reads cooking/pasta.md)
  def read(name: String): ReadResult =
    val sd      = skillsDir
    val joined  = os.path.join(sd, name + ".md")
    val absPath = os.path.abspath(os.path.normpath(joined))
    val absDir  = os.path.abspath(sd)
    // Ensure path stays within skills dir
    val isSafe =
      if absPath.startsWith(absDir) then
        if absPath.size == absDir.size then true
        else absPath.get(absDir.size) == '/'
      else false
    if !isSafe then return AccessDenied("Path outside skills directory")

    if os.path.isfile(absPath) then
      FileContent(py.open(absPath, "r").read().asString)
    else
      NotFound

  // Search all .md files recursively for a substring, return matching lines
  def grep(query: String, contextLines: Int, maxHits: Int): List[SearchHit] =
    val files = collectFiles()
    val lowerQuery = query.toLower
    var hits: List[SearchHit] = []

    for skillName ~ filePath in files do
      if hits.size >= maxHits then return hits

      val content = py.open(filePath, "r").read().asString
      val lines = content.lines
      var lineNum = 1

      for line in lines if line.toLower.contains(lowerQuery) do
        if hits.size >= maxHits then return hits

        var ctx = ""
        if contextLines > 0 then
          val startIdx = (lineNum - 1 - contextLines).max(0)
          val endIdx = (lineNum - 1 + contextLines).min(lines.size - 1)
          var i = startIdx
          while i <= endIdx do
            if i > startIdx then ctx = ctx + "\n"
            ctx = ctx + lines[i]
            i = i + 1

        hits = hits + new SearchHit(skillName, lineNum, line, ctx)

        lineNum = lineNum + 1
      end
    end

    hits
end

// Logger implementation
class LoggerImpl(console: String => Unit)
  def info(message: String): Unit =
    with stdout = console in
      print "[INFO] "
      println message

  def warn(message: String): Unit =
    with stdout = console in
      print "[WARN] "
      println message

  view AgentAPI.Logger
end

// ============================================
// Actions Implementation
// ============================================

class ActionsImpl(workspaceFS: SandboxedFS, messageScript: String)
  def hello(name: String): String =
    "Hello, " + name + "!"

  def echo(message: String): String =
    message

  def sendMessage(title: String, content: String): Unit =
    subprocess.run(messageScript, title, content)

  view AgentAPI.Actions
end

// ============================================
// Platform Entry Point
// ============================================

//[ Main entry point - reads sandbox root from sys.argv
  !
  ! Security properties:
  ! - Root directory is read from command-line arguments
  ! - User code NEVER has access to sys.argv
  ! - Root is resolved to absolute path and validated
  ! - User code CANNOT modify or inspect the root path
//]
def platformMain: Unit receives stdout =
  val argv: py.List = py.module("sys").argv.cast[py.List]
  val argc = argv.size

  if argc < 3 then
    println "Error: sandbox root and skills directory required"
    println "Usage: python3 out/task.py <sandbox-root> <skills-dir>"
    abort "Missing arguments"

  // Read sandbox root from command line
  val rootDir = os.path.abspath(argv.get(1).asString)

  // Validate the sandbox directory exists
  if !os.path.exists(rootDir) then
    println ("Error: sandbox root does not exist: " + rootDir)
    abort "Sandbox root not found"

  if !os.path.isdir(rootDir) then
    println ("Error: sandbox root is not a directory: " + rootDir)
    abort "Sandbox root is not a directory"

  // Read skills directory from command line
  val skillsDir = os.path.abspath(argv.get(2).asString)

  println ("Sandbox root: " + rootDir)
  println ("Skills dir:   " + skillsDir)

  println ""

  // Create implementations
  val sandboxedFs = new SandboxedFS(rootDir)
  val skillsImpl  = new SkillsImpl(skillsDir)
  val loggerImpl  = new LoggerImpl(stdout)
  val messageScript = "./send.sh"
  val actionsImpl = new ActionsImpl(sandboxedFs, messageScript)

  // Provide implementations via context parameters
  with
    AgentAPI.workspace = sandboxedFs,
    AgentAPI.skills = skillsImpl,
    AgentAPI.logger = loggerImpl,
    AgentAPI.actions = actionsImpl
  in
    AgentAPI.runTask()
end
