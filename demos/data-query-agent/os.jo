namespace os

private def module: py.Value = py.module("os")
private def pathModule: py.Value = module.path

interface WalkEntry
  def dirpath: String = py.value(this)[0].asString

  def filenames: py.List = py.value(this)[2].cast[py.List]
end

section path
  def isdir(path: String): Bool = pathModule.isdir(path).asBool

  def isfile(path: String): Bool = pathModule.isfile(path).asBool

  def join(base: String, paths: ..Any): String =
    pathModule.join(base, py.splice(py.list(..paths))).asString

  def normpath(path: String): String = pathModule.normpath(path).asString

  def abspath(path: String): String = pathModule.abspath(path).asString

  def relpath(path: String, start: String): String = pathModule.relpath(path, start).asString
end

def walk(top: String = "."): Any =
  module.walk(top)
