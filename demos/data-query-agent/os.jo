namespace jo.runtime.python.os

import jo.runtime.python.*

private def module: py.Value = py.importModule("os")
private def pathModule: py.Value = module.path

interface WalkEntry
  def dirpath: String = py.value(this)[0].cast[String]

  def filenames: py.List = py.value(this)[2].cast[py.List]
end

section path
  def isdir(path: String): Bool = pathModule.isdir(path).cast[Bool]

  def isfile(path: String): Bool = pathModule.isfile(path).cast[Bool]

  def join(base: String, paths: ..Any): String =
    pathModule.join(base, py.splice(py.list(..paths))).cast[String]

  def normpath(path: String): String = pathModule.normpath(path).cast[String]

  def abspath(path: String): String = pathModule.abspath(path).cast[String]

  def relpath(path: String, start: String): String = pathModule.relpath(path, start).cast[String]
end

def walk(top: String = "."): py.Iterator[WalkEntry] =
  module.walk(top).cast[py.Iterator[WalkEntry]]
