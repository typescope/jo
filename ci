#!/bin/bash

DIR=$(dirname "$0")

retcode=0

error() {
    echo "[error] testing $file failed!"
    retcode=1
}

check() {
    diff $1 $2 || error
    rm -f test-data*
}

################################################################################

# unit tests
scala-cli stack-lang/common/Base128.scala

################################################################################

# check that scripts work
bin/parse -time tests/pos/fact.stk  || exit 1
bin/type -time  tests/pos/fact.stk  || exit 1
bin/run  -time  tests/pos/fact.stk  || exit 1
bin/jsc  -time  tests/pos/fact.stk  || exit 1
bin/stac -time  tests/pos/fact.stk  || exit 1
bin/regc -time  tests/pos/fact.stk  || exit 1
bin/jo.dev build -time  tests/pos/fact.stk  || exit 1

bin/jo run -time tests/pos/fact.stk
bin/jo build -js -time tests/pos/fact.stk
bin/jo build -stack -time tests/pos/fact.stk
bin/jo build -reg -time tests/pos/fact.stk

################################################################################
# Positive tests


echo "Running positive tests"
echo

for item in $DIR/tests/pos/*; do

    if [[ $item == *.ignore ]]; then
        echo "ignore $item"
        continue
    elif [[ -d $item ]]; then
        # directory
        file=$(ls $item/*.stk)
        CHECK=$item/expect.check
        OUT=$item/actual.out
        exe=$item/prog.run
        js=$item/prog.js

    elif [[ -f $item ]] && [[ $item == *.stk ]]; then
        # single source file
        file=$item
        CHECK=$file.check
        OUT=$file.out
        exe=${file%.*}.run
        js=${file%.*}.js

        # Read options from first line if present
        OPTIONS=""
        first_line=$(head -n 1 "$file")
        if [[ $first_line == "// options:"* ]]; then
            OPTIONS=${first_line#"// options:"}
            OPTIONS=$(echo $OPTIONS | xargs)  # trim whitespace
        fi

    else
        continue
    fi

    echo "testing $item"

    # create empty check file
    if [ ! -f "$CHECK" ]; then
        touch "$CHECK"
    fi

    echo "  - eval"
    bin/jo run -testPickling $file $OPTIONS > $OUT 2>&1
    check $OUT $CHECK

    # Ast interpreter
    # bin/asti $file > $RES2 2>&1
    # check $RES1 $RES2

    # # layout 1
    echo "  - stac layout c1"
    bin/jo build -stack $file -checkTree -o $exe -layout c1 $OPTIONS
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # layout 2
    echo "  - stac layout c2"
    bin/jo build -stack $file -checkTree -o $exe -layout c2 $OPTIONS
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # fast linux
    echo "  - regc"
    bin/jo build -reg $file -checkTree -o $exe $OPTIONS
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # JavaScript
    echo "  - jsc"
    bin/jo build -js $file -checkTree -o $js $OPTIONS
    node $js > $OUT 2>&1
    check $OUT $CHECK
done

################################################################################
# Error message tests

echo
echo "Running error message tests"
echo

for item in $DIR/tests/warn/*; do

    if [[ $item == *.ignore ]]; then
        echo "ignore $item"
        continue

    elif [[ -d $item ]]; then
        # directory
        file=$(ls $item/*.stk)
        CHECK=$item/expect.check
        OUT=$item/actual.out

    elif [[ -f $item ]] && [[ $item == *.stk ]]; then
        # single source file
        file=$item
        CHECK=$file.check
        OUT=$file.out

        # Read options from first line if present
        OPTIONS=""
        first_line=$(head -n 1 "$file")
        if [[ $first_line == "// options:"* ]]; then
            OPTIONS=${first_line#"// options:"}
            OPTIONS=$(echo $OPTIONS | xargs)  # trim whitespace
        fi

    else
        continue
    fi

    echo "testing $item"

    bin/jo build -js -fatal-warnings $file $OPTIONS > $OUT
    check $OUT $CHECK
done

################################################################################
# Negative tests with positional error markers

echo
echo "Running positional error tests"
echo

scala-cli project.scala stack-lang -M negTest
if [[ $? != 0 ]]; then
  retcode=1
fi

################################################################################
# Custom integration tests

echo
echo "Running custom integration tests"
echo

for test_dir in $DIR/tests/custom/*/; do
    if [[ -f "$test_dir/test.sh" ]]; then
        "$test_dir/test.sh" || retcode=1
    fi
done

echo $retcode
exit $retcode
