#!/bin/bash

DIR=$(dirname "$0")

retcode=0
failed_tests=()

error() {
    test=$1
    echo "[error] testing $test failed!"
    failed_tests+=("$test")
    retcode=1
}

check() {
    diff $1 $2 || error "$file"
    rm -f test-data*
}

read_options() {
    OPTIONS=""
    first_line=$(head -n 1 "$1")
    if [[ $first_line == "// options:"* ]]; then
        OPTIONS=${first_line#"// options:"}
        OPTIONS=$(echo $OPTIONS | xargs)  # trim whitespace
    fi
}

prepare_test_item() {
    local item="$1"

    if [[ $item == *.ignore ]]; then
        echo "ignore $item"
        return 1
    elif [[ -d $item ]]; then
        # directory
        file=$(ls "$item"/*.jo)
        CHECK=$item/expect.check
        OUT=$item/actual.out
        exe=$item/prog.run
        js=$item/prog.js
        rb=$item/prog.rb
        py=$item/prog.py
    elif [[ -f $item ]] && [[ $item == *.jo ]]; then
        # single source file
        file=$item
        CHECK=$file.check
        OUT=$file.out
        exe=${file%.*}.run
        js=${file%.*}.js
        rb=${file%.*}.rb
        py=${file%.*}.py

        read_options "$file"
    else
        return 1
    fi

    return 0
}

run_mode() {
    mode="$1"

    case "$mode" in
      eval)
        echo "  - eval"
        bin/jo run -testPickling $file $OPTIONS > "$OUT" 2>&1
        check "$OUT" "$CHECK"
        ;;

      stac)
        echo "  - stac layout c1"
        bin/jo build -stack $file -checkTree -o "$exe" -layout c1 $OPTIONS
        "$exe" > "$OUT" 2>&1
        check "$OUT" "$CHECK"
        ;;

      reg)
        echo "  - regc"
        bin/jo build -reg $file -checkTree -o "$exe" $OPTIONS
        "$exe" > "$OUT" 2>&1
        check "$OUT" "$CHECK"
        ;;

      js)
        echo "  - jsc"
        bin/jo build -js $file -checkTree -o "$js" $OPTIONS
        node "$js" > "$OUT" 2>&1
        check "$OUT" "$CHECK"
        ;;

      ruby)
        echo "  - rbc"
        bin/jo build -ruby $file -checkTree -o "$rb" $OPTIONS
        ruby "$rb" > "$OUT" 2>&1
        check "$OUT" "$CHECK"
        ;;

      python)
        echo "  - pyc"
        bin/jo build -python $file -checkTree -o "$py" $OPTIONS
        python "$py" > "$OUT" 2>&1
        check "$OUT" "$CHECK"
        ;;

      *)
        echo "[error] unknown mode: $mode"
        retcode=1
        ;;
    esac
}

run_suite() {
    title="$1"
    pattern="$2"
    modes="$3"

    echo "Running $title tests"
    echo

    for item in $pattern; do
        prepare_test_item "$item" || continue

        echo "testing $item"

        # create empty check file
        if [ ! -f "$CHECK" ]; then
            touch "$CHECK"
        fi

        for mode in $modes; do
            run_mode "$mode"
        done
    done
}

################################################################################

# unit tests
scala-cli stack-lang/common/Base128.scala || error "Base128.scala"

################################################################################

# check that scripts work
bin/parse -time tests/pos/fact.jo  || exit 1
bin/type -time  tests/pos/fact.jo  || exit 1
bin/run  -time  tests/pos/fact.jo  || exit 1
bin/rbc  -time  tests/pos/fact.jo  || exit 1
bin/pyc  -time  tests/pos/fact.jo  || exit 1
bin/jsc  -time  tests/pos/fact.jo  || exit 1
bin/stac -time  tests/pos/fact.jo  || exit 1
bin/regc -time  tests/pos/fact.jo  || exit 1
bin/jo.dev build -time  tests/pos/fact.jo  || exit 1

bin/jo run -time tests/pos/fact.jo
bin/jo build -ruby -time tests/pos/fact.jo
bin/jo build -python -time tests/pos/fact.jo
bin/jo build -js -time tests/pos/fact.jo
bin/jo build -stack -time tests/pos/fact.jo
bin/jo build -reg -time tests/pos/fact.jo

# check doc
bin/jo doc -no-stdlib $(find lib -name '*.jo') -title "Jo Standard Library" -d stdlib-doc || exit 1

################################################################################
# Positive tests


run_suite "positive" "$DIR/tests/pos/*" "eval stac reg js ruby python"

################################################################################
# Numeric tests


run_suite "numeric" "$DIR/tests/numeric/*" "eval js ruby python"


################################################################################
# Stdlib tests


run_suite "stdlib" "$DIR/tests/stdlib/*/*.jo" "eval js ruby python reg"

################################################################################
# Performance tests

run_suite "performance" "$DIR/tests/performance/*.jo" "js ruby python reg"

################################################################################
# Error message tests

echo
echo "Running error message tests"
echo

for item in $DIR/tests/warn/*; do

    if ! prepare_test_item "$item"; then
        continue
    fi

    echo "testing $item"

    # scala native has difficult with unicode
    if [[ $item == *char-byte-range.jo ]]; then
      bin/jo.dev build -js -fatal-warnings $file $OPTIONS > $OUT
    else
      bin/jo build -js -fatal-warnings $file $OPTIONS > $OUT
    fi

    check $OUT $CHECK
done

################################################################################
# Custom integration tests

echo
echo "Running custom integration tests"
echo

for test_dir in $DIR/tests/custom/*/; do
    if [[ -f "$test_dir/test.sh" ]]; then
        "$test_dir/test.sh" || error "$test_dir"
    fi
done


################################################################################
# Demos

demos/process-monitor/build.sh || error "demos/process-monitor"
demos/data-table/build.sh || error "demos/data-table"
demos/data-table-query/build.sh || error "demos/data-table-query"
demos/sandbox-agent/build.sh || error "demos/sandbox-agent"

################################################################################
# Summary

echo
echo "========================================"
if [[ $retcode == 0 ]]; then
  echo "All tests passed!"
else
  echo "FAILED TESTS:"
  for test in "${failed_tests[@]}"; do
    echo "  - $test"
  done
fi
echo "========================================"
echo

exit $retcode
