#!/bin/bash

set -e

DIR=$(dirname "$0")

retcode=0

error() {
    echo "[error] testing $file failed!"
    retcode=1
}

check() {
    diff $1 $2 || error
}

for file in $DIR/tests/pos/*.stk; do
    echo "testing $file"
    CHECK=$file.check
    OUT=$file.out

    exe=${file%.*}.run
    js=${file%.*}.js
    bin/stki $file > $OUT 2>&1
    check $OUT $CHECK

    # Ast interpreter
    # bin/asti $file > $RES2 2>&1
    # check $RES1 $RES2

    # # layout 1
    bin/stkc $file -o $exe -p linux-x86-stack -layout c1
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # layout 2
    bin/stkc $file -o $exe -p linux-x86-stack -layout c2
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # layout 3
    bin/stkc $file -o $exe -p linux-x86-stack -layout c3
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # fast linux
    bin/stkc $file -o $exe -p linux-x86-reg
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # JavaScript
    bin/stkc $file -o $js -p js
    node $js > $OUT 2>&1
    check $OUT $CHECK
done

# neg tests
echo
echo "Running negative tests"
echo
scala-cli project.scala stack-lang -M negTest
if [[ $? != 0 ]]; then
  retcode=1
fi

echo $retcode
exit $retcode
