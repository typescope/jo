#!/bin/bash

set -e

DIR=$(dirname "$0")

retcode=0

error() {
    echo "[error] testing $file failed!"
    retcode=1
}

check() {
    diff $1 $2 || error
}

# check that scripts work
bin/parse tests/pos/fact.stk > /dev/null
bin/type  tests/pos/fact.stk > /dev/null
bin/run   tests/pos/fact.stk > /dev/null
bin/jsc   tests/pos/fact.stk > /dev/null
bin/smc   tests/pos/fact.stk > /dev/null
# bin/rmc   tests/pos/fact.stk


for item in $DIR/tests/pos/*.stk; do

    if [[ $item == *.ignore ]]; then
        echo "ignore $item"
        continue

    elif [[ -d $item ]]; then
        # directory
        file=$(ls $item/*.stk)
        CHECK=$item/expect.check
        OUT=$item/actual.out
        exe=$item/prog.run
        js=$item/prog.js

    elif [[ -f $item ]] && [[ $item == *.stk ]]; then
        # single source file
        file=$item
        CHECK=$file.check
        OUT=$file.out
        exe=${file%.*}.run
        js=${file%.*}.js

    else
        continue
    fi

    echo "testing $file"

    # create empty check file
    if [ ! -f "$CHECK" ]; then
        touch "$CHECK"
    fi

    echo "  - eval"
    bin/run $file > $OUT 2>&1
    check $OUT $CHECK

    # Ast interpreter
    # bin/asti $file > $RES2 2>&1
    # check $RES1 $RES2

    # # layout 1
    echo "  - smc layout c1"
    bin/stac $file -o $exe -layout c1
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # layout 2
    echo "  - smc layout c2"
    bin/stac $file -o $exe -layout c2
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # TODO fast linux
    # echo "  - rmc"
    # bin/regc $file -o $exe
    # $exe > $OUT 2>&1
    # check $OUT $CHECK

    # JavaScript
    echo "  - jsc"
    bin/jsc $file -o $js
    node $js > $OUT 2>&1
    check $OUT $CHECK
done

# neg tests
echo
echo "Running negative tests"
echo
scala-cli project.scala stack-lang -M negTest
if [[ $? != 0 ]]; then
  retcode=1
fi

echo $retcode
exit $retcode
