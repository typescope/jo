#!/bin/bash

DIR=$(dirname "$0")

retcode=0

error() {
    echo "[error] testing $file failed!"
    retcode=1
}

check() {
    diff $1 $2 || error
    rm -f test-data*
}

################################################################################

# unit tests
scala-cli stack-lang/common/Base128.scala

################################################################################

# check that scripts work
bin/parse -time tests/pos/fact.stk
bin/type -time tests/pos/fact.stk
bin/run  -time tests/pos/fact.stk
bin/jsc  -time  tests/pos/fact.stk
bin/stac -time  tests/pos/fact.stk
bin/regc -time  tests/pos/fact.stk

bin/run.native -time tests/pos/fact.stk
bin/jsc.native -time tests/pos/fact.stk
bin/stac.native -time tests/pos/fact.stk
bin/regc.native -time tests/pos/fact.stk

################################################################################
# Positive tests


echo "Running positive tests"
echo

for item in $DIR/tests/pos/*.stk; do

    if [[ $item == *.ignore ]]; then
        echo "ignore $item"
        continue
    elif [[ -d $item ]]; then
        # directory
        file=$(ls $item/*.stk)
        CHECK=$item/expect.check
        OUT=$item/actual.out
        exe=$item/prog.run
        js=$item/prog.js

    elif [[ -f $item ]] && [[ $item == *.stk ]]; then
        # single source file
        file=$item
        CHECK=$file.check
        OUT=$file.out
        exe=${file%.*}.run
        js=${file%.*}.js

    else
        continue
    fi

    echo "testing $file"

    # create empty check file
    if [ ! -f "$CHECK" ]; then
        touch "$CHECK"
    fi

    echo "  - eval"
    bin/run.native $file > $OUT 2>&1
    check $OUT $CHECK

    # Ast interpreter
    # bin/asti $file > $RES2 2>&1
    # check $RES1 $RES2

    # # layout 1
    echo "  - stac layout c1"
    bin/stac.native $file -checkTree -o $exe -layout c1
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # layout 2
    echo "  - stac layout c2"
    bin/stac.native $file -checkTree -o $exe -layout c2
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # fast linux
    echo "  - regc"
    bin/regc.native $file -checkTree -o $exe
    $exe > $OUT 2>&1
    check $OUT $CHECK

    # JavaScript
    echo "  - jsc"
    bin/jsc.native $file -checkTree -o $js
    node $js > $OUT 2>&1
    check $OUT $CHECK
done

################################################################################
# Error message tests

echo
echo "Running error message tests"
echo

for item in $DIR/tests/warn/*.stk; do

    if [[ $item == *.ignore ]]; then
        echo "ignore $item"
        continue

    elif [[ -d $item ]]; then
        # directory
        file=$(ls $item/*.stk)
        CHECK=$item/expect.check
        OUT=$item/actual.out

    elif [[ -f $item ]] && [[ $item == *.stk ]]; then
        # single source file
        file=$item
        CHECK=$file.check
        OUT=$file.out

    else
        continue
    fi

    echo "testing $file"

    bin/jsc.native -fatal-warnings $file > $OUT
    check $OUT $CHECK
done

################################################################################
# Negative tests with positional error markers

echo
echo "Running positional error tests"
echo

scala-cli project.scala stack-lang -M negTest
if [[ $? != 0 ]]; then
  retcode=1
fi

echo $retcode
exit $retcode
