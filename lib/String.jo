namespace jo

class String
  private def String() = abort "Cannot create new String instance"

  def size: Int = ...

  def get(i: Int): Char = ...

  def +(other: StringLike): String = ...

  def ==(other: String): Bool = ...

  def substring(from: Int, len: Int): String = ...

  def slice(from: Int, len: Int): String = this.substring from len
end

type StringLike = like String with [.toString]
