namespace jo.regex

import jo.*

section Engine
  type Pattern
  private[regex] defer def compilePattern(source: String, flags: String): Pattern

  //[ Raw backend primitive.
    !
    ! This is intentionally private so every successful match goes through
    ! `findAt`, which attaches named-group metadata before the `Match`
    ! escapes to user code.
  //]
  private defer def execPatternAt(pat: Pattern, input: String, pos: Int): Match | None

  private[regex] def findAt(regex: Regex, input: String, pos: Int): Match | None =
    match execPatternAt(regex.pat, input, pos)
      case m: Match => m.withGroupNames(regex.groupIndexByName)
      case None => None
end
