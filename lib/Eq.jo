namespace jo.Eq

import jo.Predef.Bool
import jo.Predef.Byte
import jo.Predef.Char
import jo.Predef.Int
import jo.Predef.String
import jo.Int.==

type Eq[T] = {
  def eq(this: T, that: T): Bool
}

section Defaults
  auto def byteEq: Eq[Byte] = (a, b) => a == b
  auto def charEq: Eq[Char] = (a, b) => a == b
  auto def intEq: Eq[Int] = (a, b) => a == b
  auto def stringEq: Eq[String] = (a, b) => a == b
end
