namespace jo.Array

import jo.Predef.*

//------------------------------------------------------------------------------
//
// Arrays
//

//[ Generic interface for Array
  !
  ! In causal programming, programmers might not pay too much attention to the
  ! minutia details of different array types, which only is only relevant in
  ! performance tuning.
  !
  ! In high-performance setting, users should use the concrete classes instead
  ! to avoid the dispatch cost.
//]
interface Array[T]
  def get(i: Int): T

  def size: Int

  def set(i: Int, value: T): Unit

  def clone: Array[T]
end

//[ Generic Array creation
  !
  ! The type of an array must be statically known in creation. An auto parameter
  ! ArrayBuilder[T] can be passed from the call site where `T` is known to the
  ! use site.
  !
  ! The compiler will automatically synthesize an auto of type ArrayBuilder[T]
  ! if `T` is a known type.
//]
def create[T](size: Int)(auto builder: ArrayBuilder[T]): Array[T] =
  builder.build(size)

//------------------------------------------------------------------------------
//
// IntArray

def IntArray(size: Int): IntArray =
  val arr = IntArray.create size
  new IntArray(arr)

class IntArray
  private val arr: Platform.IntArray

  private[Array] def IntArray(arr: Platform.IntArray) =
    this.arr = arr

  def get(i: Int): Int = IntArray.get this.arr i

  def size: Int = IntArray.size this.arr

  def set(i: Int, value: Int): Unit =
    IntArray.set this.arr i value

  def clone: Array[Int] = IntArray.clone(this)

  view Array[Int]
end

private section IntArray
  defer def create(size: Int): Platform.IntArray
  defer def get(arr: Platform.IntArray, i: Int): Int
  defer def set(arr: Platform.IntArray, i: Int, value: Int): Unit
  defer def size(arr: Platform.IntArray): Int

  // TODO: fast platform clone might exist
  def clone(arr: IntArray): IntArray =
    val arr2 = IntArray(arr.size)
    var i = 0
    var len = arr.size
    while i < len do
      arr2[i] = arr[i]
      i = i + 1
    end
    arr2
end

