//------------------------------------------------------------------------------
//
// CharArray

def CharArray(size: Int): CharArray =
  val arr = IntArray size
  new CharArray(arr)

class CharArray
  private val arr: IntArray

  private[Array] def CharArray(arr: IntArray) =
    this.arr = arr

  def get(i: Int): Char = this.arr[i].toChar

  def size: Int = this.arr.size

  def set(i: Int, value: Char): Unit =
    this.arr[i] = value

  def clone: Array[Char] = new CharArray(IntArray.clone(this.arr))

  view Array[Char]
end

