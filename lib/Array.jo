private section ByteArray
  defer def create(size: Int): Platform.ByteArray
  defer def get(arr: Platform.ByteArray, i: Int): Byte
  defer def set(arr: Platform.ByteArray, i: Int, value: Byte): Unit
  defer def size(arr: Platform.ByteArray): Int

  // TODO: fast platform clone might exist
  def clone(arr: ByteArray): ByteArray =
    val arr2 = ByteArray(arr.size)
    var i = 0
    var len = arr.size
    while i < len do
      arr2[i] = arr[i]
      i = i + 1
    end
    arr2

end

//------------------------------------------------------------------------------
//
// BoolArray
//
// Bool array is directly implemented in Jo based on ByteArray.

def BoolArray(size: Int): BoolArray =
  // Adding one byte is OK and makes code simple
  new BoolArray(size, ByteArray(size / 8 + 1))

class BoolArray
  private val arr: ByteArray
  private val len: Int

  private[Array] def BoolArray(size: Int, arr: ByteArray) =
    this.arr = arr
    this.len = size

  def get(i: Int): Bool =
    val byte = arr[i / 8]
    byte.toInt & (1 << (i % 8)) > 0

  def size: Int = this.len

  def set(i: Int, value: Bool): Unit =
    val byte = arr[i / 8]
    val byte2 =
      if value then (byte.toInt | (1 << (i % 8))).toByte
      else (byte.toInt & (0xFF ^ (1 << (i % 8)))).toByte // TODO: use ~
    arr[i / 8] = byte2

  def clone: Array[Bool] =
    new BoolArray(this.size, ByteArray.clone(this.arr))

  view Array[Bool]
end

//------------------------------------------------------------------------------
//
// ObjectArray

//[ The type parameter `T` must be a known non-numeric type
  !
  ! In generic code, users can use an auto for `ArrayBuilder[T]`. The
  ! compiler will automatically synthesize a value if `T` is a known type.
//]
def ObjectArray[T](size: Int): ObjectArray[T] =
  new ObjectArray(ObjectArray.create[T] size)

class ObjectArray[T]
  private val arr: Platform.ObjectArray[T]

  private[Array] def ObjectArray(arr: Platform.ObjectArray[T]) =
    this.arr = arr

  def get(i: Int): T = ObjectArray.get this.arr i

  def size: Int = ObjectArray.size this.arr

  def set(i: Int, value: T): Unit =
    ObjectArray.set this.arr i value

  // TODO: fast platform clone might exist
  def clone: Array[T] =
    val arr2 = new ObjectArray(ObjectArray.create[T] this.size)
    var i = 0
    var len = this.size
    while i < len do
      arr2[i] = this[i]
      i = i + 1
    end
    arr2

  view Array[T]
end

private section ObjectArray
  defer def create[T](size: Int): Platform.ObjectArray[T]
  defer def get[T](arr: Platform.ObjectArray[T], i: Int): T
  defer def set[T](arr: Platform.ObjectArray[T], i: Int, value: T): Unit
  defer def size[T](arr: Platform.ObjectArray[T]): Int
end

//[ Platform array types
  !
  ! The concrete implementation is up to the specific platform.
  ! Made visible to runtime implementations via private[jo] scope.
//]
private[jo] section Platform
  type ByteArray
  type IntArray
  type FloatArray
  type ObjectArray[T]
end

//[ Used to create an array for a type parameter T
  !
  ! The type of an array must be statically known in creation. An auto parameter
  ! ArrayBuilder[T] can be passed from the call site where `T` is known to the
  ! use site.
  !
  ! The compiler will automatically synthesize an auto of type ArrayBuilder[T]
  ! if `T` is a known type.
//]
interface ArrayBuilder[T]
  def build(size: Int): Array[T]
end

section ArrayBuilder
  object IntArrayBuilder
    def build(size: Int): Array[Int] = IntArray(size)
    view ArrayBuilder[Int]
  end

  object FloatArrayBuilder
    def build(size: Int): Array[Float] = FloatArray(size)
    view ArrayBuilder[Float]
  end

  object CharArrayBuilder
    def build(size: Int): Array[Char] = CharArray(size)
    view ArrayBuilder[Char]
  end

  object ByteArrayBuilder
    def build(size: Int): Array[Byte] = ByteArray(size)
    view ArrayBuilder[Byte]
  end

  object BoolArrayBuilder
    def build(size: Int): Array[Bool] = BoolArray(size)
    view ArrayBuilder[Bool]
  end
end
