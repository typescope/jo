namespace stk.Eq

import stk.Predef.Bool
import stk.Predef.Byte
import stk.Predef.Char
import stk.Predef.Int
import stk.Predef.String
import stk.Int.==

type Eq[T] = object {
  def eq(this: T, that: T): Bool
}

section Defaults
  auto def byteEq: Eq[Byte] = (a, b) => a == b
  auto def charEq: Eq[Char] = (a, b) => a == b
  auto def intEq: Eq[Int] = (a, b) => a == b
  auto def stringEq: Eq[String] = (a, b) => a == b
end
