namespace jo

class Pair[S, T](fst: S, snd: T)
  def toString(auto
      lhsShow: Show[S] with [[S].toString],
      rhsShow: Show[T] with [[T].toString])
  : String =
    lhsShow.show(fst) + " ~ " + rhsShow.show(snd)


type [S] ~ [T] = Pair[S, T]

def (a: S) ~ [S, T] (b: T): S ~ T = Pair a b

pattern (a: S) ~[S, T](b: T): S ~ T = case p then a = p.fst, b = p.snd
