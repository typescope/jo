namespace jo

class Pair[S, T](a: S, b: T)
  def toString(auto
      lhsShow: Show[S] with [[S].toString],
      rhsShow: Show[T] with [[T].toString])
  : String =
    lhsShow.show(a) + " ~ " + rhsShow.show(b)


type [S] ~ [T] = Pair[S, T]

def (a: S) ~ [S, T] (b: T): S ~ T = Pair a b

pattern (a: S) ~[S, T](b: T): S ~ T = case p then a = p.a, b = p.b
