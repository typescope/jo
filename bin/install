#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ACTIVE_BIN="${JO_INSTALL_BIN:-$HOME/.local/bin/jo}"
ACTIVE_BIN_DIR="$(dirname "$ACTIVE_BIN")"

BUILD_NATIVE=false
for arg in "$@"; do
  case "$arg" in
    --native)
      BUILD_NATIVE=true
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: bin/install [--native]"
      echo "  --native    Build a native executable (slower build, faster startup, no JVM)"
      exit 1
      ;;
  esac
done

color() {
  local code="$1"
  local text="$2"
  printf '\033[%sm%s\033[0m' "$code" "$text"
}

green() { color "32" "$1"; }
blue() { color "34" "$1"; }
yellow() { color "33" "$1"; }
dim() { color "2" "$1"; }

confirm_remove() {
  local path="$1"
  printf "%s '%s'. %s " "$(yellow "Already exists:")" "$path" "$(dim "Remove it first? [y/N]")"
  read -r answer
  case "$answer" in
    y|Y|yes|YES|Yes) rm -rf "$path" ;;
    *) echo "$(yellow "Install cancelled.")"; exit 1 ;;
  esac
}

# Build the compiler artifacts (launcher, payload, bundled libraries) via the
# build script, the single source of truth for how a compiler is produced.
echo "$(blue "Building Jo from source...")"

if [ "$BUILD_NATIVE" = true ]; then
  PAYLOAD="jo.native"
  ( cd "$ROOT_DIR" && ./build --native )
else
  PAYLOAD="jo.jar"
  ( cd "$ROOT_DIR" && ./build --fat )
fi

VERSION="$("$ROOT_DIR/bin/jo" --version)"
INSTALL_DIR="$HOME/.jo/compilers/$VERSION"
INSTALL_BIN_DIR="$INSTALL_DIR/bin"

echo "$(blue "Installing compiler $VERSION to $INSTALL_DIR ...")"

if [ -e "$INSTALL_DIR" ] || [ -L "$INSTALL_DIR" ]; then
  confirm_remove "$INSTALL_DIR"
fi

mkdir -p "$INSTALL_DIR" "$ACTIVE_BIN_DIR"
mkdir -p "$INSTALL_BIN_DIR"
cp "$ROOT_DIR/LICENSE" "$INSTALL_DIR/LICENSE"
cp -r "$ROOT_DIR/libs" "$INSTALL_DIR/"
cp -r "$ROOT_DIR/assets" "$INSTALL_DIR/"

# Reuse the launcher and payload produced by the build (same layout as the
# release tarball: bin/jo runs the sibling bin/$PAYLOAD).
cp "$ROOT_DIR/bin/jo" "$INSTALL_BIN_DIR/jo"
cp "$ROOT_DIR/bin/$PAYLOAD" "$INSTALL_BIN_DIR/$PAYLOAD"
chmod +x "$INSTALL_BIN_DIR/jo" "$INSTALL_BIN_DIR/$PAYLOAD"

if [ -e "$ACTIVE_BIN" ] || [ -L "$ACTIVE_BIN" ]; then
  confirm_remove "$ACTIVE_BIN"
fi

cat > "$ACTIVE_BIN" <<EOF
#!/bin/bash
exec "$INSTALL_BIN_DIR/jo" "\$@"
EOF
chmod +x "$ACTIVE_BIN"

echo "$(green "Installed compiler:")"
echo "  $INSTALL_BIN_DIR/jo"
echo
echo "$(green "Active command:")"
echo "  $ACTIVE_BIN"
echo "  -> $INSTALL_BIN_DIR/jo"

case ":$PATH:" in
  *":$ACTIVE_BIN_DIR:"*) ;;
  *)
    echo
    echo "$(dim "Add '$ACTIVE_BIN_DIR' to your PATH if needed.")"
    ;;
esac
