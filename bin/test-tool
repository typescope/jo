#!/bin/bash

files=(
    stack-lang/tool/toml/Toml.scala
    stack-lang/tool/toml/TomlScanner.scala
    stack-lang/tool/toml/TomlParser.scala
    stack-lang/tool/BuildSpec.scala
    stack-lang/tool/LockFile.scala
    stack-lang/tool/PackageMeta.scala
    stack-lang/tool/Graph.scala
    stack-lang/tool/GraphPrinter.scala
    stack-lang/tool/GraphCheck.scala
)

FILES=${files[*]}

retcode=0
failed=()

run_file_tests() {
    local title="$1"
    local dir="$2"
    local main_class="$3"
    shift 3
    local extra_args=("$@")

    echo "=== $title ==="

    for toml_file in "$dir"/*/jo.toml; do
        [ -f "$toml_file" ] || continue
        txt_file="${toml_file%.toml}.txt"
        out_file="${toml_file%.toml}.out"

        if [ ! -f "$txt_file" ]; then
            scala-cli project.scala $FILES --main-class "$main_class" -- "${extra_args[@]}" "$toml_file" > "$txt_file" 2>/dev/null
            echo "  generated: $txt_file"
            continue
        fi

        scala-cli project.scala $FILES --main-class "$main_class" -- "${extra_args[@]}" "$toml_file" > "$out_file" 2>/dev/null
        if diff -q "$txt_file" "$out_file" > /dev/null 2>&1; then
            echo "  ok: $toml_file"
            rm -f "$out_file"
        else
            echo "FAIL: $toml_file"
            diff "$txt_file" "$out_file"
            retcode=1
            failed+=("$toml_file")
        fi
    done
}

run_file_tests "Graph resolution" tests/tool-graph tool.graphCheck

echo
if [ $retcode -eq 0 ]; then
    echo "All tool tests passed."
else
    echo "FAILED: ${failed[*]}"
fi

exit $retcode
