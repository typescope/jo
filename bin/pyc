#!/bin/bash

files=(
    # parser
    stack-lang/ast/*.scala
    stack-lang/common/*.scala
    stack-lang/parsing/*.scala
    stack-lang/reporting/*.scala

    # typer
    stack-lang/typing/*.scala

    stack-lang/sast/*.scala

    stack-lang/pickle/*.scala

    # python compiler
    stack-lang/python/*.scala

    stack-lang/phases/*.scala

    # cli
    stack-lang/cli/OptionParser.scala

)

FILES=${files[*]}

scala-cli project.scala $FILES --main-class python.Compiler -- "$@"
