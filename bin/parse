#!/bin/bash

files=(
    stack-lang/Ast.scala
    stack-lang/Diagnostics.scala
    stack-lang/IO.scala
    stack-lang/Parser.scala
    stack-lang/Positions.scala
    stack-lang/Reporter.scala
    stack-lang/Scanner.scala
