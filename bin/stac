#!/bin/bash

files=(
    # parser
    stack-lang/ast/*.scala
    stack-lang/common/*.scala
    stack-lang/parsing/*.scala
    stack-lang/reporting/*.scala

    # typer
    stack-lang/typing/*.scala

    stack-lang/sast/*.scala

    stack-lang/pickle/*.scala

    # native compiler
    stack-lang/native/*.scala
    stack-lang/native/arch/*.scala
    stack-lang/native/os/*.scala
    stack-lang/native/stack/*.scala
    stack-lang/native/runtime/*.scala

    stack-lang/phases/*.scala

    # cli
    stack-lang/cli/OptionParser.scala
)

FILES=${files[*]}

scala-cli project.scala $FILES --main-class native.stack.StackMachine -- "$@"
