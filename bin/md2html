#!/bin/bash

set -e

# Check if pandoc is available
if ! command -v pandoc >/dev/null 2>&1; then
  echo "Error: pandoc is required but not installed"
  echo "Install pandoc: https://pandoc.org/installing.html"
  exit 1
fi

# Parse command line arguments
if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "Usage: $0 <input.md> [output.html]"
  echo "Convert Markdown to HTML with GitHub-style CSS"
  echo ""
  echo "Examples:"
  echo "  $0 README.md                 # Creates README.html"
  echo "  $0 README.md docs/index.html # Creates docs/index.html"
  exit 1
fi

INPUT_FILE="$1"
OUTPUT_FILE="${2:-${INPUT_FILE%.md}.html}"

# Check if input file exists
if [ ! -f "$INPUT_FILE" ]; then
  echo "Error: Input file '$INPUT_FILE' not found"
  exit 1
fi

# Create output directory if it doesn't exist
OUTPUT_DIR=$(dirname "$OUTPUT_FILE")
if [ "$OUTPUT_DIR" != "." ] && [ ! -d "$OUTPUT_DIR" ]; then
  mkdir -p "$OUTPUT_DIR"
fi

# Extract title from input file for metadata
TITLE=$(basename "$INPUT_FILE" .md)

# Create temporary CSS file with proper path that won't be deleted
CSS_FILE=$(mktemp)
cat > "$CSS_FILE" << 'EOF'
html {
  background-color: #f6f8fa;
}

body {
  max-width: 1012px;
  margin: 0 auto;
  padding: 45px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  line-height: 1.5;
  color: #24292e;
  background-color: #ffffff;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
  border-radius: 6px;
  margin-top: 20px;
  margin-bottom: 20px;
}

h1, h2, h3, h4, h5, h6 {
  border-bottom: 1px solid #eaecef;
  padding-bottom: 0.3em;
  margin-top: 24px;
  margin-bottom: 16px;
  font-weight: 600;
  line-height: 1.25;
}

h1 { font-size: 2em; }
h2 { font-size: 1.5em; }
h3 { font-size: 1.25em; }

p {
  margin-bottom: 16px;
}

code {
  background-color: #f6f8fa;
  padding: 0.2em 0.4em;
  border-radius: 3px;
  font-size: 85%;
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
}

pre {
  background-color: #f6f8fa;
  padding: 16px;
  border-radius: 6px;
  overflow: auto;
  font-size: 85%;
  line-height: 1.45;
}

pre code {
  background-color: transparent;
  padding: 0;
  border-radius: 0;
  font-size: 100%;
}

blockquote {
  border-left: 0.25em solid #dfe2e5;
  padding: 0 1em;
  color: #6a737d;
  margin: 16px 0;
}

ul, ol {
  padding-left: 2em;
  margin-bottom: 16px;
}

li {
  margin-bottom: 0.25em;
}

table {
  border-spacing: 0;
  border-collapse: collapse;
  margin-bottom: 16px;
}

table th, table td {
  padding: 6px 13px;
  border: 1px solid #dfe2e5;
}

table th {
  background-color: #f6f8fa;
  font-weight: 600;
}

a {
  color: #0366d6;
  text-decoration: none;
}

a:hover {
  text-decoration: underline;
}

hr {
  border: 0;
  border-bottom: 1px solid #eaecef;
  margin: 24px 0;
}

/* Center aligned content */
h1[align="center"], h3[align="center"], p[align="center"] {
  text-align: center;
}
EOF

# Generate HTML with embedded CSS
cat > "$OUTPUT_FILE" << EOF
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="" xml:lang="">
<head>
  <meta charset="utf-8" />
  <meta name="generator" content="pandoc" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
  <title>$TITLE</title>
  <style>
$(cat "$CSS_FILE" | sed 's/^/    /')
  </style>
</head>
<body>
$(pandoc "$INPUT_FILE")
</body>
</html>
EOF

# Clean up temporary files
rm "$CSS_FILE"

echo "Generated $OUTPUT_FILE from $INPUT_FILE with GitHub-style CSS"