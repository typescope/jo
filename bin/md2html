#!/bin/bash

set -e

# Check if pandoc is available
if ! command -v pandoc >/dev/null 2>&1; then
  echo "Error: pandoc is required but not installed"
  echo "Install pandoc: https://pandoc.org/installing.html"
  exit 1
fi

# Parse command line arguments
if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "Usage: $0 <input.md> [output.html]"
  echo "Convert Markdown to HTML with GitHub-style CSS"
  echo ""
  echo "Examples:"
  echo "  $0 README.md                 # Creates README.html"
  echo "  $0 README.md docs/index.html # Creates docs/index.html"
  exit 1
fi

INPUT_FILE="$1"
OUTPUT_FILE="${2:-${INPUT_FILE%.md}.html}"

# Check if input file exists
if [ ! -f "$INPUT_FILE" ]; then
  echo "Error: Input file '$INPUT_FILE' not found"
  exit 1
fi

# Create output directory if it doesn't exist
OUTPUT_DIR=$(dirname "$OUTPUT_FILE")
if [ "$OUTPUT_DIR" != "." ] && [ ! -d "$OUTPUT_DIR" ]; then
  mkdir -p "$OUTPUT_DIR"
fi

# Extract title from input file for metadata
TITLE=$(basename "$INPUT_FILE" .md)

# Use external CSS files

# Generate HTML with embedded CSS
cat > "$OUTPUT_FILE" << EOF
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="" xml:lang="">
<head>
  <meta charset="utf-8" />
  <meta name="generator" content="pandoc" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
  <title>$TITLE</title>
  <style>
    /* Center layout styling */
$(cat "docs/css/center-layout.css" | sed 's/^/    /')

    /* Highlight.js modern theme */
$(cat "docs/css/highlight-modern.css" | sed 's/^/    /')
  </style>
  <script>
$(cat "docs/js/highlight.min.js")
  </script>
  <script>
$(cat "docs/js/jo.js")
  </script>
  <script>
    // Highlight all standard code blocks
    hljs.highlightAll();

    // Manually process Jo code blocks generated by pandoc
    document.querySelectorAll('pre.jo code').forEach(function(codeBlock) {
      // Set the language class that highlight.js expects
      codeBlock.className = 'language-jo hljs';

      // Try to highlight with explicit language
      const result = hljs.highlight(codeBlock.textContent, {language: 'jo'});
      codeBlock.innerHTML = result.value;
    });
  </script>
</head>
<body>
$(pandoc "$INPUT_FILE")
</body>
</html>
EOF

# No temporary files to clean up

echo "Generated $OUTPUT_FILE from $INPUT_FILE with GitHub-style CSS"
