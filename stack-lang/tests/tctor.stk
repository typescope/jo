type List[T] = <Nil, Cons [head: T, tail: List[T]]>;

val a: List[Int] = #Nil of List[Int];
val b: List[Int] = #Cons [head = 5, tail = a] of List[Int];
val c: List[Int] = #Cons [head = 20, tail = b] of List[Int];

fun foreach(l: List[Int]): Void =
  match l
    case #Nil =>

    case #Cons xs =>
      xs.head p
      xs.tail foreach
  end;

type Pair[T] = [a: T, b: T];
val x: Pair[Int] = [a = 36, b = 49];

x.a p x.b p

c foreach
