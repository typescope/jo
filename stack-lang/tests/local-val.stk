fun fact(n) =
  if n 0 == then 1
  else
    val r = n 1 - fact;
    r n *
  end;

fun mul(m, n) =
  if (m 0 ==) (n 0 ==) or then 0
  else
    if 1 m & 0 == then
      val a = m 1 >> n mul;
      a a +
    else
      val b = m 1 >> n mul;
      b b + n +
    end
  end;

fun test1() =
  val a = 0 fact;
  val b = 4 fact;
  val c = 5 fact;
  a p
  b p
  c p
  2 fact;

test1 p
2 3 mul p
0 3 mul p
3 0 mul p
5 6 mul p
