param indent: Int

fun line(text: String): Unit =
  var i = 0
  while i < indent do
    printChar ' '
    i <- i + 1
  println text

type Printer = String => Unit receives indent

fun makeLinePrinter(): Printer =
  (text) => line text

fun main =
  val f = makeLinePrinter with indent = 5
  f "hello, world!" with indent = 10
