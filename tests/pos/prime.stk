type List = <Nil, Cons Int * List>

fun isPrime(primes: List, n: Int): Bool =
  match primes
    case #Nil => true
    case #Cons x xs =>
      if n x % 0 == then
        false
      else
        xs n isPrime

fun prime(primes: List, cur: Int, until: Int): Void =
  if cur until < then
    if primes cur isPrime then
      cur p
      val primes2: List = #Cons cur primes of List
      primes2 (1 cur +) until prime
    else
      primes (1 cur +) until prime

fun primeUntil(until: Int): Void =
  var primes: List = #Cons 2 (#Nil of List) of List
  var cur = 3;
  while cur until < do
    if primes cur isPrime then
      cur p
      primes = #Cons cur primes of List;
    end
    cur = cur 1 +;

(#Cons 2 (#Nil of List) of List) 3 100 prime

100 primeUntil
