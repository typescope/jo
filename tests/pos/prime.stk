type List = <Nil, Cons Int * List>

fun isPrime(primes: List, n: Int): Bool =
  match primes
    case #Nil => true
    case #Cons(x, xs) =>
      if n % x == 0 then
        false
      else
        isPrime xs n

fun prime(primes: List, cur: Int, until: Int): Void =
  if cur < until then
    if isPrime primes cur then
      cur p
      val primes2: List = #Cons(cur, primes)
      prime primes2 (1 + cur) until
    else
      prime primes (1 + cur) until

fun primeUntil(until: Int): Void =
  var primes: List = #Cons(2, #Nil)
  var cur = 3
  while cur < until do
    if isPrime primes cur then
      cur p
      primes = #Cons(cur, primes) as List
    end
    cur = cur + 1

prime #Cons(2, #Nil) 3 100

primeUntil 100
