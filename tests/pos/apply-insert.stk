type List[T] = #Nil | #Cons(head: T, tail: List[T])

fun List = object {
  def apply[T](a: T): List[T] = #Cons(a, #Nil)
}

fun foo(): Int = 30
fun bar: Int = 20

fun main =
  foo()
  bar()

  match List(4)
   case #Cons(a, _) => a p
   case _ =>

  match List 5
   case #Cons(a, _) => a p
   case _ =>
