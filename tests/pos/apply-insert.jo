union Lst[T] = Nil | Cons(head: T, tail: Lst[T])

def Lst = {
  def apply[T](a: T): Lst[T] = Cons a Nil
}

def foo(): Int = 30
def bar: Int = 20

def main =
  foo()
  bar()

  match Lst.apply(4)
   case Cons(a, _) => println a
   case _ =>

  match Lst 5
   case Cons(a, _) => println a
   case _ =>
