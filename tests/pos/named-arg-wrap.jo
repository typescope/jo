import jo.compile.Mixed

// Named args on regular functions are wrapped with namedArg
def greet(greeting: String, name: String): String =
  greeting + ", " + name + "!"

// Named args in varargs with NamedArg element type
def collect(args: ..Mixed[String]): String = args.join ", "

def main =
  println(greet(name = "World", greeting = "Hello"))

  println(collect("a", "b"))              // positional only
  println(collect(foo = "bar", baz = "qux")) // named — wrapped with namedArg
  println(collect("a", key = "b"))           // mixed
