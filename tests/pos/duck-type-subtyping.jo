// Define adapter function
def intToStr(x: Int): String = "converted"

type StringLike = String :- [intToStr, .toString]
type Printable = String :- [.toString]

// Test functions with duck type parameters
def test1(x: StringLike): String = x
def test2(x: String): StringLike = x
def test3(x: StringLike): Printable = x
def test4(x: Printable): StringLike = x

def main: Unit = pass
