// https://mathworld.wolfram.com/TAKFunction.html

def tak(x: Int, y: Int, z: Int): Int =
    if x <= y then
      y
    else
      val a = tak (x - 1) y z
      val b = tak (y - 1) z x
      val c = tak (z - 1) x y
      tak a b c

def main =
  tak 1 1 1 p
  tak 1 2 3 p
  tak 2 3 1 p
  tak 3 2 1 p

  tak 3 4 5 p
  tak 10 15 13 p
