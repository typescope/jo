class Complex(real: Int, image: Int)

section Complex

  def (c1: Complex) + (c2: Complex): Complex =
    Complex
      c1.real + c2.real
      c1.image + c2.image

  def (c1: Complex) - (c2: Complex): Complex =
    Complex
      c1.real - c2.real
      c1.image - c2.image

  def (c1: Complex) * (c2: Complex): Complex =
    Complex
      c1.real * c2.real - c1.image * c2.image
      c1.real * c2.image + c1.image * c2.real

  def (c: Complex) show: String = "\{c.real} + \{c.image}i"
end

def main =
  val c1 = Complex 1 3
  val c2 = Complex 2 4
  val c3 = Complex 1 5
  val c4 = Complex> c1 + c2 * c3

  println (Complex> c4 show)
