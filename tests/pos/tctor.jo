type List[T] = Nil | Cons(head: T, tail: List[T])


def foreach(l: List[Int]): Unit =
  match l
    case Nil =>

    case Cons(xs) =>
      println xs.head
      foreach xs.tail
  end

class Pair[T](a: T, b: T)


type A[T] = {a: Int, b: A[T]}
type B[T] = {a: Int, b: B[T]}

def test2[T](o: A[T]): B[T] = o

def main =
  val a: List[Int] = Nil
  val b: List[Int] = Cons(head: 5, tail: a)
  val c: List[Int] = Cons(head: 20, tail: b)

  val x: Pair[Int] = Pair 36 49

  println x.a
  println x.b

  foreach c
