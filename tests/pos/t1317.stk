type B = { b: Int }
type C = { c: Int }

type Either[S, T] = <Left S, Right T >
type List[T] = <Cons T * List[T], Nil>

fun list[T](a: T, b: T): List[T] =
  #Cons a (#Cons b #Nil)

fun left[U, V](a: U): Either[U, V] = #Left a
fun right[X, Y](a: Y): Either[X, Y] = (#Right a)

list
  left  { b = 3 }
  right { c = 3 }
