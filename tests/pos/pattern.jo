class Student(name: String, sex: Bool, age: Int)

pattern Name(name: String): Student =
  case Student name _ _

pattern InferRes(name: String, sex: Bool, age: Int): Student =
  case Student name sex age

pattern Type(s: Student): Student = case s: Student

def test(s: Student) =
  match s
    case Name n => println n

  match s
    case InferRes n _ _ => println n

  match s
    case Student n s a => println n

  val u = match s case Type u => u
  match u
    case Student n s a => println n

def test2(a: Option[String]) =
  match a
    case Some s => println s
    case None => println "none"

def main =
  test (Student "bla" true 23)

  test2 (Some "abc")

  test2 None
