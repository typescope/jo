param indent: Int = 7

def localOnly(): Int receives none =
  indent

def viaAllow(): Int receives indent =
  allow none in indent

def viaExplicitNone(): Int receives indent =
  localOnly()

def main receives IO.stdout =
  println:
    with indent = 100 in localOnly()

  println:
    with indent = 200 in viaAllow()

  println:
    with indent = 300 in viaExplicitNone()
