type ..[T] = List[T]

def print(l: ..String): Unit =
  l.foreach s => println s

data Pair[A, B](lhs: A, rhs: B)

type [A] ~ [B] = Pair[A, B]
def (lhs: A) ~[A, B](rhs: B): A ~ B = Pair lhs rhs

def main =
  print
    List "hello" "world!"

  val list: List Int = List 3 5 8

  val a = 1 ~ "one"
  println a.rhs
