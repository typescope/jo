// https://mathworld.wolfram.com/TAKFunction.html

def tak(x: Int, y: Int, z: Int): Int =
    if x <= y then
      y
    else
      val a = tak (x - 1) y z
      val b = tak (y - 1) z x
      val c = tak (z - 1) x y
      tak a b c

def main =
  println (tak 1 1 1)
  println (tak 1 2 3)
  println (tak 2 3 1)
  println (tak 3 2 1)

  println (tak 3 4 5)
  println (tak 10 15 13)
