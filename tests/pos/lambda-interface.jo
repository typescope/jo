// Test for lambda interface functionality
// A lambda interface is an interface with exactly one abstract method (SAM type)

// Simple lambda interfaces (Single Abstract Method interfaces)
interface Predicate[T]
  def test(x: T): Bool
  def notOK(x: T): Bool = ! test(x)
end

interface Transformer[T, U]
  def transform(x: T): U
end

interface BinaryOp[T]
  def apply(x: T, y: T): T
end

interface Runnable
  def run(): Unit
end

interface Supplier[T]
  def get(): T
end

interface Logger
  def log(msg: String): Unit receives IO.stdout
end

// Function that accepts a Predicate interface
def testPredicate(x: Int, pred: Predicate[Int]): Bool =
  pred.test(x)
end

// Function that accepts a Transformer interface
def testTransformer(x: Int, trans: Transformer[Int, String]): String =
  trans.transform(x)
end

// Function that accepts a BinaryOp interface
def testBinaryOp(x: Int, y: Int, op: BinaryOp[Int]): Int =
  op.apply(x, y)
end

// Function that accepts a Runnable interface
def testRunnable(task: Runnable) receives IO.stdout =
  println("Executing task...")
  task.run()
  println("Task complete")
end

// Function that accepts a Supplier interface
def testSupplier(supplier: Supplier[Int]): Int =
  supplier.get()
end

// Function that accepts a Logger interface
def testLogger(logger: Logger) receives IO.stdout =
  logger.log("Test message from logger")
end

def main receives IO.stdout =
  // Test 1: Predicate with lambda
  println("=== Test 1: Predicate ===")
  val isEven = testPredicate(4, x => x % 2 == 0)
  println("Is 4 even? " + isEven)
  val isOdd = testPredicate(5, x => x % 2 == 0)
  println("Is 5 even? " + isOdd)

  // Test 2: Transformer with lambda
  println("")
  println("=== Test 2: Transformer ===")
  val str1 = testTransformer(42, x => "Value: " + x)
  println(str1)

  // Test 3: BinaryOp with lambda
  println("")
  println("=== Test 3: BinaryOp ===")
  val sum = testBinaryOp(10, 20, (x, y) => x + y)
  println("10 + 20 = " + sum)
  val product = testBinaryOp(5, 7, (x, y) => x * y)
  println("5 * 7 = " + product)

  // Test 4: Runnable with lambda
  println("")
  println("=== Test 4: Runnable ===")
  testRunnable(() => println("Lambda task executed"))

  // Test 5: Supplier with lambda
  println("")
  println("=== Test 5: Supplier ===")
  val value = testSupplier(() => 42)
  println("Lazy value: " + value)

  // Test 6: Store lambda interface in variable
  println("")
  println("=== Test 6: Variable assignment ===")
  val isPositive: Predicate[Int] = x => x > 0
  println("Is 5 positive? " + isPositive.test(5))
  println("Is -3 positive? " + isPositive.test(-3))

  // Test 7: More complex lambda
  println("")
  println("=== Test 7: Complex lambda ===")
  val addPrefix: Transformer[String, String] = s => "PREFIX:" + s
  val result = addPrefix.transform("hello")
  println("With prefix: " + result)

  // Test 8: Interface with context parameter
  println("")
  println("=== Test 8: Logger with context ===")
  testLogger(msg => println("[LOG] " + msg))

  // Test 9: Verify context parameter comes from call site, not capture
  println("")
  println("=== Test 9: Context from call site ===")
  val logger: Logger = msg => println("[LOGGER] " + msg)

  // Create custom stdout that adds prefix
  val customStdout = (s: String) => IO.stdout("[CUSTOM] " + s)

  // Call logger with modified IO.stdout - should use the modified one
  println("Before custom context:")
  logger.log("Message 1")

  println("With custom context:")
  logger.log("Message 2") with IO.stdout = customStdout

  println("After custom context:")
  logger.log("Message 3")
end
