def add(a: Int, b: Int): Int = a + b

// precedence of function
def app(f: Int => Int, x: Int): Int = f x

def test(): Int =
  val f = (x: Int) => x + x
  (app f 30) + (f 5)

def main =
  println (add 5 6)

  println (3 + 5 * 2)

  println (4 + 7 - 3)

  if 7 - 4 >= 3 + 1 * 2 then println 10 else println 20

  println test
