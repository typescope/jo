def add(a: Int, b: Int): Int = a + b

// precedence of function
def app(f: Int => Int, x: Int): Int = f x
def test(): Int =
  val * = (x: Int) => x + x
  app * 30 + (* 5)

def test2(): Int =
  val f = (x: Int) => x + x
  app f 30 + (f 5)

def main =
  println (add 5 6)

  println (3 + 5 * 2)

  println (4 + 7 - 3)

  println (if 7 - 4 >= 3 + 1 * 2 then 10 p else 20)

  println test
  println test2
