class Box[T](value: T)

class Post(title: String, author: String, content: String)

union Option[T] = Some(value: T) | None

union List[T] = Cons(head: T, tail: List[T]) | Nil

union Tree[T] = Node(value: T, left: Tree[T], right: Tree[T]) | Leaf(value: T)

union Either[S, T] = Left(value: S) | Right(value: T)

def testData =
  val box = Box(5)
  val post = Post("Hello, World", "Turing", "Bla bla...")

  val c1: Box[Int] | Post = Box 3
  val c2: Box[Int] | Post = post

  match c1
    case Box(value) => println value
    case p: Post => println p.title

  match c2
    case Box value      => println value
    case Post title _ _ => println title

  println post.title
  println box.value

def testEnum =
  val a: Option[Int] = Some 20
  match a
    case Some v => println v
    case None =>

  val l: List[Int] = Cons 4 (Cons 5 Nil)
  match l
    case Cons x (Cons y Nil) => println (x + y)
    case _ =>

  val e: Either[Int, String] = Left 9
  match e
    case Left v => println v
    case _ =>

def main =
  testData
  testEnum
