def main =
  val c1 = 'a'
  val c2: Char = 4

  val i1: Int = 'a'

  test()

def test =
  val a = "hello"
  val b = "world"

  println a.size

  println a

  val c =
    a + " " + b

  println c.size
  println c

  print c[3]
  print '\n'

  val d = a.substring(1, 3)

  println d.size
  println d

  coercion()
  coercion_truncate()

def (x: Int) asInt: Int = x

def coercion =
  // char
  val c: Char = 'a'
  println (c asInt)

  // int
  val i: Int = 100
  val c_i: Char = i.toChar
  println (c_i asInt)

def coercion_truncate =
  // int - no overflow, char is int
  val i: Int = 65536 + 1024 + 64
  val c_i: Char = i.toChar
  println (c_i asInt)
