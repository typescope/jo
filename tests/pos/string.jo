def main =
  val c1 = 'a'
  val c2: Char = 4

  val b1: Byte = 50
  val b2: Byte = 'e'

  val i1: Int = 'a'

  test()

def test =
  val a = "hello"
  val b = "world"

  println a.size

  println a

  val c =
    a + " " + b

  println c.size
  println c

  print c[3]
  print '\n'

  val d = a.substring(1, 3)

  println d.size
  println d

  coercion()
  coercion_truncate()

def coercion =
  // byte
  val b: Byte = 45
  println (b as Int)
  print b.toChar
  print '\n'

  // char
  val c: Char = 'a'
  println (c as Int)
  val b_c: Byte = c.toByte
  println b_c

  // int
  val i: Int = 100
  val b_i: Byte = i.toByte
  val c_i: Char = i.toChar
  println b_i
  println (c_i as Int)

def coercion_truncate =
  // char
  val c: Char = (1024 + 56).toChar
  val b_c: Byte = c.toByte
  println b_c

  // int - no overlow, char is int
  val i: Int = 65536 + 1024 + 64
  val b_i: Byte = i.toByte
  val c_i: Char = i.toChar
  println b_i
  println (c_i as Int)
