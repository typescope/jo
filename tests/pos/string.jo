def main =
  val c1 = 'a'
  val c2: Char = 4

  val b1: Byte = 50
  val b2: Byte = 'e'

  val i1: Int = 'a'

  test

def test =
  val a = "hello"
  val b = "world"

  println a.size

  println a

  val c =
    a + " " + b

  println c.size
  println c

  printChar c[3]
  printChar '\n'

  val d =
    a.substring(1, 3)

  println d.size
  println d

  coercion
  coercion_truncate

def coercion =
  // byte
  val b: Byte = 45
  println b
  printChar (byteToChar b)
  printChar '\n'

  // char
  val c: Char = 'a'
  println c
  val b_c: Byte = charToByte c
  println b_c

  // int
  val i: Int = 100
  val b_i: Byte = intToByte i
  val c_i: Char = intToChar i
  println b_i
  println c_i

def coercion_truncate =
  // char
  val c: Char = intToChar (1024 + 56)
  val b_c: Byte = charToByte c
  println b_c

  // int - overlow
  val i: Int = 65536 + 1024 + 64
  val b_i: Byte = intToByte i
  val c_i: Char = intToChar i
  println b_i
  println c_i
