type Expr[Lang] =
    #Lit(n: Int)
  | #Add(lhs: Lang, rhs: Lang)

type LangA = Expr[LangA]

fun eval(expr: LangA): Int =
  match expr
    case #Lit n => n
    case #Add lhs rhs => (eval lhs) + (eval rhs)

type ExprExt[Lang] = Expr[Lang] | #Mul(lhs: Lang, rhs: Lang)

type LangB = ExprExt[LangB]

fun eval2(expr: LangB): Int =
  match expr
    case #Lit n => n
    case #Add lhs rhs => (eval2 lhs) + (eval2 rhs)
    case #Mul lhs rhs => (eval2 lhs) * (eval2 rhs)

fun main =
  val lang1: LangA =
    #Add
      #Lit 3
      #Add
        #Lit 2
        #Lit 5

  val lang2: LangB = #Mul lang1 (#Lit 3)

  println
    intToStr
      eval lang1

  println
    intToStr
      eval2 lang2
