// Test unicode escapes in string and char literals

def main(): Unit =
  // Basic unicode escapes (flexible length)
  val abc = "\u{41}\u{42}\u{43}"
  print(abc)
  print("\n")

  // ANSI color codes for colored output
  val red = "\u{1B}[31m"
  val green = "\u{1B}[32m"
  val reset = "\u{1B}[0m"

  print(red)
  print("Red Text")
  print(reset)
  print("\n")

  print(green)
  print("Green Text")
  print(reset)
  print("\n")

  // Char literals with unicode
  val esc = '\u{1B}'
  val letterA = '\u{41}'

  print("Char A: ")
  print(letterA)
  print("\n")

  // Mixed escapes
  val mixed = "Tab:\t Unicode:\u{58} Newline:\n"
  print(mixed)

  // Edge cases - shorter hex sequences
  val null_char = "\u{0}End"
  val high_bmp = "\u{FFFF}"

  print("Done\n")
