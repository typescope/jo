// Test unicode escapes in string and char literals

def main(): Unit =
  // Basic unicode escapes
  val abc = "\u0041\u0042\u0043"
  print(abc)
  print("\n")

  // ANSI color codes for colored output
  val red = "\u001B[31m"
  val green = "\u001B[32m"
  val reset = "\u001B[0m"

  print(red)
  print("Red Text")
  print(reset)
  print("\n")

  print(green)
  print("Green Text")
  print(reset)
  print("\n")

  // Char literals with unicode
  val esc = '\u001B'
  val letterA = '\u0041'

  print("Char A: ")
  print(letterA)
  print("\n")

  // Mixed escapes
  val mixed = "Tab:\t Unicode:\u0058 Newline:\n"
  print(mixed)

  // Edge cases
  val null_char = "\u0000End"
  val high_bmp = "\uFFFF"

  print("Done\n")
