// ASCII-first Thompson NFA regex prototype
// Supports: ., ^, $, *, +, ?, {n}, {n,m}, (), |, [], [^], \d\s\w and inverse classes
// Full-match semantics only (pattern must match entire input).

param DEBUG: Bool = false

def Start: Int = 0
def Finish: Int = 1

object Epsilon
object StartAnchor
object EndAnchor
object WordBoundary
object NotWordBoundary
class EnterCapture(name: String)
class ExitCapture(name: String)
class EnterLoop(groups: List[String])
object ExitLoop
class EnterOption(groups: List[String])
object ExitOption

class CharClass(chars: List[Char], ranges: List[Char ~ Char], negated: Bool)
object Dot

type Atom = Char | Dot | CharClass

type Label =
    Epsilon
  | StartAnchor
  | EndAnchor
  | WordBoundary
  | NotWordBoundary
  | EnterCapture
  | ExitCapture
  | EnterLoop
  | ExitLoop
  | EnterOption
  | ExitOption
  | Atom

class Edge(from: Int, label: Label, to: Int)

union Pattern =
    EmptyP
  | AtomP(a: Atom)
  | Seq(p1: Pattern, p2: Pattern)
  | Or(p1: Pattern, p2: Pattern)
  | Star(p: Pattern, greedy: Bool)
  | Optional(p: Pattern, greedy: Bool)
  | Capture(name: String, p: Pattern)
  | StartP
  | EndP
  | WordBoundaryP
  | NotWordBoundaryP

class Segment(from: Int, to: Int)
type Result = Segment | List[Result] | Option[Result]

class NFA
  private val transitionMap: mutable.Map[Int, List[Edge]]
  private var stateCounter: Int = 2

  def NFA() =
    this.transitionMap = {}

  def newState(): Int =
    val id = stateCounter
    stateCounter = stateCounter + 1
    id

  def addTransition(from: Int, label: Label, to: Int): Unit =
    val edge = Edge(from, label, to)
    val existing = transitionMap.getOrElse from []
    transitionMap[from] = existing + edge

  def getTransitions(state: Int): List[Edge] =
    transitionMap.getOrElse state []

  def numStates: Int = stateCounter
end

section Chars
  def inRange(c: Char, lo: Char, hi: Char): Bool =
    val x = c.toInt
    lo.toInt <= x && x <= hi.toInt

  def isDigit(c: Char): Bool = inRange(c, '0', '9')

  def isWord(c: Char): Bool =
    inRange(c, 'a', 'z') || inRange(c, 'A', 'Z') || isDigit(c) || c == '_'

  def isSpace(c: Char): Bool =
    c == ' ' || c == '\t' || c == '\n' || c == '\r' || c == '\f' || c == 0x000B.toChar

  def singleton(c: Char): CharClass = CharClass([c], [], false)

  def charClassMatches(cc: CharClass, c: Char): Bool =
    val inChars = cc.chars.exists(x => x == c)
    val inRanges = cc.ranges.exists(r =>
      val lo ~ hi = r
      inRange(c, lo, hi)
    )
    val present = inChars || inRanges
    if cc.negated then !present else present

  def atomMatches(a: Atom, c: Char): Bool =
    match a
      case x: Char => x == c
      case Dot => c != '\n'
      case cc: CharClass => charClassMatches(cc, c)
end

def construct(pat: Pattern, from: Int, to: Int, nfa: NFA): Unit =
  match pat
    case EmptyP =>
      nfa.addTransition(from, Epsilon, to)

    case Capture(name, p) =>
      val enter = nfa.newState()
      val exit = nfa.newState()
      nfa.addTransition(from, EnterCapture(name), enter)
      construct(p, enter, exit, nfa)
      nfa.addTransition(exit, ExitCapture(name), to)

    case Or(lhs, rhs) =>
      construct lhs from to nfa
      construct rhs from to nfa

    case Star(p, greedy) =>
      val groups = patternCaptures(p)
      if groups.size > 0 then
        val loop = nfa.newState()
        nfa.addTransition(from, EnterLoop(groups), loop)
        // Keep stable capture-loop ordering used by the capture handlers.
        nfa.addTransition(loop, ExitLoop, to)
        construct(p, loop, loop, nfa)
      else
        if greedy then
          construct(p, from, from, nfa)
          nfa.addTransition(from, Epsilon, to)
        else
          nfa.addTransition(from, Epsilon, to)
          construct(p, from, from, nfa)

    case Optional(p, greedy) =>
      val groups = patternCaptures(p)
      if groups.size > 0 then
        val enter = nfa.newState()
        val exit = nfa.newState()
        nfa.addTransition(from, EnterOption(groups), enter)
        // Keep stable capture-option ordering used by the capture handlers.
        nfa.addTransition(enter, Epsilon, exit)
        construct(p, enter, exit, nfa)
        nfa.addTransition(exit, ExitOption, to)
      else
        if greedy then
          construct(p, from, to, nfa)
          nfa.addTransition(from, Epsilon, to)
        else
          nfa.addTransition(from, Epsilon, to)
          construct(p, from, to, nfa)

    case Seq(p1, p2) =>
      val mid = nfa.newState()
      construct p1 from mid nfa
      construct p2 mid to nfa

    case AtomP(a) =>
      nfa.addTransition(from, a, to)

    case StartP =>
      nfa.addTransition(from, StartAnchor, to)

    case EndP =>
      nfa.addTransition(from, EndAnchor, to)

    case WordBoundaryP =>
      nfa.addTransition(from, WordBoundary, to)

    case NotWordBoundaryP =>
      nfa.addTransition(from, NotWordBoundary, to)
  end

def patternCaptures(p: Pattern): List[String] =
  match p
    case EmptyP => []
    case AtomP(_) => []
    case StartP => []
    case EndP => []
    case WordBoundaryP => []
    case NotWordBoundaryP => []
    case Capture(name, inner) => patternCaptures(inner) + name
    case Seq(a, b) => patternCaptures(a) ++ patternCaptures(b)
    case Or(a, b) => patternCaptures(a) ++ patternCaptures(b)
    case Star(inner, _) => patternCaptures(inner)
    case Optional(inner, _) => patternCaptures(inner)

class Scanner(reg: String)
  var index: Int = 0

  def hasMore(): Bool = index < reg.size

  def peek(): Char = reg[index]

  def next(): Char =
    val c = reg[index]
    index = index + 1
    c

  def location(): String =
    if hasMore() then
      "position " + index.toString + " (next='" + peek().toString + "')"
    else
      "end of pattern at position " + index.toString

  def fail(msg: String): Unit =
    abort(msg + " at " + location())

  def eat(c: Char): Unit =
    if !hasMore() || peek() != c then
      fail("Expected '" + c.toString + "'")
    next()

  def pos(): Int = index
end

class Parser(scanner: Scanner)
  private val captureNames: mutable.Set[String] = {}

  def parseError(msg: String): Unit =
    abort(msg + " at " + scanner.location())

  def parse(): Pattern =
    val p = parseAlternation()
    if scanner.hasMore() then
      parseError("Trailing characters")
    p

  def parseAlternation(): Pattern =
    val left = parseSequence()
    if scanner.hasMore() && scanner.peek() == '|' then
      scanner.next()
      Or(left, parseAlternation())
    else
      left

  def parseSequence(): Pattern =
    var parts: List[Pattern] = []
    while scanner.hasMore() && scanner.peek() != ')' && scanner.peek() != '|' do
      parts = parts + parsePostfix()

    if parts.isEmpty then
      parseError("Empty sequence")
    foldSeq(parts)

  def parsePostfix(): Pattern =
    var atom = parseAtom()
    var cont = true
    while cont && scanner.hasMore() do
      val c = scanner.peek()
      if c == '*' then
        scanner.next()
        val greedy =
          if scanner.hasMore() && scanner.peek() == '?' then
            scanner.next()
            false
          else
            true
        atom = Star(atom, greedy)
      else if c == '+' then
        scanner.next()
        val greedy =
          if scanner.hasMore() && scanner.peek() == '?' then
            scanner.next()
            false
          else
            true
        atom = Seq(atom, Star(atom, greedy))
      else if c == '?' then
        scanner.next()
        val greedy =
          if scanner.hasMore() && scanner.peek() == '?' then
            scanner.next()
            false
          else
            true
        atom = Optional(atom, greedy)
      else if c == '{' then
        atom = parseBounded(atom)
      else
        cont = false
    atom

  def parseBounded(base: Pattern): Pattern =
    scanner.eat('{')
    val min = parseNumber()
    if !scanner.hasMore() then parseError("Unclosed bounded repetition")

    if scanner.peek() == '}' then
      scanner.next()
      if scanner.hasMore() && scanner.peek() == '?' then
        scanner.next()
      repeatExact(base, min)

    else if scanner.peek() == ',' then
      scanner.next()
      val max = parseNumber()
      scanner.eat('}')
      if min > max then parseError("Invalid bound: min > max")
      val greedy =
        if scanner.hasMore() && scanner.peek() == '?' then
          scanner.next()
          false
        else
          true
      repeatRange(base, min, max, greedy)

    else
      abort("Invalid bounded repetition syntax at " + scanner.location())

  def parseNumber(): Int =
    if !scanner.hasMore() || !Chars.isDigit(scanner.peek()) then
      parseError("Expected number in bounded repetition")
    var value = 0
    while scanner.hasMore() && Chars.isDigit(scanner.peek()) do
      val ch = scanner.next()
      value = value * 10 + (ch.toInt - '0'.toInt)
    value

  def parseAtom(): Pattern =
    if !scanner.hasMore() then
      parseError("Unexpected end: expected atom")

    val c = scanner.peek()
    if c == '(' then
      scanner.next()
      if scanner.hasMore() && scanner.peek() == '?' then
        scanner.next()
        if scanner.hasMore() && scanner.peek() == ':' then
          scanner.next()
          val p = parseAlternation()
          scanner.eat(')')
          p
        else if scanner.hasMore() && scanner.peek() == '<' then
          scanner.next()

          var name = ""
          while scanner.hasMore() && scanner.peek() != '>' do
            name = name + scanner.next()
          end
          if name.size == 0 then parseError("Empty capture name")
          if captureNames.contains(name) then
            parseError("Duplicate capture group name: " + name)
          captureNames += name
          scanner.eat('>')

          val p = parseAlternation()
          scanner.eat(')')
          Capture(name, p)
        else
          abort("Invalid group syntax: expected : or < after (? at " + scanner.location())
      else
        val p = parseAlternation()
        scanner.eat(')')
        p
    else if c == '[' then
      scanner.next()
      AtomP(parseClass())
    else if c == '.' then
      scanner.next()
      AtomP(Dot)
    else if c == '^' then
      scanner.next()
      StartP
    else if c == '$' then
      scanner.next()
      EndP
    else if c == '\\' then
      scanner.next()
      parseEscapedPattern()
    else if c == ')' || c == '|' || c == '*' || c == '+' || c == '?' || c == '{' || c == '}' then
      abort("Unexpected token: " + c.toString + " at " + scanner.location())
    else
      scanner.next()
      AtomP(c)

  def parseClass(): CharClass =
    var negated = false
    if scanner.hasMore() && scanner.peek() == '^' then
      scanner.next()
      negated = true

    var chars: List[Char] = []
    var ranges: List[Char ~ Char] = []
    var first = true

    while scanner.hasMore() && scanner.peek() != ']' do
      val left = parseClassChar()

      if scanner.hasMore() && scanner.peek() == '-' then
        scanner.next()
        if !scanner.hasMore() || scanner.peek() == ']' then
          chars = chars + left
          chars = chars + '-'
        else
          val right = parseClassChar()
          if left.toInt > right.toInt then parseError("Invalid class range")
          ranges = ranges + (left ~ right)
      else
        chars = chars + left
      first = false
    end

    if !scanner.hasMore() then parseError("Unclosed character class")
    if first then parseError("Empty character class")
    scanner.eat(']')
    CharClass(chars, ranges, negated)

  def parseClassChar(): Char =
    if !scanner.hasMore() then parseError("Unexpected end inside character class")
    if scanner.peek() == '\\' then
      scanner.next()
      val e = scanner.next()
      if e == 'd' || e == 'D' || e == 's' || e == 'S' || e == 'w' || e == 'W' then
        parseError("Use \\d/\\s/\\w outside [] in this strawman")
      classEscapeChar(e)
    else
      scanner.next()

  def parseEscape(inClass: Bool): Atom =
    if !scanner.hasMore() then parseError("Dangling escape")
    val c = scanner.next()

    if c == 'd' then
      CharClass([], ['0' ~ '9'], false)
    else if c == 'D' then
      CharClass([], ['0' ~ '9'], true)
    else if c == 's' then
      CharClass([' ', '\t', '\n', '\r', '\f', 0x000B.toChar], [], false)
    else if c == 'S' then
      CharClass([' ', '\t', '\n', '\r', '\f', 0x000B.toChar], [], true)
    else if c == 'w' then
      CharClass(['_'], ['a' ~ 'z', 'A' ~ 'Z', '0' ~ '9'], false)
    else if c == 'W' then
      CharClass(['_'], ['a' ~ 'z', 'A' ~ 'Z', '0' ~ '9'], true)
    else
      classEscapeChar(c)

  def parseEscapedPattern(): Pattern =
    if !scanner.hasMore() then parseError("Dangling escape")
    val c = scanner.peek()
    if c == 'b' then
      scanner.next()
      WordBoundaryP
    else if c == 'B' then
      scanner.next()
      NotWordBoundaryP
    else
      AtomP(parseEscape(false))

  def classEscapeChar(c: Char): Char =
    if c == 'n' then '\n'
    else if c == 't' then '\t'
    else if c == 'r' then '\r'
    else if c == 'f' then '\f'
    else if c == 'v' then 0x000B.toChar
    else c

  def foldSeq(parts: List[Pattern]): Pattern =
    match parts
      case [x] => x
      case [x, ..xs] => Seq(x, foldSeq(xs))
      case _ => abort "internal: empty sequence"

  def repeatExact(base: Pattern, n: Int): Pattern =
    assert(n >= 0, "negative repeat")
    if n == 0 then
      EmptyP
    else
      var acc = base
      var i = 1
      while i < n do
        acc = Seq(acc, base)
        i = i + 1
      acc

  def repeatRange(base: Pattern, min: Int, max: Int, greedy: Bool): Pattern =
    var acc = repeatExact(base, min)
    var i = min
    while i < max do
      acc = Seq(acc, Optional(base, greedy))
      i = i + 1
    acc
end

section Engine
  type Captures = Top | Loop | Options

  class Top
    var captures: Map[String, Result]
    def Top(captures: Map[String, Result]) =
      this.captures = captures
  end

  class Loop
    var captures: Map[String, List[Result]]
    val outer: Captures
    def Loop(outer: Captures, captures: Map[String, List[Result]]) =
      this.outer = outer
      this.captures = captures
  end

  class Options
    var captures: Map[String, Option[Result]]
    val outer: Captures
    def Options(outer: Captures, captures: Map[String, Option[Result]]) =
      this.outer = outer
      this.captures = captures
  end

  def cloneCaptures(captures: Captures): Captures =
    match captures
      case top: Top =>
        new Top(top.captures)
      case loop: Loop =>
        new Loop(cloneCaptures(loop.outer), loop.captures)
      case option: Options =>
        new Options(cloneCaptures(option.outer), option.captures)

  def pushCapture(captures: Captures, group: String, value: Result): Unit =
    match captures
      case top: Top =>
        top.captures = top.captures.update(group, value)
      case loop: Loop =>
        assert(loop.captures.contains(group), "Unexpected group in loop: " + group)
        loop.captures = loop.captures.update(group, loop.captures[group] + value)
      case option: Options =>
        assert(option.captures.contains(group), "Unexpected group in option: " + group)
        option.captures = option.captures.update(group, Some(value))

  def finishCaptures(captures: Captures): Captures =
    match captures
      case top: Top => top
      case loop: Loop =>
        for group ~ values in loop.captures do pushCapture(loop.outer, group, values)
        loop.outer
      case option: Options =>
        for group ~ value in option.captures do pushCapture(option.outer, group, value)
        option.outer

  class Thread
    var step: Int
    var captureStack: List[String ~ Int]
    var captures: Captures
    var priority: List[Int]

    def Thread(step: Int, captureStack: List[String ~ Int], captures: Captures, priority: List[Int]) =
      this.step = step
      this.captureStack = captureStack
      this.captures = captures
      this.priority = priority

    private var _used: Bool = false
    def used: Bool = _used
    def markUsed(): Thread =
      _used = true
      this
    def markFree(): Thread =
      _used = false
      this
  end

  def cloneThread(captures: Captures, t: Thread): Thread =
    new Thread(t.step, t.captureStack, cloneCaptures(captures), t.priority)

  def MaxPriorityLen: Int = 24

  def withPriorityChoice(t: Thread, choice: Int): Thread =
    if t.priority.size < MaxPriorityLen then
      t.priority = t.priority + choice
    t

  def priorityLess(a: List[Int], b: List[Int]): Bool =
    var cmp = 0
    var i = 0
    while i < a.size && i < b.size && cmp == 0 do
      if a[i] < b[i] then cmp = -1
      else if a[i] > b[i] then cmp = 1
      i = i + 1
    end
    if cmp < 0 then true
    else if cmp > 0 then false
    else a.size < b.size

  def keepBetter(stateToThread: mutable.Map[Int, Thread], state: Int, candidate: Thread): Unit =
    match stateToThread.getOpt(state)
      case Some(existing) =>
        if priorityLess(candidate.priority, existing.priority) then
          stateToThread[state] = candidate
      case None =>
        stateToThread[state] = candidate

  def enterCapture(t: Thread, name: String, pos: Int): Unit =
    t.captureStack = t.captureStack + (name ~ pos)

  def exitCapture(t: Thread, name: String, pos: Int): Unit =
    match t.captureStack
      case [..xs, top] =>
        val group ~ startPos = top
        assert(group == name, "capture stack mismatch")
        t.captureStack = xs
        pushCapture(t.captures, name, Segment(startPos, pos))
      case _ =>
        abort "Unexpected empty capture stack"

  def enterLoop(t: Thread, groups: List[String]): Unit =
    val loop = new Loop(t.captures, {})
    t.captures = loop
    for group in groups do
      loop.captures = loop.captures.update(group, [])

  def exitLoop(t: Thread): Unit =
    t.captures = finishCaptures(t.captures)

  def enterOption(t: Thread, groups: List[String]): Unit =
    val opt = new Options(t.captures, {})
    t.captures = opt
    for group in groups do
      opt.captures = opt.captures.update(group, None)

  def exitOption(t: Thread): Unit =
    t.captures = finishCaptures(t.captures)

  def compile(pat: String): NFA =
    val parser = new Parser(new Scanner(pat))
    val ast = parser.parse()
    val nfa = new NFA
    construct(ast, Start, Finish, nfa)
    nfa

  def isActiveState(nfa: NFA, state: Int): Bool =
    state == Finish || nfa.getTransitions(state).exists(edge => edge.label is (_: Atom))

  def epsilonClosure(
      nfa: NFA,
      initial: mutable.Map[Int, Thread],
      pos: Int,
      atEnd: Bool,
      wordBoundary: Bool): mutable.Map[Int, Thread] =
    val result: mutable.Map[Int, Thread] = {}
    val work: mutable.Map[Int, Thread] = initial
    val seen: mutable.Set[Int] = {}

    def follow(edge: Edge, t: Thread): Option[Int ~ Thread] =
      match edge.label
        case Epsilon => Some(edge.to ~ t)
        case StartAnchor =>
          if pos == 0 then Some(edge.to ~ t) else None
        case EndAnchor =>
          if atEnd then Some(edge.to ~ t) else None
        case WordBoundary =>
          if wordBoundary then Some(edge.to ~ t) else None
        case NotWordBoundary =>
          if !wordBoundary then Some(edge.to ~ t) else None
        case EnterCapture(name) =>
          enterCapture(t, name, pos)
          Some(edge.to ~ t)
        case ExitCapture(name) =>
          exitCapture(t, name, pos)
          Some(edge.to ~ t)
        case EnterLoop(groups) =>
          enterLoop(t, groups)
          Some(edge.to ~ t)
        case ExitLoop =>
          exitLoop(t)
          Some(edge.to ~ t)
        case EnterOption(groups) =>
          enterOption(t, groups)
          Some(edge.to ~ t)
        case ExitOption =>
          exitOption(t)
          Some(edge.to ~ t)
        case _: Atom =>
          None

    while work.size > 0 do
      val todo = work.toList
      work.clear()

      for state ~ thread in todo do
        if !seen.contains(state) then
          seen += state
        assert(!thread.used, "thread should be free")
        val captures = thread.captures
        if isActiveState(nfa, state) then
          keepBetter(result, state, thread.markUsed())
        val edges = nfa.getTransitions(state)
        var idx = 0
        for edge in edges do
          val t = withPriorityChoice(cloneThread(captures, thread).markFree(), idx)
          idx = idx + 1
          match follow(edge, t)
            case Some(nextState ~ nextThread) =>
              if !result.contains(nextState) && !seen.contains(nextState) then
                keepBetter(work, nextState, nextThread)
            case None =>
              pass
        end
      end
    end

    result

  def step(
      nfa: NFA,
      current: mutable.Map[Int, Thread],
      c: Char,
      posAfter: Int,
      atEndAfter: Bool,
      wordBoundaryAfter: Bool): mutable.Map[Int, Thread] =
    val moved: mutable.Map[Int, Thread] = {}
    for state ~ thread in current do
      val edges = nfa.getTransitions(state)
      var idx = 0
      for edge in edges do
        match edge.label
          case a: Atom =>
            if Chars.atomMatches(a, c) then
              val t = withPriorityChoice(cloneThread(thread.captures, thread), idx)
              t.step = posAfter
              t.markFree()
              keepBetter(moved, edge.to, t)
          case _ => pass
        idx = idx + 1
      end
    end

    epsilonClosure(nfa, moved, posAfter, atEndAfter, wordBoundaryAfter)

  def matchResult(str: String, pat: String): Option[Thread] =
    val nfa = compile(pat)
    val iter = str.iterator
    var hasCurrent = iter.hasNext
    var currentChar = 0x0000.toChar
    var nextWord = false
    if hasCurrent then
      currentChar = iter.next
      nextWord = Chars.isWord(currentChar)

    var current: mutable.Map[Int, Thread] = epsilonClosure(
      nfa,
      { Start: new Thread(0, [], new Top({}), []) },
      0,
      !hasCurrent,
      nextWord
    )

    var pos = 0
    var prevWord = false
    while hasCurrent do
      val c = currentChar
      pos = pos + 1
      prevWord = nextWord

      if iter.hasNext then
        currentChar = iter.next
        nextWord = Chars.isWord(currentChar)
      else
        hasCurrent = false
        nextWord = false

      current = step(nfa, current, c, pos, !hasCurrent, prevWord != nextWord)
    end

    current.getOpt(Finish)

  def matchFull(str: String, pat: String): Bool =
    match matchResult(str, pat)
      case Some(_) => true
      case None => false

  def matchCaptures(str: String, pat: String): Option[Map[String, List[Segment]]] =
    match matchResult(str, pat)
      case Some(thread) =>
        match thread.captures
          case top: Top =>
            val flat: Map[String, List[Segment]] =
              top.captures.fold {} (acc, name, result) =>
                acc.update(name, flattenResult(result))
            Some(flat)
          case _ =>
            None
      case None => None

  def flattenResult(result: Result): List[Segment] =
    match result
      case s: Segment => [s]
      case list: List[Result] =>
        list.fold [] (acc, r) => acc ++ flattenResult(r)
      case opt: Option[Result] =>
        match opt
          case Some(r) => flattenResult(r)
          case None => []
end

def expect(input: String, pat: String, want: Bool): Unit =
  val got = Engine.matchFull(input, pat)
  assert(got == want, "Mismatch: input='" + input + "' pat='" + pat + "' want=" + want.toString + " got=" + got.toString)
  println "OK  input='\{input}' pat='\{pat}' => \{got}"

def expectLarge(input: String, pat: String, want: Bool): Unit =
  val got = Engine.matchFull(input, pat)
  assert(got == want, "Mismatch: input_len=" + input.size.toString + " pat='" + pat + "' want=" + want.toString + " got=" + got.toString)
  println "OK  input_len=\{input.size} pat='\{pat}' => \{got}"

def expectCaptureTexts(input: String, pat: String, name: String, want: List[String]): Unit =
  match Engine.matchCaptures(input, pat)
    case Some(captures) =>
      val segs = captures.getOrElse(name, [])
      val gotTexts = segs.map(s => input.substring(s.from, s.to - s.from))
      assert(segs.size == want.size, "Capture size mismatch for " + name + ": got=" + gotTexts.toString + ", want=" + want.toString)
      var i = 0
      while i < segs.size do
        assert(
          segs[i].from >= 0 && segs[i].to >= segs[i].from && segs[i].to <= input.size,
          "Capture bounds invalid for " + name
        )
        val got = input.substring(segs[i].from, segs[i].to - segs[i].from)
        assert(got == want[i], "Capture text mismatch for " + name + ": got=" + got + ", want=" + want[i])
        i = i + 1
      end
      println "OK  captures input='\{input}' pat='\{pat}' name='\{name}' => \{want}"
    case None =>
      assert(false, "Pattern did not match in capture expectation")

def main receives IO.stdout =
  println "=== Basics ==="
  expect("abc", "abc", true)
  expect("abc", "abd", false)

  println ""
  println "=== Wildcard Dot (no newline) ==="
  expect("aXc", "a.c", true)
  expect("a\nc", "a.c", false)

  println ""
  println "=== Quantifiers ==="
  expect("", "a*", true)
  expect("b", "a*b", true)
  expect("aaab", "a*b", true)
  expect("aaaaac", "a*b", false)
  expect("aaaa", "a+", true)
  expect("", "a+", false)
  expect("b", "a+b", false)
  expect("aaab", "a+b", true)
  expect("ac", "ab?c", true)
  expect("abc", "ab?c", true)
  expect("abbc", "ab?c", false)

  println ""
  println "=== Quantifier Edge Cases ==="
  expect("", "a*b*", true)
  expect("aaa", "a*b*", true)
  expect("bbb", "a*b*", true)
  expect("aaabbb", "a*b*", true)
  expect("abab", "a*b*", false)
  expect("abccc", "a*b*c*", true)
  expect("aaabbbccc", "a*b*c*", true)
  expect("aaabbbcccd", "a*b*c*", false)
  expect("", "(a?)*", true)
  expect("aaa", "(a?)*", true)
  expect("b", "(a?)*", false)
  expect("aaaa", "(a*)*", true)
  expect("aaaaab", "(a*)*b", true)
  expect("aaaaa", "(a*)*b", false)
  expect("aaaa", "(a|aa)+", true)
  expect("aaab", "(a|aa)+b", true)

  println ""
  println "=== Bounded Repetition ==="
  expect("aaa", "a{3}", true)
  expect("aa", "a{3}", false)
  expect("aa", "a{2,4}", true)
  expect("aaaa", "a{2,4}", true)
  expect("aaaaa", "a{2,4}", false)

  println ""
  println "=== Alternation and Grouping ==="
  expect("ab", "(ab|cd)", true)
  expect("cd", "(ab|cd)", true)
  expect("ad", "(ab|cd)", false)
  expect("abab", "(ab)+", true)
  expect("ab", "^(?:ab)$", true)
  expect("abab", "^(?:ab)+$", true)
  expect("acd", "^a(?:b|c)d$", true)
  expect("abd", "^a(?:b|c)d$", true)
  expect("aed", "^a(?:b|c)d$", false)

  println ""
  println "=== Character Classes ==="
  expect("a", "[abc]", true)
  expect("d", "[abc]", false)
  expect("k", "[a-z]", true)
  expect("K", "[a-z]", false)
  expect("K", "[^a-z]", true)
  expect("-", "[-a]", true)
  expect("-", "[a-]", true)

  println ""
  println "=== Common Escapes ==="
  expect("7", "\\d", true)
  expect("x", "\\d", false)
  expect("x", "\\D", true)
  expect(" ", "\\s", true)
  expect("\t", "\\s", true)
  expect("x", "\\s", false)
  expect("A", "\\w", true)
  expect("_", "\\w", true)
  expect("-", "\\w", false)
  expect("-", "\\W", true)

  println ""
  println "=== Anchors ==="
  expect("abc", "^abc$", true)
  expect("zabc", "^abc$", false)
  expect("abcz", "^abc$", false)
  expect("abc", "^a.*c$", true)
  expect("a\nc", "^a.*c$", false)

  println ""
  println "=== Greedy vs Nongreedy ==="
  expectCaptureTexts("a123b456b789c", "^a(?<x>.*)b(?<y>.*)c$", "x", ["123b456"])
  expectCaptureTexts("a123b456b789c", "^a(?<x>.*)b(?<y>.*)c$", "y", ["789"])
  expectCaptureTexts("a123b456b789c", "^a(?<x>.*?)b(?<y>.*)c$", "x", ["123"])
  expectCaptureTexts("a123b456b789c", "^a(?<x>.*?)b(?<y>.*)c$", "y", ["456b789"])
  expectCaptureTexts("aaaa", "^(?<x>a+?)a+$", "x", ["a"])
  expectCaptureTexts("aaaa", "^(?<x>a+)a+$", "x", ["aaa"])
  expectCaptureTexts("a", "^(?<x>a??)a$", "x", [""])
  expectCaptureTexts("aaaa", "^(?<x>a{1,3}?)a+$", "x", ["a"])
  expectCaptureTexts("aaaa", "^(?<x>a{1,3})a+$", "x", ["aaa"])

  println ""
  println "=== Word Boundaries ==="
  expect("foo", "^\\bfoo\\b$", true)
  expect("foo!", "^\\bfoo\\b!$", true)
  expect("!foo", "^!\\bfoo$", true)
  expect("foo", "^\\Bfoo\\B$", false)
  expect("afoob", "^a\\Bfoo\\Bb$", true)
  expect("afoo b", "^a\\Bfoo\\Bb$", false)

  println ""
  println "=== Mixed Realistic Patterns ==="
  expect("2026-02-18", "^\\d{4}-\\d{2}-\\d{2}$", true)
  expect("2026-2-18", "^\\d{4}-\\d{2}-\\d{2}$", false)
  expect("INFO_42", "^\\w+$", true)
  expect("INFO-42", "^\\w+$", false)
  expect("k=v", "^\\w+=\\w+$", true)
  expect("k =v", "^\\w+=\\w+$", false)

  println ""
  println "=== Adversarial Smoke ==="
  val longA = "a" * 1200
  val longACapture = "a" * 600
  val longAPlusBang = longA + "!"
  val longLabels = ("aaaa." * 250) + "aaaa"
  val longLabelsBang = longLabels + "!"
  expectLarge(longA, "^(a?)*a*$", true)
  expectLarge(longA + "b", "^(a?)*a*$", false)
  expectLarge(longA, "^(a|aa)*$", true)
  expectLarge(longACapture, "^(?<o>(?<x>a)?)*$", true)
  expectLarge(longACapture, "^(?<o>(?<x>a)*)$", true)
  expectLarge(longA + "b", "^(a*)*b$", true)
  expectLarge(longA + "c", "^(a*)*b$", false)
  expectLarge(longA, "^(a+)+$", true)
  expectLarge(longAPlusBang, "^(a+)+$", false)
  expectLarge(longA, "^([a-z]+)*$", true)
  expectLarge(longAPlusBang, "^([a-z]+)*$", false)
  expectLarge(longA, "^([A-Za-z]+\\s?)*$", true)
  expectLarge(longAPlusBang, "^([A-Za-z]+\\s?)*$", false)
  expectLarge(longLabels, "^([A-Za-z0-9_]+\\.)*[A-Za-z0-9_]+$", true)
  expectLarge(longLabelsBang, "^([A-Za-z0-9_]+\\.)*[A-Za-z0-9_]+$", false)

  println ""
  println "=== Named Captures ==="
  expectCaptureTexts("abc", "^(?<all>abc)$", "all", ["abc"])
  expectCaptureTexts("aaab", "^(?<xs>a*)b$", "xs", ["aaa"])
  expectCaptureTexts("b", "^(?<x>a)?b$", "x", [])
  expectCaptureTexts("ac", "^a(?<x>b)?c$", "x", [])
  expectCaptureTexts("abc", "^a(?<x>b)?c$", "x", ["b"])
  expectCaptureTexts("abc", "^(?<o>a(?<i>b)c)$", "o", ["abc"])
  expectCaptureTexts("abc", "^(?<o>a(?<i>b)c)$", "i", ["b"])
  expectCaptureTexts("ababab", "^(?<pair>ab)*$", "pair", ["ab", "ab", "ab"])
  expectCaptureTexts("ab", "^(?<x>(?<y>a)(?<z>b))*$", "x", ["ab"])
  expectCaptureTexts("ab", "^(?<x>(?<y>a)(?<z>b))*$", "y", ["a"])
  expectCaptureTexts("ab", "^(?<x>(?<y>a)(?<z>b))*$", "z", ["b"])
  expectCaptureTexts("a", "^(?<x>a)|(?<y>b)$", "x", ["a"])
  expectCaptureTexts("b", "^(?<x>a)|(?<y>b)$", "y", ["b"])
  expectCaptureTexts("2026-02-18", "^(?<y>\\d{4})-(?<m>\\d{2})-(?<d>\\d{2})$", "y", ["2026"])
  expectCaptureTexts("2026-02-18", "^(?<y>\\d{4})-(?<m>\\d{2})-(?<d>\\d{2})$", "m", ["02"])
  expectCaptureTexts("2026-02-18", "^(?<y>\\d{4})-(?<m>\\d{2})-(?<d>\\d{2})$", "d", ["18"])
  expectCaptureTexts("ab", "^(?:a(?<x>b))$", "x", ["b"])
  expectCaptureTexts("ab", "^(?:ab)$", "x", [])

  println ""
  println "=== Tricky Capture Cases ==="
  expectCaptureTexts("", "^(?<x>a*)$", "x", [""])
  expectCaptureTexts("aa", "^(?<x>(?<y>a)*)$", "x", ["aa"])
  expectCaptureTexts("aa", "^(?<x>(?<y>a)*)$", "y", ["a", "a"])
  expectCaptureTexts("aaabbb", "^(?<a>a)*(?<b>b)*$", "a", ["a", "a", "a"])
  expectCaptureTexts("aaabbb", "^(?<a>a)*(?<b>b)*$", "b", ["b", "b", "b"])
  expectCaptureTexts("ab", "^(?<x>a)(?<y>b)?$", "x", ["a"])
  expectCaptureTexts("ab", "^(?<x>a)(?<y>b)?$", "y", ["b"])
  expectCaptureTexts("a", "^(?<x>a)(?<y>b)?$", "x", ["a"])
  expectCaptureTexts("a", "^(?<x>a)(?<y>b)?$", "y", [])
  expectCaptureTexts("ac", "^(?<outer>a(?<inner>b)?c)$", "outer", ["ac"])
  expectCaptureTexts("ac", "^(?<outer>a(?<inner>b)?c)$", "inner", [])
  expectCaptureTexts("abc", "^(?<outer>a(?<inner>b)?c)$", "outer", ["abc"])
  expectCaptureTexts("abc", "^(?<outer>a(?<inner>b)?c)$", "inner", ["b"])
  expectCaptureTexts("ab", "^(?<alt>(?<x>a)|(?<y>b))(?<z>b)$", "alt", ["a"])
  expectCaptureTexts("ab", "^(?<alt>(?<x>a)|(?<y>b))(?<z>b)$", "x", ["a"])
  expectCaptureTexts("ab", "^(?<alt>(?<x>a)|(?<y>b))(?<z>b)$", "y", [])
  expectCaptureTexts("ab", "^(?<alt>(?<x>a)|(?<y>b))(?<z>b)$", "z", ["b"])
  expectCaptureTexts("aa", "^(?<o>(?<x>a)*)?$", "o", ["aa"])
  expectCaptureTexts("aa", "^(?<o>(?<x>a)*)?$", "x", ["a", "a"])
  expectCaptureTexts("", "^(?<o>(?<x>a)*)?$", "o", [])
  expectCaptureTexts("", "^(?<o>(?<x>a)*)?$", "x", [])
  expectCaptureTexts("ababb", "^(?<o>(?<x>a)?b)*$", "o", ["ab", "ab", "b"])
  expectCaptureTexts("ababb", "^(?<o>(?<x>a)?b)*$", "x", ["a", "a"])
  expectCaptureTexts("aabaaab", "^(?<o>(?<x>a*)b)*$", "o", ["aab", "aaab"])
  expectCaptureTexts("aabaaab", "^(?<o>(?<x>a*)b)*$", "x", ["aa", "aaa"])
  expectCaptureTexts("ab", "^(?<o>(?<x>a)?b)?$", "o", ["ab"])
  expectCaptureTexts("ab", "^(?<o>(?<x>a)?b)?$", "x", ["a"])
  expectCaptureTexts("b", "^(?<o>(?<x>a)?b)?$", "o", ["b"])
  expectCaptureTexts("b", "^(?<o>(?<x>a)?b)?$", "x", [])
  expectCaptureTexts("", "^(?<o>(?<x>a)?b)?$", "o", [])
  expectCaptureTexts("", "^(?<o>(?<x>a)?b)?$", "x", [])
  expect("aaa", "^(?<o>(?<x>a)?)*$", true)
  expect("", "^(?<o>(?<x>a)?)*$", true)

  println ""
  println "All regex-strawman tests passed."
