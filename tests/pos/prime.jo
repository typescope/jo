union List = Nil | Cons(head: Int, tail: List)

def isPrime(primes: List, n: Int): Bool =
  match primes
    case Nil => true
    case Cons x xs =>
      if n % x == 0 then
        false
      else
        isPrime xs n

def prime(primes: List, cur: Int, until: Int): Unit =
  if cur < until then
    if isPrime primes cur then
      println cur
      val primes2: List = Cons(cur, primes)
      prime primes2 (1 + cur) until
    else
      prime primes (1 + cur) until

def primeUntil(until: Int): Unit =
  var primes: List = Cons 2 Nil
  var cur = 3
  while cur < until do
    if isPrime primes cur then
      println cur
      primes = Cons(cur, primes)
    end
    cur = cur + 1

def main =
  prime Cons(2, Nil) 3 100

  primeUntil 100
