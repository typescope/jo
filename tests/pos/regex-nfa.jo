// Thompson NFA-based Regular Expression Matcher
// ===============================================
//
// Clean graph-based representation where:
// - States are just integers (0 = Start, 1 = Finish, 2+ = other states)
// - Characters are stored on edges (transitions)
//
// TIME COMPLEXITY: O(n*m) where n = input length, m = number of states
// No backtracking, no exponential blowup!

param DEBUG: Bool = false

def Start: Int = 0
def Finish: Int = 1

// Edge labels: either epsilon (no character consumed) or a character match
object Epsilon
type Label = Epsilon | Char

// Edge: a transition in the NFA graph
class Edge(from: Int, label: Label, to: Int)

// Pattern AST: parsed regex structure
union Pattern =
    Lit(c: Char)
  | Seq(p1: Pattern, p2: Pattern)
  | Or(p1: Pattern, p2: Pattern)
  | Star(p: Pattern)
  | Optional(p: Pattern)

// NFA: Directed graph with labeled edges
class NFA
  private var transitions: List[Edge] = List.empty
  private var stateCounter: Int = 2  // Start=0, Finish=1, others start from 2

  // Create a new state
  def newState(): Int =
    val id = stateCounter
    stateCounter = stateCounter + 1
    id

  // Get the number of states in the NFA
  def numStates: Int = stateCounter

  // Add a labeled transition
  def addTransition(from: Int, label: Label, to: Int): Unit =
    transitions = transitions.prepend new Edge(from, label, to)

  // Get all successors reachable via a specific label
  def getSuccessors(state: Int, label: Label): List[Int] =
    collectSuccessors transitions state label List.empty

  def collectSuccessors(trans: List[Edge], from: Int, lbl: Label, acc: List[Int]): List[Int] =
    var result = acc
    var list = trans
    while !list.isEmpty do
      match list
        case [] =>
        case [edge, ..rest] =>
          list = rest
          if edge.from == from && (labelsMatch edge.label lbl) then
            result = result.prepend edge.to
      end
    end
    result

  def labelsMatch(l1: Label, l2: Label): Bool =
    match l1
      case Epsilon =>
        match l2
          case Epsilon => true
          case _ => false
        end
      case c1: Char =>
        match l2
          case c2: Char => c1.toInt == c2.toInt
          case _ => false
        end
end

// construct: Build NFA transitions for a pattern between from and to states
def construct(pat: Pattern, from: Int, to: Int, nfa: NFA): Unit =
  match pat
    // Alternation: both branches go from 'from' to 'to'
    case Or(lhs, rhs) =>
      construct lhs from to nfa
      construct rhs from to nfa

    // Star: pattern can repeat zero or more times
    // from --ε--> to (skip), pattern goes from -> from (creates loop)
    case Star(p) =>
      nfa.addTransition from Epsilon to
      construct p from from nfa

    // Optional: epsilon from 'from' to 'to' (skip), or go through pattern
    case Optional(p) =>
      nfa.addTransition from Epsilon to
      construct p from to nfa

    // Sequence: connect via intermediate state
    case Seq(p1, p2) =>
      val mid = nfa.newState()
      construct p1 from mid nfa
      construct p2 mid to nfa

    // Character: direct transition with character edge
    case Lit(c) =>
      nfa.addTransition from c to
  end

// Scanner: tokenizes regex patterns
class Scanner(reg: String)
  var index: Int = 0

  def hasMore() = index < reg.size

  def peek(): Int = reg[index]

  def next(): Int =
    val c = reg[index]
    index = index + 1
    c

  def eat(c: Int): Unit =
    assert (hasMore() && peek() == c) "unexpected character"
    next()
end

// Parser: builds Pattern AST from regex string
class Parser(scanner: Scanner)
  def parseAlternation(): Pattern =
    val left = parseSequence()
    if scanner.hasMore() && scanner.peek() == '|'.toInt then
      scanner.next()
      val right = parseAlternation()
      Or(left, right)
    else
      left

  def parseSequence(): Pattern =
    if !scanner.hasMore() || scanner.peek() == ')'.toInt || scanner.peek() == '|'.toInt then
      Lit(0.toChar)  // epsilon
    else
      val head = parsePostfix()
      if !scanner.hasMore() || scanner.peek() == ')'.toInt || scanner.peek() == '|'.toInt then
        head
      else
        val rest = parseSequence()
        Seq(head, rest)

  def parsePostfix(): Pattern =
    val atom = parseAtom()
    if scanner.hasMore() then
      val c = scanner.peek()
      if c == '*'.toInt then
        scanner.next()
        Star(atom)
      else if c == '?'.toInt then
        scanner.next()
        Optional(atom)
      else
        atom
    else
      atom

  def parseAtom(): Pattern =
    if !scanner.hasMore() then
      Lit(0.toChar)  // epsilon
    else
      val c = scanner.peek()
      if c == '('.toInt then
        scanner.next()
        val pat = parseAlternation()
        scanner.eat ')'.toInt
        pat
      else if c == ')'.toInt || c == '|'.toInt || c == '*'.toInt || c == '?'.toInt then
        Lit(0.toChar)  // epsilon
      else
        scanner.next()
        Lit(c.toChar)
end

// compile: Parse pattern and build NFA
def compile(pat: String): NFA =
  debug "Compiling"
  val scanner = new Scanner(pat)
  val parser = new Parser(scanner)
  val ast = parser.parseAlternation()
  val nfa = new NFA
  construct ast Start Finish nfa
  nfa

// Simulator: NFA simulation functions
section Simulator
  // addState: Compute epsilon closure iteratively - follow all epsilon transitions
  def addState(nfa: NFA, states: List[Int], state: Int): List[Int] =
    var result = states
    var worklist: List[Int] = [state]

    while !worklist.isEmpty do
      match worklist
        case [] =>
        case [s, ..rest] =>
          worklist = rest
          if !(contains result s) then
            result = result.prepend s
            val successors = nfa.getSuccessors s Epsilon
            worklist = worklist ++ successors
      end
    end
    result

  def addAllStates(nfa: NFA, states: List[Int], toAdd: List[Int]): List[Int] =
    var result = states
    var todo = toAdd

    while !todo.isEmpty do
      match todo
        case [] =>
        case [s, ..rest] =>
          todo = rest
          result = addState nfa result s
      end
    end
    result

  def contains(states: List[Int], state: Int): Bool =
    var found = false
    var list = states
    while !found && !list.isEmpty do
      match list
        case [] =>
        case [s, ..rest] =>
          list = rest
          if s == state then found = true
      end
    end
    found

  // matchString: Simulate NFA on input
  def matchString(str: String, pat: String): Bool =
    val nfa = compile pat
    var current: List[Int] = addState nfa List.empty Start

    var i = 0
    while i < str.size do
      val c = str[i]
      debug "Processing char"

      var next: List[Int] = List.empty
      var todo: List[Int] = current
      while !todo.isEmpty do
        match todo
          case [] =>

          case [state, ..rest] =>
            todo = rest
            val successors = nfa.getSuccessors state c
            next = addAllStates nfa next successors
        end
      end

      current = next
      i = i + 1
    end

    contains current Finish
end

def debug(msg: String) =
  if DEBUG then println msg

def main receives IO.stdout =
  println "=== Basic Character Matching ==="
  test "abc" "abc"
  test "abc" "abd"

  println ""
  println "=== Kleene Star (*) ==="
  test "bc" "a*bc"
  test "abc" "a*bc"
  test "aabc" "a*bc"
  test "" "a*"
  test "a" "a*"
  test "aaa" "a*"
  test "abc" "a*b*c*"
  test "aaabbbccc" "a*b*c*"

  println ""
  println "=== Optional (?) ==="
  test "ac" "ab?c"
  test "abc" "ab?c"
  test "abbc" "ab?c"

  println ""
  println "=== Alternation (|) ==="
  test "a" "a|b"
  test "b" "a|b"
  test "c" "a|b"
  test "ab" "ab|cd"
  test "cd" "ab|cd"
  test "ac" "ab|cd"

  println ""
  println "=== Complex Patterns ==="
  test "" "(a|b)*"
  test "a" "(a|b)*"
  test "ab" "(a|b)*"
  test "aba" "(a|b)*"
  test "c" "(a|b)*"

  println ""
  println "=== Should Fail ==="
  test "abc" "abcd"
  test "a" "ab"

def test(str: String, pat: String) =
  val nfa = compile pat
  val res = Simulator.matchString str pat
  println
    str + "\t ~ \t" + pat + "\t\t" + (if res then "true" else "false") + "\t[" + nfa.numStates + " states]"
