type Y[T] = Y[T] => T

def Y[T](f: (T => T) => (T => T)): T => T =
  val g = (x: Y[T => T]) =>
    f (a: T) =>
       (x x) a
  g g

def main =
  val fact0 = (f: Int => Int) => (n: Int) =>
    if n == 0 then 1
    else (f (n - 1)) * n

  val fact = Y fact0

  println (fact 0)
  println (fact 4)
  println (fact 5)
  println (fact 10)
