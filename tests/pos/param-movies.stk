type Movie = { name: String, director: String, year: Int }
type MovieFinder = object { def findAll(): List[Movie] }

param finder: MovieFinder

def moviesDirectedBy(arg: String): List[Movie] =
  val allMovies = finder.findAll()
  def filter(movies: List[Movie]): List[Movie] =
    match movies
      case [] => List.empty
      case [m, rest*] =>
        if m.director == arg then (filter rest).prepend(m)
        else filter rest
    end
  end
  filter allMovies

def main =
  val testFinder: MovieFinder = object {
    def findAll(): List[Movie] =
      val movie1 = { name: "A", director: "a", year: 2010 }
      val movie2 = { name: "B", director: "b", year: 2023 }
      List.empty + movie1 + movie2
  }

  val res = moviesDirectedBy "b" with finder = testFinder
  res.foreach (m => println m.name)
