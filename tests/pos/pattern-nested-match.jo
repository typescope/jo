data Option[T] = None | Some(v: T)
class Config(host: Option[String], port: Int)

def test(opt: Option[Config]) =
  match opt
    // OK: cfg is bound first, then used in nested match
    case Some(cfg) & match cfg.host with Some(h) => println h
    case _ => println "no config"

def main =
  val config = new Config(Some "localhost", 8080)
  test (Some config)
  test None
