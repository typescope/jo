fun fact(n: Int): Int =
  if n == 0 then 1
  else
    val r = fact (n - 1)
    r * n

fun mul(m: Int, n: Int): Int =
  if (m == 0) or (n == 0) then 0
  else
    if 1 & m == 0 then
      val a = mul m (1 >> n)
      a + a
    else
      val b = mul m (1 >> n)
      b + b + n

fun test1(): Unit =
  val a = fact 0
  val b = fact 4
  val c = fact 5
  a p
  b p
  c p

fun main =
  test1
  mul 2 3 p
  mul 0 3 p
  mul 3 0 p
  mul 5 6 p
