fun ident[T](x: T): T = x

fun foo[T <: {a: Int}](x: T): Int = x.a

fun test1[X, Y <: X](y: Y): X = y

fun test2[X <: Int](x: X): Int = x

fun swap[S, T](x: {a: S, b: T}): {a: T, b: S} =
  { a = x.b, b = x.a }

ident[Int] 3 p

val x = { a = 4, b = false }
val y = swap[Int, Bool] x

y.b p

foo[{a: Int}] x p
