param DEBUG: Bool = false

type Seg = #Seg(start: Int, str: String)

type Cont = Seg => Bool
type Reg  = (Seg, Cont) => Bool

fun epsilon(seg: Seg, cont: Cont): Bool =
  debug "epsilon"
  cont seg

fun star(reg: Reg, seg: Seg, cont: Cont): Bool =
  debug "star"
  alt
    (seg, cont) => epsilon seg cont
    (seg, cont) => plus reg seg cont
    seg
    cont

fun plus(reg: Reg, seg: Seg, cont: Cont): Bool =
  debug "plus"
  val cont1 = (seg) => star reg seg cont
  reg seg cont1

fun alt(reg1: Reg, reg2: Reg, seg: Seg, cont: Cont): Bool =
  debug "alt"
  if reg1 seg cont then true
  else if reg2 seg cont then true
  else false

fun seq(regs: List[Reg], seg: Seg, cont: Cont): Bool =
  match regs
    case #Nil => cont seg
    case #Cons reg rest =>
      val cont1 = (seg) => seq rest seg cont
      reg seg cont1

fun char(c: Char, seg: Seg, cont: Cont): Bool =
  debug (charToStr c)
  if seg.start >= seg.str.size then
    false

  else if seg.str(seg.start) == c then
    cont
      #Seg (seg.start + 1) seg.str

  else
    false

fun dot(seg: Seg, cont: Cont): Bool =
  debug "."
  if seg.start < seg.str.size then
    cont
      #Seg (seg.start + 1) seg.str

  else
    false

fun construct(reg: String): Reg =
  val scanner = object {
    var index = 0

    def cur() = reg index

    def hasMore() = index < reg.size

    def peek(): Char = reg(index)

    def eat(c: Char): Unit =
      val cStr = charToStr c
      assert
        hasMore()
        "expect " + cStr + ", but reached end of pattern"

      assert
        cur() == c
        "expect " + cStr + ", found = " + (charToStr cur())

      next()

    def next(): Char =
      val c = reg(index)
      index = index + 1
      c
  }

  val parser = object {
    def parseSequence(): List[Reg] =
      if not scanner.hasMore() then
        #Nil
      else if scanner.cur() == ')' then
        #Nil
      else
        #Cons parseComposite() parseSequence()

    def parseComposite(): Reg =
      val atom = parseAtom()
      if scanner.hasMore() then
        val c = scanner.peek()
        if c == '*' then
          scanner.next()
          (seg, cont) => star atom seg cont

        else if c == '+' then
          scanner.next()
          (seg, cont) => plus atom seg cont

        else
          atom
        end

      else
        atom

    def parseAtom(): Reg =
      if not scanner.hasMore() then
        (seg, cont) => epsilon seg cont
      else
        val c = scanner.next()
        if c == '(' then
          val regs = parseSequence()
          val reg = (seg, cont) => seq regs seg cont
          scanner.eat ')'
          reg

        else if c == '.' then
          (seg, cont) => dot seg cont

        else
          (seg, cont) => char c seg cont

  }

  val regs = parser.parseSequence()
  (seg, cont) => seq regs seg cont
end

fun matchString(str: String, pat: String): Bool =
  val reg : Reg  = construct pat
  val cont: Cont = (seg) => seg.start == str.size
  reg #Seg(0, str) cont

fun debug(msg: String) =
  if DEBUG then println(msg)

fun main =
  test "abba" "abba"
  test "abba" ".b.a"
  test "abba" ".*ba"
  test "abxba" ".*x.*"
  test "abababa" ".*(ba)*"
  test "abababa" ".*(ba)+"

  test "abba" "ba"
  test "abababc" ".*(ba)+"

fun test(str: String, pat: String) =
  val res = matchString str pat
  println
    str + "\t ~ \t" + pat + "\t\t" + (if res then "true" else "false")
