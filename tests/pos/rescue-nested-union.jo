union AppError = NotFound | ParseError(msg: String)

class Data(value: Int)

type FetchResult = Data | AppError

def fetchData(ok: Bool): FetchResult =
  if ok then Data(42)
  else NotFound

def process(ok: Bool): Data =
  fetchData(ok) rescue err: AppError => Data(-1)

def main =
  val d1 = process(true)
  println d1.value
  val d2 = process(false)
  println d2.value
