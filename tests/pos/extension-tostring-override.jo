// Test: Extension toString takes precedence over class toString in duck type adaptation
// When a class has its own toString and is extended with another toString,
// println adaptation should prefer the extended toString.

class Point(x: Int, y: Int)
  def toString: String = "dummy toString"
end

extension PointExt for Point
  @shadow def toString: String = "(" + this.x.toString + ", " + this.y.toString + ")"
end

type EPoint = Point :+ [PointExt.toString!]

def main receives IO.stdout =
  val p: EPoint = Point(3, 4)

  // Should use extension toString, not class toString
  println(p)
