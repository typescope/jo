import jo.IO.*

def main =
  ioTest() with stdin = () => "jo"

def ioTest =
  stdout "name: "
  val name = stdin()
  println
    "hello, " + name

  val file = open("test-data.txt")
  file.write("123456789\n")
  file.write("abcdef")
  file.seek 0
  assert file.hasMore "no more"
  stdout
    file.readLine + "\n"
  file.close()

  val file2 = IO.open("test-data.txt")
  stdout
    file2.readLine + "\n"
  file2.close()
