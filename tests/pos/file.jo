def main =
  ioTest with stdin = { def readLine = "jo" }

def ioTest =
  IO.stdout.write("name: ")
  val name = stdin.readLine
  println
    "hello, " + name

  val file = IO.open("test-data.txt")
  file.write("123456789\n")
  file.write("abcdef")
  file.seek 0
  assert file.hasMore "no more"
  stdout.write
    file.readLine + "\n"
  file.close

  val file2 = IO.open("test-data.txt")
  IO.stdout.write
    file2.readLine + "\n"
  file2.close
