param indent: Int
param pageWidth: Int

def line(text: String): Unit =
  var i = 0
  while i < indent do
    print ' '
    i = i + 1
  println text

  println:
    "indent = " + indent

  println:
    "pageWidth = " + pageWidth

interface Printer
  def print(text: String): Unit receives indent
end

def makeLinePrinter(): Printer = (text) => line text

def main =
  val f = with indent = 5, pageWidth = 2 in makeLinePrinter
  with indent = 10, pageWidth = 4 in f.print "hello, world!"
