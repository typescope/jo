data List[T] = Nil | Cons(head: T, tail: List[T])

def main =
  test (Some (Some 5))

  test (Some None)

  test None

  test2 (Cons 4 (Cons 1 (Cons 5 Nil)))
  test2 (Cons 4 (Cons 3 Nil))
  test2 (Cons 4 Nil)
  test2 Nil

def test(a: Option[Option[Int]]): Unit =
  match a
    case Some None => println "some none"
    case Some (Some n) => println n
    case None => println "none"

pattern (x: Int) :: (rest: List[Int]): Cons[Int] =
  case Cons x rest

pattern List2(x: Int, y: Int): Partial[List[Int]] =
  case Cons x (Cons y Nil)

def test2(a: List[Int]): Unit =
  match a
    case Cons x inner@(Cons y rest) => println (x + inner.head)
    case Cons x Nil => println x
    case Nil => println "empty"

  match a
    case Cons _ (Cons _ Nil) | Cons _ Nil | Nil => println "size < 2"
    case _ => println "size > 2"

  match a
    case Cons _ l@(Cons _ Nil) | l@(Cons _ Nil) => println l.head
    case _ => println "size > 2"

  match a
    case (Cons x Nil) | (Cons x (Cons _ _)) =>
      println
        "binding in or patterns: " + x

    case Nil =>

  match a
    case (x :: Nil) | (x :: (Cons _ _)) =>
      println
        "Infix pattern predicate: " + x

    case Nil =>

  match a
    case |(Cons x Nil, Cons x (Cons _ _)) =>
      println
        "apply or patterns: " + x

    case Nil =>

  match a
    case List2 x y =>
      println
        (intToStr x) + ", " + (intToStr y)

    case _ =>
      println "not list2"
