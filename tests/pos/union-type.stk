type Option = <None, Some Int>
type Sum = <Left Int, Right Int>
type Bot = < >

type OptionSum = <None, Some Sum>

val a: Sum = #Left 3 of Sum
val b: Option = #None of Option
val c: Option = #Some 5 of Option
val d: OptionSum = #Some (#Right 2024 of Sum) of OptionSum

fun foo(x: Sum): Int =
  match x
    case #Left n =>  n n +
    case #Right n => n n *

match c
  case #None => 0 p
  case #Some n => n p

a foo p

match d
  case #None => 0 p
  case #Some sum =>
    match sum
      case #Left v  =>
        99 p
        v p

      case #Right v =>
        100 p
        v p
