param indent: Int

def line(text: String): Unit =
  var i = 0
  while i < indent do
    print ' '
    i = i + 1
  println text

type Printer = String => Unit receives indent

def makeLinePrinter(): Printer =
  (text) => line text

def main =
  val f = makeLinePrinter with indent = 5
  f "hello, world!" with indent = 10
