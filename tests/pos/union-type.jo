class None
class Some(value: Int)
type Option = None | Some

class Left(value: Int)
class Right(value: Int)
type Either = Left | Right

def foo(x: Either): Int =
  match x
    case l: Left =>  l.value * 2
    case r: Right => r.value * r.value

def main =
  val a: Either = new Left(3)
  val c: Option = new Some(5)

  match c
    case _: None => println 0
    case s: Some => println s.value

  println (foo a)
