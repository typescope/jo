def main =
  var a = 3
  var b = 1
  val r =
    a + b + (
      if a > 0 then
        b = 2
        a = 4
        a + 1
      else
        b = 2
        a = 5
        a * 2
      )
      + b + a + (
      if a > 0 then
        a = 10
        a + 1
      else
        a = 20
        a * 2
      )

  println r
