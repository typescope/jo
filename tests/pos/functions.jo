class A
class B

type F1 = A => (A | B)
type F2 = (A | B) => A

def foo(a: Int => Int): Int => Int = a

def bar(a: (Int, Bool) => Int): (Int, Bool) => Int = a

def qux(a: (Int, Bool) => (Int, Bool) => Int): (Int, Bool) => (Int, Bool) => Int = a

def test(f: F2): F1 = f

def makeMul(x: Int): Int => Int = (n: Int) => x * n

def app(x: Int, f: Int => Int): Int = f x

def main =
  val f0 = (x: Int) => x + x
  println (f0 10)

  val f1 = makeMul 5
  println (f1 2)

  val f2 = makeMul 8
  println (f2 3)

  println (app 10 f2)
