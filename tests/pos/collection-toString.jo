def main =
  // Test List.toString
  val list = [1, 2, 3, 4, 5]
  println list.toString

  val emptyList: List[Int] = []
  println emptyList.toString

  // Test Map.toString (immutable)
  val map = { 1: "one", 2: "two", 3: "three" }
  println map.toString

  val emptyMap: Map[Int, String] = {}
  println emptyMap.toString

  // Test Set.toString (immutable)
  val set = { 1, 2, 3, 4 }
  println set.toString

  val emptySet: Set[Int] = {}
  println emptySet.toString
