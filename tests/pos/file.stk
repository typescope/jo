fun main =
  ioTest with stdin = object { def readLine = "stk" }

fun ioTest =
  stdout.write("name: ")
  val name = stdin.readLine
  println
    "hello, " + name

  val file = open("abc.txt")
  file.write("123456789")
  file.seek 0
  stdout.write
    file.readLine + "\n"
  file.close

  val file2 = open("abc.txt")
  stdout.write
    file2.readLine + "\n"
  file2.close
