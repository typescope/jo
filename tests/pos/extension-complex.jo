// Test: Extension operator methods (infix) for DSL - Complex numbers

class Complex(re: Int, im: Int)

// Extension with arithmetic operators
extension RichComplex for Complex
  // Accessor methods
  def real: Int = this.re
  def imag: Int = this.im

  // Prefix negation operator
  def ~-(): RichComplex = new Complex(- this.re, - this.im)

  // Infix operators
  def +(other: Complex): RichComplex =
    new Complex(this.re + other.re, this.im + other.im)

  def -(other: Complex): RichComplex =
    new Complex(this.re - other.re, this.im - other.im)

  def *(other: Complex): RichComplex =
    // (a + bi)(c + di) = (ac - bd) + (ad + bc)i
    val re = this.re * other.re - this.im * other.im
    val im = this.re * other.im + this.im * other.re
    new Complex(re, im)

  // Magnitude squared
  def magnitudeSquared: Int =
    this.re * this.re + this.im * this.im

  // Conjugate
  def ~~ : RichComplex =
    new Complex(this.re, - this.im)

  // String representation
  def show: String =
    if this.im >= 0 then
      this.re.toString + " + " + this.im.toString + "i"
    else
      this.re.toString + " - " + (- this.im).toString + "i"
end

def main receives IO.stdout =
  val c1: RichComplex = new Complex(3, 4)   // 3 + 4i
  val c2: RichComplex = new Complex(1, 2)   // 1 + 2i

  // Test accessors
  println("c1 = " + c1.show)
  println("c2 = " + c2.show)

  // Test prefix negation operator
  val negC1: RichComplex = -c1
  println("-c1 = " + negC1.show)

  // Test addition via operator
  val sum: RichComplex = c1 + c2
  println("c1 + c2 = " + sum.show)

  // Test subtraction via operator
  val diff: RichComplex = c1 - c2
  println("c1 - c2 = " + diff.show)

  // Test multiplication via operator
  // (3 + 4i)(1 + 2i) = 3 + 6i + 4i + 8i^2 = 3 + 10i - 8 = -5 + 10i
  val prod: RichComplex = c1 * c2
  println("c1 * c2 = " + prod.show)

  // Test conjugate
  val conj: RichComplex = ~c1
  println("conjugate(c1) = " + conj.show)

  // Test magnitude squared: |3 + 4i|^2 = 9 + 16 = 25
  val mag = c1.magnitudeSquared
  println("|c1|^2 = " + mag.toString)

  // Chain operations: (c1 + c2) * c1.conjugate
  val chained: RichComplex = (c1 + c2) * ~c1
  println("(c1 + c2) * conj(c1) = " + chained.show)
end
