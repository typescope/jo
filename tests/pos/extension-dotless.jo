// Test: Extension type with parenthesis-less call
// Currently fails: parenthesis-less calls do not work with extension types

class Some[T](value: T)
object None

extension OptionOps[T] for Some[T] | None
  def isEmpty: Bool =
    match this
      case _: Some[T] => false
      case None => true
  end

  def getOrElse(default: T): T =
    match this
      case s: Some[T] => s.value
      case None => default
  end
end

type Option[T] = (Some[T] | None) :+ [OptionOps.isEmpty, OptionOps.getOrElse]

def main receives IO.stdout =
  val opt: Option[Int] = Some(42)
  val empty: Option[Int] = None

  println:
    opt.getOrElse 0

  println:
    empty.getOrElse 99
