fun foo(x: Int) = x x +

val a: Int = 5 foo

fun fact(x: Int) =
  if 0 x == then 1
  else x 1 - fact x *

val b: Int = 10 fact

fun f(x: Int) = x g
fun g(x: Int) = x f

fun h(x: Int): Int = x f x g +

fun k(x: Int): Bool = x f x g and

fun m(x: Int) =
  if 0 x == then { a = 1 }
  else { a = x 1 - m, b = x }

fun test1(x: Int): { a: Int } =
  10 m

fun q(x: Int) =
  if 0 x == then { a = 1 }
  else { a = x, b = 1 (x 1 - q).a + }

fun test2(x: Int): { a: Int } =
  10 q
