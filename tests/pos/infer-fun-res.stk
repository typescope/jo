fun foo(x: Int) = x + x


fun fact(x: Int): Int =
  if 0 == x then 1
  else fact (x - 1) * x


fun q(x: Int): { a: Int } =
  if 0 == x then { a = 1 }
  else
    val r = q (x - 1)
    { a = x, b = 1 + r.a }

fun test2(x: Int): { a: Int } =
  q 10

fun main =
  val a: Int = foo 5
  val b: Int = fact 10

  (test2 10).a p
