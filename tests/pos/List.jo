interface List[T]
  def size: Int
  def get(i: Int): T
  def slice(from: Int, to: Int): List[T]

  def updated(i: Int, v: T): List[T]
  def +(v: T): List[T]
  def prepend(v: T): List[T]
  def ++(l: List[T]): List[T]

  def map[S](f: T => S): List[S]
  def foreach(f: T => Unit): Unit
end

section List
  union Repr[T] =
      Nil
    | Cons(head: T, tail: List[T])
    | Append(prefix: List[T], last: T)
    | Concat(lhs: List[T], rhs: List[T])

  pattern Size[T](n: Int): Repr[T] =
    case Nil then n = 0
    case Cons(_, tail) then n = 1 + tail.size
    case Append(prefix, _) then n = prefix.size + 1
    case Concat(lhs, rhs) then n = lhs.size + rhs.size

  def errorIndex(i: Int): Bottom = abort ("invalid index for list " + i)

  def empty[T]: List[T] = new ListImpl[T](Nil)

  class ListImpl[T](repr: Repr[T])
    val _size: Int = match repr case Size(n) => n

    def size: Int = _size

    def get(i: Int): T =
      if either (i < 0) (i > size) then errorIndex i

      match repr
        case Nil => errorIndex i

        case Cons(v, tail) =>
          if i == 0 then v else tail[i - 1]

        case Append(prefix, v) =>
          if i == size - 1 then v else prefix[i]

        case Concat(lhs, rhs) =>
          if i < lhs.size then lhs[i] else rhs[i - lhs.size]
      end

    def slice(from: Int, to: Int): List[T] =
      var result: List[T] = new ListImpl[T](Nil)
      var i = from
      while i < to do
        result = result + this[i]
        i = i + 1
      end
      result

    def updated(i: Int, value: T): List[T] =
      if either (i < 0) (i > size) then errorIndex i

      match repr
        case Nil => errorIndex i

        case Cons(v, tail) =>
          if i == 0 then
            new ListImpl(Cons value tail)
          else
            new ListImpl(Cons value tail.updated(i + 1, value))

        case Append(prefix, v) =>
          if i == size - 1 then
            new ListImpl(Append prefix value)
          else
            new ListImpl(Append prefix.updated(i, value) v)

        case Concat(lhs, rhs) =>
          if i < lhs.size then
            new ListImpl(Concat lhs.updated(i, value) rhs)
          else
            new ListImpl(Concat lhs rhs.updated(i - lhs.size, value))
      end


    def +(v: T): List[T] = new ListImpl[T](Append this v)

    def prepend(v: T): List[T] = new ListImpl[T](Cons v this)

    def ++(l: List[T]): List[T] = new ListImpl[T](Concat this l)

    def map[S](f: T => S): List[S] =
      match repr
        case Nil => new ListImpl[S](Nil)

        case Cons(v, tail) =>
          new ListImpl(Cons (f v) (tail.map f))

        case Append(prefix, v) =>
          new ListImpl(Append (prefix.map f) (f v))

        case Concat(lhs, rhs) =>
          new ListImpl(Concat (lhs.map f) (rhs.map f))
      end

    def foreach(op: T => Unit): Unit =
      match repr
        case Nil =>

        case Cons(v, tail) =>
          op v
          tail.foreach op


        case Append(prefix, v) =>
          prefix.foreach op
          op v

        case Concat(lhs, rhs) =>
          lhs.foreach op
          rhs.foreach op
      end

    view List[T]
  end
end

def toList(s: String): List[Char] =
  var l: List[Char] = List.empty
  var i = 0
  while i < s.size do
    l = l + s[i]
    i = i + 1
  end
  l

def main =
  val list = List.empty + "apple" + "orange" + "banana"
  list.foreach (s => println s)

  val email = toList "hello@jo-lang.org"
  match email
    case [(a if a != '@')*, '@', b*] =>
      println "valid email"

    case _ =>
      println "invalid email"
