section List
  class List[T](repr: Repr[T])
    val _size: Int = match repr case Size(n) => n

    def size: Int = _size

    def get(i: Int): T =
      if i < 0 || i > size then errorIndex i

      match repr
        case Nil => errorIndex i

        case Cons(v, tail) =>
          if i == 0 then v else tail[i - 1]

        case Append(prefix, v) =>
          if i == size - 1 then v else prefix[i]

        case Concat(lhs, rhs) =>
          if i < lhs.size then lhs[i] else rhs[i - lhs.size]
      end

    def slice(from: Int, len: Int): List[T] =
      var result: List[T] = new List[T](Nil)
      var i = from
      val to = from + len
      while i < to do
        result = result + this[i]
        i = i + 1
      end
      result

    def updated(i: Int, value: T): List[T] =
      if i < 0 || i > size then errorIndex i

      match repr
        case Nil => errorIndex i

        case Cons(v, tail) =>
          if i == 0 then
            new List(Cons value tail)
          else
            new List(Cons value tail.updated(i + 1, value))

        case Append(prefix, v) =>
          if i == size - 1 then
            new List(Append prefix value)
          else
            new List(Append prefix.updated(i, value) v)

        case Concat(lhs, rhs) =>
          if i < lhs.size then
            new List(Concat lhs.updated(i, value) rhs)
          else
            new List(Concat lhs rhs.updated(i - lhs.size, value))
      end


    def +(v: T): List[T] = new List[T](Append this v)

    def prepend(v: T): List[T] = new List(Cons v this)

    def ++(l: List[T]): List[T] = new List[T](Concat this l)

    def map[S](f: T => S): List[S] =
      match repr
        case Nil => new List[S](Nil)

        case Cons(v, tail) =>
          new List(Cons (f v) (tail.map f))

        case Append(prefix, v) =>
          new List(Append (prefix.map f) (f v))

        case Concat(lhs, rhs) =>
          new List(Concat (lhs.map f) (rhs.map f))
      end

    def toString(auto elementShow: Show[T] with [[T].toString]): String =
      // Show at most 100
      var res = "["
      var count = 0

      while count < 100 && count < size do
        val text = elementShow.show this.get(count)
        if count == 0 then
          res = res + text
        else
          res = res + ", " + text
        count = count + 1
      end
      if count == 100 then res = res + ", ..."
      res = res + "]"
      res

    def foreach(op: T => Unit): Unit =
      match repr
        case Nil =>

        case Cons(v, tail) =>
          op v
          tail.foreach op


        case Append(prefix, v) =>
          prefix.foreach op
          op v

        case Concat(lhs, rhs) =>
          lhs.foreach op
          rhs.foreach op
      end
  end

  union Repr[T] =
      Nil
    | Cons(head: T, tail: List[T])
    | Append(prefix: List[T], last: T)
    | Concat(lhs: List[T], rhs: List[T])

  pattern Size[T](n: Int): Repr[T] =
    case Nil then n = 0
    case Cons(_, tail) then n = 1 + tail.size
    case Append(prefix, _) then n = prefix.size + 1
    case Concat(lhs, rhs) then n = lhs.size + rhs.size

  def errorIndex(i: Int): Bottom = abort ("invalid index for list " + i)

  def empty[T]: List[T] = new List[T](Nil)
end

type List[T] = List.List[T]

def toList(s: String): List[Char] =
  var l: List[Char] = List.empty
  var i = 0
  while i < s.size do
    l = l + s[i]
    i = i + 1
  end
  l

def main =
  val list = List.empty + "apple" + "orange" + "banana"
  list.foreach (s => println s)

  val email = toList "hello@jo-lang.org"
  match email

    case [..lhs while !'@', '@', ..rhs] =>
      println "valid email: lhs = \{lhs}, rhs = \{rhs}"

    case _ =>
      println "invalid email"
