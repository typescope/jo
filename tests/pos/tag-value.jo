type Sheep = #Sheep(origin: String)
type Cow   = #Cow(origin: String)
type Tiger = #Tiger(origin: String)
type Wolf  = #Wolf(origin: String)

type Herbivore = Sheep | Cow
type Carnivore = Tiger | Wolf
type Animal = Herbivore | Carnivore

def showHerbivore(h: Herbivore): String =
  match h
    case s: Sheep => "Sheep: " + s.origin
    case c: Cow => "Cow: " + c.origin

def showCarnivore(c: Carnivore): String =
  match c
    case t: Tiger => "Tiger: " + t.origin
    case w: Wolf => "Wolf: " + w.origin

def showAnimal(a: Animal): String =
  match a
    case h: Herbivore => showHerbivore h
    case c: Carnivore => showCarnivore c

def testOptionParamName: Unit =
  type Position = #Position(Int, Int)
  val pos: Position = #Position 5 10
  pos._1 p
  pos._2 p

  type Point = #Point(Int, y: Int)
  val point: Point = #Point 15 20
  point._1 p
  point.y p

  type Tuple = #Tuple(x: Int, Int)
  val tuple: Tuple = #Tuple 30 40
  tuple.x p
  tuple._2 p

def main =
  val c = #Cow "Europe"
  val t = #Tiger "Asian"
  val w = #Wolf "Italy"
  val s = #Sheep "Ireland"

  println (showAnimal c)
  println (showHerbivore c)

  println (showAnimal t)
  println (showCarnivore t)

  println (showAnimal w)
  println (showCarnivore w)

  println (showAnimal s)
  println (showHerbivore s)

  testOptionParamName
