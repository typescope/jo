type Student = #Student(name: String, sex: Bool, age: Int)

pattern Student(s: String, sex: Bool, age: Int): Student =
  #Student s sex age

pattern Name(name: String): Student =
  #Student name _ _

pattern Some[T](value: T): #Some(v: T) =
  #Some value

pattern None: #None = #None

pattern InferRes(name: String, sex: Bool, age: Int): Student =
  #Student name sex age

pattern Type(s: Student): Student = s: Student

fun test(s: Student) =
  match s
    case Name n => println n

  match s
    case InferRes n _ _ => println n

  match s
    case Student n s a => println n

  match (match s case Type u => u)
    case Student n s a => println n

fun test2(a: Option[String]) =
  match a
    case Some s => println s
    case None => println "none"

fun main =
  test (#Student "bla" true 23)

  test2 (#Some "abc")

  test2 #None
