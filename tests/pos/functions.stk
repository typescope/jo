type F1 = {a: Int, b: Int} => {x: Int}
type F2 = {a: Int} => {x: Int, y: Int}

fun foo(a: Int => Int): Int => Int = a

fun bar(a: Int * Bool => Int): Int * Bool => Int = a

fun qux(a: Int * Bool => Int * Bool => Int): Int * Bool => Int * Bool => Int = a

fun test(f: F2): F1 = f

fun makeMul(x: Int): Int => Int = (n: Int) => x n *

fun app(x: Int, f: Int => Int): Int = x => f

val f0 = (x: Int) => x x +
10 => f0 p

val f1 = 5 makeMul
2 => f1 p

val f2 = 8 makeMul
3 => f2 p

10 f2 app p
