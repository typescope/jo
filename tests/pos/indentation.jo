def fact0(n: Int): Int =
  if 0 == n then 1
  else fact0(n - 1) * n
  end
end

def fact1(n: Int): Int =
  if 0 == n then 1
  else fact1(n - 1) * n
end

def fact2(n: Int): Int =
  if 0 == n then 1
  else fact2(n - 1) * n
  end

def fact3(n: Int): Int = if 0 == n then 1 else fact3(n - 1) * n

def fact4(n: Int): Int = if 0 == n then 1 else fact4(n - 1) * n end

def fact5(n: Int): Int =
  if 0 == n then 1
  else fact5(n - 1) * n end

