fun main =
  test (#Some (#Some 5))

  test (#Some #None)

  test #None

  test2 (Cons 4 (Cons 1 (Cons 5 Nil)))
  test2 (Cons 4 (Cons 3 Nil))
  test2 (Cons 4 Nil)
  test2 Nil

fun test(a: Option[Option[Int]]): Unit =
  match a
    case #Some #None => println "some none"
    case #Some (#Some n) => println (intToStr n)
    case #None => println "none"

type Cons = #Cons(head: Int, tail: List[Int])

pattern Cons(x: Int, rest: List[Int]): Cons =
  #Cons x rest

fun Cons(x: Int, rest: List[Int]): List[Int] =
  #Cons x rest

pattern Nil: #Nil = #Nil
fun Nil: #Nil = #Nil

fun test2(a: List[Int]): Unit =
  match a
    case Cons x inner@(Cons y rest) => println (intToStr (x + inner.head))
    case Cons x Nil => println (intToStr x)
    case Nil => println "empty"

  match a
    case Cons x (Cons y Nil) | Cons _ Nil | Nil => println "size < 2"
    case _ => println "size > 2"
