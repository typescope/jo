pattern Pos: Partial[Int] = case x if x > 0

fun test(a: Seq[Int]) =
  match a
    case [> (x if x > 2), (ys @ Pos)*, z*] =>
      println (intToStr x)
      ys.foreach (x => println (intToStr x))
      println "after pos: "
      z.foreach (x => println (intToStr x))

    case _ =>

fun main =
  val a: Seq[Int] = List.empty + 1 + 8 + 5 + 7 + 9 + (-3) + 10 + 20
  test a
