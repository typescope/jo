type Y[T] = Y[T] => T

fun Y[T](f: (T => T) => (T => T)): T => T =
  val g = (x: Y[T => T]) =>
    f (a: T) =>
       val h = x x
       h a
  g g

fun main =
  val fact0 = (f: Int => Int) => (n: Int) =>
    if n == 0 then 1
    else (f (n - 1)) * n

  val fact = Y fact0

  fact 0 p
  fact 4 p
  fact 5 p
  fact 10 p
