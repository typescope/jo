def NAND(p: Bool, q: Bool): Bool = !(p && q)
def NOT (p: Bool): Bool          = NAND p p
def AND (p: Bool, q: Bool): Bool = NOT (NAND p q)
def OR  (p: Bool, q: Bool): Bool = NAND (NOT p) (NOT q)

def main =
  if NOT true then
    10 p
  else
    20 p

  if AND true false then
    1 p
  else
    2 p

  if OR true false then
    5 p
  else
    10 p
  end
