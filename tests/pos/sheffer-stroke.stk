fun NAND(p: Bool, q: Bool): Bool = p q and not
fun NOT (p: Bool): Bool          = p p NAND
fun AND (p: Bool, q: Bool): Bool = p q NAND NOT
fun OR  (p: Bool, q: Bool): Bool = p NOT q NOT NAND

if true NOT then
  10 p
else
  20 p

if true false AND then
  1 p
else
  2 p

if true false OR then
  5 p
else
  10 p
end
