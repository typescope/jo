type B = { b: Int }
type C = { c: Int }

data Either[S, T] = Left(value: S) | Right(value: T)
data List[T] = Cons(head: T, tail: List[T]) | Nil

def list[T](a: T, b: T): List[T] =
  Cons(a, Cons(b, Nil))

def left[U, V](a: U): Either[U, V] = Left(a)
def right[X, Y](a: Y): Either[X, Y] = Right(a)

def main: Unit =
  list
    left  { b: 3 }
    right { c: 3 }
