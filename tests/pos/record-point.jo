type Point = {x: Int, y: Int}

def prod(p1: Point, p2: Point): Point =
  {x: p1.x * p2.x, y: p1.y * p2.y}

def main =
  val p1: Point = {x: 3, y: 5}
  val p2: Point = {x: 6, y: 8}
  val p3: Point = prod p1 p2

  println (prod p1 p3).x
  println p3.x
  println p3.y

  println {x: 3, y: { a: 4 }}.y.a
