class Point(x: Int, y: Int)

class Nested(a: Int)
class Outer(x: Int, y: Nested)

def prod(p1: Point, p2: Point): Point =
  Point(p1.x * p2.x, p1.y * p2.y)

def main =
  val p1: Point = Point(3, 5)
  val p2: Point = Point(6, 8)
  val p3: Point = prod p1 p2

  println (prod p1 p3).x
  println p3.x
  println p3.y

  println (Outer(3, Nested(4))).y.a
