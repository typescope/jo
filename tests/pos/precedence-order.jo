def add(a: Int, b: Int) = a + b
def sub(a: Int, b: Int) = a - b
def mul(a: Int, b: Int) = a * b
def div(a: Int, b: Int) = a / b

def main =
  testPostFix
  testMixedInfixPostFix

def testPostFix =
  def (a: Int, b: Int) + = add a b
  def (a: Int, b: Int) - = sub a b
  def (a: Int, b: Int) * = mul a b
  def (a: Int, b: Int) / = div a b

  val a = 3 5 + 3 2 * -
  println a

def testMixedInfixPostFix =
  def (a: Int, b: Int) + = add a b

  val a = 4 * 3 10 / 5 +
  println a
