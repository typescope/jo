type Tree =
    #Leaf(value: Int)
  | #Node(left: Tree, right: Tree, value: Int)

fun postOrder(tree: Tree): Unit =
  match tree
    case #Leaf(n) => n p
    case #Node(left, right, value) =>
      postOrder left
      postOrder right
      value p

fun preOrder(tree: Tree): Unit =
  match tree
    case #Leaf(n) => n p
    case #Node(left, right, value) =>
      value p
      preOrder left
      preOrder right

fun main =
  val a: Tree = #Leaf(3)
  val b: Tree = #Node(#Leaf(5), #Leaf(6), 10)
  val tree: Tree = #Node(a, b, 20)

  postOrder tree
  preOrder tree
