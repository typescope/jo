class Movie(name: String, director: String, year: Int)
type MovieFinder = () => List[Movie]

param finder: MovieFinder

def moviesDirectedBy(arg: String): List[Movie] =
  val allMovies = finder()
  def filter(movies: List[Movie]): List[Movie] =
    match movies
      case [] => List.empty
      case [m, ..rest] =>
        if m.director == arg then (filter rest).prepend(m)
        else filter rest
    end
  end
  filter allMovies

def main =
  val testFinder = () =>
    val movie1 = new Movie("A", "a", 2010)
    val movie2 = new Movie("B", "b", 2023)
    [movie1, movie2]

  val res = moviesDirectedBy "b" with finder = testFinder
  for m in res do println m.name
