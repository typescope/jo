// Extension type using a section with prefix methods instead of extension definition

class Some[T](value: T)
object None

section OptionOps
  def [T](it: Some[T] | None) isEmpty: Bool =
    match it
      case _: Some[T] => false
      case _: None => true
    end
  end

  def [T](it: Some[T] | None) getOrElse(default: T): T =
    match it
      case s: Some[T] => s.value
      case _: None => default
  end
end

type Option[T] = extend Some[T] | None with OptionOps

def main =
  val opt: Option[Int] = Some(42)
  val empty: Option[Int] = None
  println opt.isEmpty
  println empty.isEmpty
  println opt.getOrElse(0)
  println empty.getOrElse(99)
