// Test various features of case definitions

class Point(x: Int, y: Int)
class Box(width: Int, height: Int)
class Rect(topLeft: Point, bottomRight: Point)

union Option[T] = Some(value: T) | None
union Either[L, R] = Left(value: L) | Right(value: R)

// Helper functions to create values
def makePoint(x: Int, y: Int): Point = Point x y
def makeRect(): Rect = Rect (Point 0 0) (Point 10 20)
def makeSome[T](x: T): Option[T] = Some x
def makeRight[L, R](x: R): Either[L, R] = Right x

// Test 1: Simple variable binding
def testSimpleVar(): Unit =
  case x = 42
  println x

// Test 2: Constructor pattern
def testConstructor(): Unit =
  val p = Point 4 5
  case Point x y = p
  println x
  println y

// Test 3: Nested patterns
def testNested(): Unit =
  case Rect (Point x1 y1) (Point x2 y2) = makeRect()
  println x1
  println y1
  println x2
  println y2

// Test 4: Type pattern
def testTypePattern(): Unit =
  case n: Int = 100
  println n

// Test 5: Multiple sequential case definitions
def testSequential(): Unit =
  case Point x1 y1 = makePoint 1 2
  case Point x2 y2 = makePoint 3 4
  println x1
  println y1
  println x2
  println y2

// Test 6: Using bound variables in expressions
def testUsingVars(): Unit =
  case Point x y = makePoint 3 4
  val sum = x + y
  println sum

// Test 7: Multiple fields of different types
class Person(name: String, age: Int, active: Bool)

def makePerson(): Person = Person "Alice" 30 true

def testMultipleTypes(): Unit =
  case Person name age active = makePerson()
  println name
  println age
  println active

// Test 8: Wildcard in pattern
def testWildcard(): Unit =
  case Point x _ = makePoint 5 6
  println x

// Test 9: Case def in nested blocks
def testNestedBlock(): Unit =
  val result =
    case Point x y = makePoint 10 20
    x + y
  println result

def main =
  testSimpleVar()
  testConstructor()
  testNested()
  testTypePattern()
  testSequential()
  testUsingVars()
  testMultipleTypes()
  testWildcard()
  testNestedBlock()
