def fact(n: Int): Int =
  if n == 0 then 1
  else
    val r = fact (n - 1)
    r * n

def mul(m: Int, n: Int): Int =
  if either (m == 0) (n == 0) then 0
  else
    if 1 & m == 0 then
      val a = mul m (1 >> n)
      a + a
    else
      val b = mul m (1 >> n)
      b + b + n

def test1(): Unit =
  val a = fact 0
  val b = fact 4
  val c = fact 5
  println a
  println b
  println c

def main =
  test1
  println (mul 2 3)
  println (mul 0 3)
  println (mul 3 0)
  println (mul 5 6)
