import jo.IO.File

param readLine: () => Option[String]

def lineCount =
  def recur(acc: Int): Int =
    match readLine()
      case Some(_) => recur (acc + 1)
      case None    => acc
    end
  end

  recur 0

class TestFile
  var moreAvailable: Bool = true
  var currentLine: Int = 0

  view File

  def close(): Unit = {}

  def seek(pos: Int): Unit = abort "no seek"

  def hasMore(): Bool = currentLine <= 1

  def readLine(): String =
    if currentLine == 0 then
      currentLine = currentLine + 1
      "abc"

    else if currentLine == 1 then
      currentLine = currentLine + 1
      "123"

    else
      ...

  def write(content: String): Unit = abort "no write"
end

def main =
  val file = new TestFile

  val readLineFun: () => Option[String] = () =>
    if file.hasMore then Some(file.readLine())
    else None

  val res = lineCount() with readLine = readLineFun allow none
  println res

def test() =
  val readLineFun = {
    var line: Int = 0
    def apply(): Option[String] =
      if line == 0 then
        line = line + 1
        Some("abc")

      else if line == 1 then
        line = line + 1
        Some("123")

      else
        None
  }

  lineCount() with readLine = readLineFun allow none
