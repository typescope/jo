import jo.IO.File

param readLine: () => Option[String]

def lineCount =
  def recur(acc: Int): Int =
    match readLine()
      case Some(_) => recur (acc + 1)
      case None    => acc
    end
  end

  recur 0

class TestFile
  var moreAvailable: Bool = true
  var currentLine: Int = 0

  view File

  def close(): Unit = pass

  def seek(pos: Int): Unit = abort "no seek"

  def hasMore(): Bool = currentLine <= 1

  def readLine(): String =
    if currentLine == 0 then
      currentLine = currentLine + 1
      "abc"

    else if currentLine == 1 then
      currentLine = currentLine + 1
      "123"

    else
      ...

  def write(content: String): Unit = abort "no write"
end

def main =
  val file = new TestFile

  val readLineFun: () => Option[String] = () =>
    if file.hasMore then Some(file.readLine())
    else None

  val res = allow none in lineCount() with readLine = readLineFun
  println res

class MockInput
  var line: Int = 0
  def read(): Option[String] =
    if line == 0 then
      line = line + 1
      Some("abc")

    else if line == 1 then
      line = line + 1
      Some("123")

    else
      None
end

def test() =
  val input = new MockInput
  val readLineFun = () => input.read()

  allow none in lineCount() with readLine = readLineFun
