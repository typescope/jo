def main receives IO.stdout =
  // Mutable map with explicit constructor
  val m1 = mutable.Map("a" ~ 1, "b" ~ 2, "c" ~ 3)
  println(m1.getOrElse("a", 0))
  println(m1.size)

  // Modify the mutable map
  m1["d"] = 4
  println(m1.size)
  println(m1.getOrElse("d", 0))

  // Empty mutable map
  val m2: mutable.Map[String, Int] = mutable.Map()
  println(m2.size)
  m2["x"] = 10
  println(m2.size)
  println(m2.getOrElse("x", 0))
