def main receives IO.stdout =
  // Mutable map literal with explicit type
  val m1: mutable.Map[String, Int] = {"a": 1, "b": 2, "c": 3}
  println(m1.getOrElse("a", 0))
  println(m1.size)

  // Modify the mutable map
  m1["d"] = 4
  println(m1.size)
  println(m1.getOrElse("d", 0))

  // Empty mutable map
  val m2: mutable.Map[String, Int] = {}
  println(m2.size)
  m2["x"] = 10
  println(m2.size)
  println(m2.getOrElse("x", 0))
