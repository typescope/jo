// Test that Byte, Char, Int, and Float can be used directly in union types

type A = Byte | String
type B = Char | String
type C = Int | String
type D = Float | String

def showA(v: A): String =
  match v
    case b: Byte => "Byte: " + b
    case s: String => "String: " + s

def showB(v: B): String =
  match v
    case c: Char => "Char: " + c
    case s: String => "String: " + s

def showC(v: C): String =
  match v
    case i: Int => "Int: " + i
    case s: String => "String: " + s

def showD(v: D): String =
  match v
    case f: Float => "Float: " + f
    case s: String => "String: " + s

def main =
  val a1: A = intToByte 42
  val a2: A = "hello"

  val b1: B = intToChar 65  // 'A' is 65
  val b2: B = "world"

  val c1: C = 100
  val c2: C = "test"

  val d1: D = 3.14
  val d2: D = "float"

  println(showA a1)
  println(showA a2)
  println(showB b1)
  println(showB b2)
  println(showC c1)
  println(showC c2)
  println(showD d1)
  println(showD d2)
