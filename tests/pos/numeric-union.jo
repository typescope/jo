// Test that Char, Int, and Float can be used directly in union types

type B = Char | String
type C = Int | String
type D = Float | String

def showB(v: B): String =
  match v
    case c: Char => "Char: " + c
    case s: String => "String: " + s

def showC(v: C): String =
  match v
    case i: Int => "Int: " + i
    case s: String => "String: " + s

def main =
  val b1: B = 65.toChar  // 'A' is 65
  val b2: B = "world"

  val c1: C = 100
  val c2: C = "test"

  println(showB b1)
  println(showB b2)
  println(showC c1)
  println(showC c2)
