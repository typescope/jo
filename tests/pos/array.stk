fun main =
  testIntArray
  testBoolArray
  testObjectArray

fun testIntArray =
  val arr: Array[Int] = Array.create[Int] 3

  Array > begin
    set arr 0 10
    set arr 1 12
    set arr 2 14

    size arr p
    get arr 0 p
    get arr 1 p
    get arr 2 p
  end

fun testBoolArray =
  val arr = Array.create[Bool] 3

  fun (b: Bool) pb: Unit =
    if b then println "true" else println "false"

  Array > begin
    set arr 0 true
    set arr 1 false
    set arr 2 true

    size arr p
    get arr 0 pb
    get arr 1 pb
    get arr 2 pb

fun testObjectArray =
  val arr = Array.create[String] 3

  Array > begin
    set arr 0 "a"
    set arr 1 "b"
    set arr 2 "c"

    size arr p
    println (get arr 0)

    println (get arr 1)

    println (get arr 2)
