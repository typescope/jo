type Counter = object {
  def inc(): Unit
  def get(): Int
}

param counter: Counter = newCounter(0)

def newCounter(from: Int): Counter = object {
  var count = from
  def inc() =
    count = count + 1

  def get() = count
}

def testCounter(): Int =
  counter.inc()
  counter.inc()
  counter.get()

def makeFun(): () => Int = () =>
  testCounter()

def main =
  testCounter() p   // 0

  println
    intToStr
      testCounter() allow none // 0

  println
    intToStr
      testCounter() allow none
        with counter = newCounter(4) // 0

  println
    intToStr
      testCounter() allow none with
        counter = newCounter(4) // 0

  makeFun()() p     // 0

  println           // 5
    intToStr
      makeFun()() with counter = newCounter(3)
