type Counter = object {
  def inc(): Unit
  def get(): Int
}

param counter: Counter = newCounter(0)

fun newCounter(from: Int): Counter = object {
  var count = from
  def inc() =
    count = count + 1

  def get() = count
}

fun testCounter(): Int =
  counter.inc()
  counter.inc()
  counter.get()

fun makeFun(): () => Int = () =>
  testCounter()

fun main =
  testCounter() p   // 0

  println
    intToStr
      testCounter() allow none // 0

  println
    intToStr
      testCounter() allow none with counter = newCounter(4) // 0

  makeFun()() p     // 0

  println           // 5
    intToStr
      makeFun()() with counter = newCounter(3)
