def main receives IO.stdout =
  // Immutable map
  val im = Map("a" ~ 1, "b" ~ 2)
  println(im.size)

  // Mutable map
  val mm = mutable.Map("x" ~ 10, "y" ~ 20)
  println(mm.size)
  mm.update("z", 30)
  println(mm.size)

  // Immutable set
  val iset = Set(1, 2, 3)
  println(iset.size)

  // Mutable set
  val ms = mutable.Set(10, 20, 30)
  println(ms.size)
  ms.add(40)
  println(ms.size)

  // Empty with type annotations
  val em: mutable.Map[String, Int] = mutable.Map()
  println(em.size)

  val es: mutable.Set[Int] = mutable.Set()
  println(es.size)
