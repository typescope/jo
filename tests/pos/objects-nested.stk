def foo(x: Int, y: Int) =
  {
    var id = 0
    def makeCounter(init: Int) =
      id = id + 1
      {
        val cid = id
        var count = init
        def inc() = count = count + 1
        def get() = count
        def total() = id
      }

    def makeMul() = (n: Int) => y * n
  }

def main =
  val metaMaker = foo 4 10

  println "counter 1"
  val c1 = metaMaker.makeCounter 5
  c1.inc
  c1.get p
  c1.total p

  println "counter 2"
  val c2 = metaMaker.makeCounter 8
  c1.inc
  c1.get p
  c1.total p

  println "multiplier"
  val f = metaMaker.makeMul
  (f 10) p
