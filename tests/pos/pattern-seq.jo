// Test that only member signature matters
type MySeq[T] = {
  def isEmpty: Bool
  def size: Int
  def get(i: Int): T
}

pattern Pos: Partial[Int] = case x if x > 0

def test(a: MySeq[Int]) =
  match a
    case [> (x if x > 2), (ys @ Pos)*, z*] =>
      println x
      ys.foreach (x => println x)
      println "after pos: "
      z.foreach (x => println x)

    case _ =>

pattern Size[T](n: Int): List[T] =
  case [] with n = 0
  case [x, ..Size(acc)] with n = 1 + acc

def main =
  val a: List[Int] = List 1 8 5 7 9 -3 10 20

  val b = {
    def isEmpty: Bool = a.size == 0
    def size: Int = a.size
    def get(i: Int): Int = a[i]
  }

  test b

  println "test .."
  match a
    case [] =>
    case [x] =>
    case [x, y, ..xs] =>
      println y
      xs.foreach i => println i

  match a case Size v => println ("Size = " + v)
