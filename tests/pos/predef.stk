// test predef

import stk.Set
import stk.Eq.Eq

fun main =
  val l =
    List.empty
      + 3
      + 4

  l.map(x => x * 2).foreach (x => println (intToStr x))
  println
    intToStr
      l.fold 0 (acc, i) => acc + i


  val l2 = List 3 6 8 9 10
  l2.select(i => i % 2 == 0)
    .foreach (i => println (intToStr i))

  l2.select(i => i % 2  == 1)
    .foreach (i => println (intToStr i))

  val eq: Eq[Int] = (a, b) => a == b
  val s = Set eq 2 3 4 7 8
  (s + 3 - 2).foreach i => println (intToStr i)

  val eqStr: Eq[String] = (a, b) => a == b
  val s2 = Set eqStr "Apple" "Orange" "Banana"
  (s2 + "Grape" - "Orange" - "Banana").foreach fruit => println fruit
