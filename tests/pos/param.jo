param indent: Int

def padding(unit: Int): Int = indent * unit

param alpha: Int
param beta: Int

def foo(n: Int): Int = alpha + beta * n

def printInt(x: Int): Unit = println x

def main =
  println "test context parameters"

  val a = with indent = 2 in padding 2
  printInt a

  printInt:
    with indent = 6 in padding 2

  printInt:
    with indent = 6 in padding 4


  printInt:
    with indent = 8 in padding 4

  printInt:
    with alpha = 3, beta = 6 in foo 10

  val b = with alpha = 3, beta = 6 in foo 5
  printInt b

  printInt:
    with alpha = 4, beta = 6 in
      foo:
        with beta = 3 in foo 5

  // check that with args are evaluated with outer bindings
  printInt:
    with alpha = 4, beta = 6 in
      foo:
        with alpha = 2 + beta, beta = 3 + alpha in foo 5
