def main =
  testIntArray()
  testByteArray()
  testBoolArray()
  testCharArray()
  testObjectArray()

def testIntArray =
  val arr: Array[Int] = Array.create[Int] 3

  arr[0] = 10
  arr[1] = 12
  arr[2] = 14

  println (arr.size )
  println arr[0]
  println arr[1]
  println arr[2]

def testByteArray =
  val arr = Array.create[Byte] 3

  arr[0] = '1'
  arr[1] = '2'
  arr[2] = '3'

  println arr.size
  println arr[0]
  println arr[1]
  println arr[2]

def testBoolArray =
  val arr = Array.create[Bool] 13

  arr[0] = true
  arr[1] = true
  arr[2] = false
  arr[12] = false

  println arr.size
  println arr[0]
  println arr[1]
  println arr[2]
  println arr[12]

def testCharArray =
  val arr = Array.create[Char] 3

  arr[0] = 'x'
  arr[1] = 'y'
  arr[2] = 'z'

  println arr.size
  println arr[0]
  println arr[1]
  println arr[2]

def testObjectArray =
  val arr = Array.create[String] 3

  arr[0] = "a"
  arr[1] = "b"
  arr[2] = "c"

  println arr.size
  println arr[0]

  println arr[1]

  println arr[2]
