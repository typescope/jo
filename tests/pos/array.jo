def main =
  testIntArray
  testBoolArray
  testObjectArray

def testIntArray =
  val arr: Array[Int] = Array.create[Int] 3

  Array > begin
    set arr 0 10
    set arr 1 12
    set arr 2 14

    println (size arr)
    println (get arr 0)
    println (get arr 1)
    println (get arr 2)
  end

def testBoolArray =
  val arr = Array.create[Bool] 3

  def (b: Bool) pb: Unit =
    if b then println "true" else println "false"

  Array > begin
    set arr 0 true
    set arr 1 false
    set arr 2 true

    println (size arr)
    get arr 0 pb
    get arr 1 pb
    get arr 2 pb

def testObjectArray =
  val arr = Array.create[String] 3

  Array > begin
    set arr 0 "a"
    set arr 1 "b"
    set arr 2 "c"

    println (size arr)
    println (get arr 0)

    println (get arr 1)

    println (get arr 2)
