data List[T] = Nil | Cons(head: T, tail: List[T])


def (x: Int) :: (rest: List[Int]): Cons[Int] = Cons x rest
pattern (x: Int) :: (rest: List[Int]): Cons[Int] =
  case Cons x rest

param delta: Int
def foo(x: Int): Int =
  x + delta

pattern Len(x: Int): List[Int] =
  case Nil              with x = (foo 0 with delta = 1)
  case _ :: (Len y)     with x = (foo y with delta = 2)

def test(l: List[Int]): Unit =
  match l case Len n => println ("len = " + n)

  match l
    case Len n if (foo n > 2 with delta = 1) => println "len > 1"
    case _ => println "size <= 1"

def main =
  test Nil
  test (5 :: Nil)
