param fontSize: Int

union Element =
    H2(text: String)
  | Label(text: String)
  | P(text: String)
  | Div(elems: List[Element])


def renderText(text: String) =
  println:
    text + " [" + "pageWidth = " + fontSize + "]"

def renderH2(h2: H2) =
  with fontSize = 20 in renderText(h2.text)  // shadowing, fontSize = 20

def renderElement(e: Element): Unit =
  match e
    case h2: H2            => renderH2 h2
    case P text            => renderText text
    case Label text        => renderText text
    case div: Div          => renderDiv div

def renderDiv(div: Div) =
  def recur(elems: List[Element]): Unit =
    match elems
      case [] => pass
      case [e, ..es] =>
        renderElement e
        recur es
    end
  end
  recur div.elems

def main =
  val div: Div = Div:
    List.empty[Element] + (H2 "Test render") + (Label "a dummy html rendering engine") + (P "Hello, HTML!")

  with fontSize = 14 in renderDiv div
