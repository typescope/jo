param fontSize: Int

type H2Element    = #H2(text: String)
type LabelElement = #Label(text: String)
type PElement     = #P(text: String)
type DivElement   = #Div(elems: List[Element])

type Element = H2Element | LabelElement | PElement | DivElement

def renderText(text: String) =
  println
    text + " [" + "pageWidth = " + (intToStr fontSize) + "]"

def renderH2(h2: H2Element) =
  renderText(h2.text) with fontSize = 20  // shadowing, fontSize = 20

def renderElement(e: Element): Unit =
  match e
    case h2: H2Element     => renderH2 h2
    case #P text           => renderText text
    case #Label text       => renderText text
    case div: DivElement   => renderDiv div

def renderDiv(div: DivElement) =
  def recur(elems: List[Element]): Unit =
    match elems
      case [] =>
      case [e, es*] =>
        renderElement e
        recur es
    end
  end
  recur div.elems

def main =
  val div: DivElement = #Div
    List.empty[Element] + (#H2 "Test render") + (#Label "a dummy html rendering engine") + (#P "Hello, HTML!")

  renderDiv div with fontSize = 14
