def main receives IO.stdout =
  // Mutable set literal with explicit type
  val s1: mutable.Set[Int] = {1, 2, 3}
  println(s1.size)
  println(s1.contains(2))
  println(s1.contains(5))

  // Modify the mutable set
  s1 += 4
  println(s1.size)
  println(s1.contains(4))

  // Empty mutable set
  val s2: mutable.Set[Int] = {}
  println(s2.size)
  s2 += 10
  println(s2.size)
  println(s2.contains(10))
