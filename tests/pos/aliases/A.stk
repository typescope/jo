namespace A

type Message = B.Inner.Message

alias def foo = B.foo
alias param prefix = B.prefix

type Flags = Int

section Nested
  alias def foo = B.foo

  alias def Some = B.Inner.Some.Some
  alias pattern Some = B.Inner.Some.Some

  def bar(x: Option[Message]) =
    match x
      case Some s => println s
      case None => println "none"
end

def main =
  Nested.foo "alias foo"

  Nested.foo "alias foo" with prefix = "[warn]"

  Nested.bar (Nested.Some "alias some")

  B.Nested.bar 5
