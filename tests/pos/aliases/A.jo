namespace A

type Message = B.Inner.Message

alias def foo = B.foo
alias param prefix = B.prefix

type Flags = Int

section Nested
  alias def foo = B.foo

  alias def Some = B.Inner.Some
  alias pattern Some = B.Inner.Some

  def bar(x: B.Inner.Option[Message]) =
    match x
      case Some s => println s
      case B.Inner.None => println "none"
end

def main receives IO.stdout =
  Nested.foo "alias foo"

  Nested.foo "alias foo" with prefix = "[warn]"

  Nested.bar (Nested.Some "alias some")

  B.Nested.bar 5
