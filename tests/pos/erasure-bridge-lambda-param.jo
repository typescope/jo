// Tests bridge methods generated by Erasure for interfaces whose abstract methods
// have lambda-typed parameters or return lambda types, instantiated with numeric
// union types (Num = Int | String) or primitive types (Int, Bool).
//
// The bridge adapts between the erased interface signature (Any / Any=>Any) and
// the concrete implementation signature (Num / Num=>Num or Int / Int=>Int).

type Num = Int | String

def showNum(n: Num): String =
  match n
    case i: Int => "Int:" + i
    case s: String => "Str:" + s

// --- Interface 1: method takes T => T as parameter ---
// Erased:         mapWith(Any => Any, Any): Any
// T = Num impl:   mapWith(Num => Num, Num): Num  — bridge wraps lambda param
// T = Int impl:   mapWith(Int => Int, Int): Int  — bridge unboxes x AND wraps lambda
interface Mapper[T]
  def mapWith(f: T => T, x: T): T
end

// --- Interface 2: method takes a binary (T, T) => T lambda ---
// Erased:       foldAll(List, Any, (Any, Any) => Any): Any
// T = Num impl: foldAll(List[Num], Num, (Num, Num) => Num): Num
// T = Int impl: foldAll(List[Int], Int,  (Int,  Int) => Int): Int
interface Folder[T]
  def foldAll(items: List[T], init: T, f: (T, T) => T): T
end

// --- Interface 3: method returns T => T lambda ---
// Erased:       makeDouble(): Any => Any
// T = Num impl: makeDouble(): Num => Num  — bridge wraps returned lambda
// T = Int impl: makeDouble(): Int => Int
interface LambdaMaker[T]
  def makeDouble(): T => T
end

// --- Interface 4: method takes T => Int (return type is untagged Int) ---
// Erased:       measureAll(List, Any => Int): List
// T = Num impl: measureAll(List[Num], Num => Int): List[Int]
interface Measurer[T]
  def measureAll(items: List[T], f: T => Int): List[Int]
end

def runMapper[T](m: Mapper[T], f: T => T, x: T): T = m.mapWith(f, x)
def runFolder[T](fo: Folder[T], items: List[T], init: T, f: (T, T) => T): T = fo.foldAll(items, init, f)
def runLambdaMaker[T](lm: LambdaMaker[T], x: T): T = lm.makeDouble() x
def runMeasurer[T](m: Measurer[T], items: List[T], f: T => Int): List[Int] = m.measureAll(items, f)

def main =
  // --- Mapper[Num]: bridge must wrap lambda f: Any=>Any -> Num=>Num ---
  val double: Num => Num = n =>
    match n
      case i: Int => i * 2
      case s: String => s + s

  val numMapper: Mapper[Num] = (f, x) => f x
  println (showNum (runMapper[Num](numMapper, double, 7)))    // Int:14
  println (showNum (runMapper[Num](numMapper, double, "ab"))) // Str:abab

  // Mapper[Int]: bridge unboxes x: Any->Int AND wraps f: Any=>Any -> Int=>Int
  val intMapper: Mapper[Int] = (f, x) => f x
  println (runMapper[Int](intMapper, x => x + 10, 5))   // 15
  println (runMapper[Int](intMapper, x => x * x, 4))    // 16

  // Mapper[Bool]: bridge unboxes Bool AND wraps Bool=>Bool lambda
  val boolMapper: Mapper[Bool] = (f, x) => f x
  println (runMapper[Bool](boolMapper, x => !x, true))   // false
  println (runMapper[Bool](boolMapper, x => !x, false))  // true

  // --- Folder[Num]: bridge wraps binary (Any,Any)=>Any -> (Num,Num)=>Num ---
  val items: List[Num] = [1, "two", 3, "four"]
  val numFolder: Folder[Num] = (lst, init, f) => lst.fold[Num](init, f)

  val joined = runFolder[Num](numFolder, items, "",
    (acc, v) =>
      match acc
        case _: Int => showNum v
        case s: String => s + "|" + (showNum v)
  )
  println (showNum joined)  // Str:|Int:1|Str:two|Int:3|Str:four

  // Folder[Int]: bridge unboxes Int params in binary lambda
  val intNums: List[Int] = [1, 2, 3, 4, 5]
  val intFolder: Folder[Int] = (lst, init, f) => lst.fold[Int](init, f)
  println (runFolder[Int](intFolder, intNums, 0, (a, b) => a + b))  // 15
  println (runFolder[Int](intFolder, intNums, 1, (a, b) => a * b))  // 120

  // --- LambdaMaker[Num]: bridge wraps returned Any=>Any -> Num=>Num lambda ---
  val numMaker: LambdaMaker[Num] = () => double
  println (showNum (runLambdaMaker[Num](numMaker, 5)))    // Int:10
  println (showNum (runLambdaMaker[Num](numMaker, "x")))  // Str:xx

  // LambdaMaker[Int]: bridge wraps returned Any=>Any -> Int=>Int lambda
  val intMaker: LambdaMaker[Int] = () => (x => x * 3)
  println (runLambdaMaker[Int](intMaker, 7))    // 21
  println (runLambdaMaker[Int](intMaker, -2))   // -6

  // --- Measurer[Num]: bridge wraps f: Any=>Int -> Num=>Int ---
  // (lambda param has tagged input but untagged Int output)
  val numMeasurer: Measurer[Num] = (lst, f) => lst.map[Int](f)
  val lengths = runMeasurer[Num](numMeasurer, items, n =>
    match n
      case i: Int => i
      case s: String => s.length
  )
  for len in lengths do println len  // 1, 3, 1, 4

  // Measurer[Int]: bridge unboxes Int arg inside lambda, returns untagged Int
  val intMeasurer: Measurer[Int] = (lst, f) => lst.map[Int](f)
  val squares = runMeasurer[Int](intMeasurer, intNums, x => x * x)
  for sq in squares do println sq  // 1, 4, 9, 16, 25
