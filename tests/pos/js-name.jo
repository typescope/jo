class Console(log: String, a: Int)

class A
  val const: Int = 3
  val let: Int = 5
  val brk: Int = 10
  val cont: Int = 20
  val constructor: Int = 50
  val function: Int = 100

class B
  def const: Int = 3
  def let: Int = 5
  def brk: Int = 10
  def cont: Int = 20
  def constructor: Int = 50
  def function: Int = 100

def main =
  val console = Console("hello\n", 10)
  print console.log
  println console.a

  val a = new A
  println a.const
  println a.let
  println a.brk
  println a.cont
  println a.constructor
  println a.function

  val b = new B
  println b.const
  println b.let
  println b.brk
  println b.cont
  println b.constructor
  println b.function
