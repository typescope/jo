param level: Int = 0

def plain(x: Int): Int receives none =
  x + 1

def main receives IO.stdout =
  println level

  val nested = with level = 10 in
    val a =
      val p = plain(1)
      level + p

    val b = with level = 20 in
      val p = plain(2)
      level + p

    val d = with level = 31 in
      val inner = with level = 32 in level
      level + inner

    val e = with level = 40 in level

    val f = level
    a + b + d + e + f

  val branchThen = with level = 101 in
    val p = plain(3)
    level + p

  val branchElse =
    if false then
      with level = 301 in
        val p = plain(5)
        level + p
    else
      with level = 401 in
        val p = plain(6)
        level + p

  println nested
  println branchThen
  println branchElse
  println level
