import jo.Int


type Complex = {
  def real: Int
  def image: Int

  def +(c: Complex): Complex
  def -(c: Complex): Complex
  def *(c: Complex): Complex

  def show: String
}

def Complex(x: Int, y: Int): Complex =
  {
    def real = x
    def image = y

    def +(c: Complex): Complex =
      Complex
        Int> x + c.real
        Int> y + c.image

    def -(c: Complex): Complex =
      Complex
        Int> x - c.real
        Int> y - c.image

    def *(c: Complex): Complex =
      Complex
        Int> x * c.real - y * c.image
        Int> x * c.image + y * c.real

    def show: String = "\{x} + \{y}i"
  }

def main =
  val c1 = Complex 1 3
  val c2 = Complex 2 4
  val c3 = Complex 1 5
  val c4 = c1 + c2 * c3

  println c4.show
