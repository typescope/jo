type Eq[T] = object {
  def eq(a: T, b: T): Bool
}

auto def intEq: Eq[Int] = (a, b) => a == b

auto def intString: Eq[String] = (a, b) => a == b

auto def listEq[T](auto eqItem: Eq[T]): Eq[List[T]] = (a, b) =>
  var equal = a.size == b.size
  var i = 0
  while equal && i < a.size do
    equal = equal && (eqItem a[i] b[i])
  equal

type A = object {
  def foo(auto eq: Eq[Int]): Unit
}

type Set[T] = object {
  def size: Int
  def contains(x: T): Bool
  def +(x: T): Set[T]
  def -(x: T): Set[T]
  def select(pred: T => Bool): Set[T]
  def exclude(pred: T => Bool): Set[T]
  def foreach(f: T => Unit): Unit
  def exists(pred: T => Bool): Bool
}

def Set[T](l: ..T)(auto eq: Eq[T]): Set[T] = object {
    def size: Int = l.size

    def contains(x: T): Bool = exists e => eq e x

    def +(x: T): Set[T] =
      if contains x then this
      else
        Set (..(l + x))

    def -(x: T): Set[T] = exclude e => eq x e

    def select(pred: T => Bool): Set[T] =
      Set
        ..(l.select pred)

    def exclude(pred: T => Bool): Set[T] =
      Set
        ..(l.exclude pred)

    def foreach(f: T => Unit): Unit = l.foreach f

    def exists(pred: T => Bool): Bool = l.exists pred
}

def main =
  val s = Set 4 5 8 9
  (s - 5 + 4 + 10).foreach i => println (intToStr i)
