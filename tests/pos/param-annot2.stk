param indent: Int
param pageWidth: Int

fun line(text: String): Unit =
  var i = 0
  while i < indent do
    printChar ' '
    i = i + 1
  println text

  println
    "indent = " + (intToStr indent)

  println
    "pageWidth = " + (intToStr pageWidth)

type Printer = object {
  def apply(text: String): Unit receives indent
}

fun makeLinePrinter(): Printer =
  (text) => line text

fun main =
  val f = makeLinePrinter with indent = 5, pageWidth = 2
  f "hello, world!" with indent = 10, pageWidth = 4
