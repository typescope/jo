def main receives IO.stdout =
  val m1 = {"a" ~ 1, "b" ~ 2, "c" ~ 3}
  match m1.get("a")
    case Some(v) => println(v)
    case None => println("not found")

  match m1.get("b")
    case Some(v) => println(v)
    case None => println("not found")

  val m2 = {"x" ~ "hello", "y" ~ "world"}
  for k ~ v in m2 do
    println(k + " -> " + v)

  val empty: Map[String, Int] = {}
  println(empty.size)
