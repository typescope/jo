def main =
  if ! true then
    println 1
  else
    println 2
  end

  if ! false then
    println 1
  else
    println 2
  end

  if ! false then
    println 10
  else
    println 20
  end

  if false && true then
    println 99
  else
   println -99
  end

  if false || true then
    println 999
  else
    println -999
  end

  // Test short-circuit semantics for &&
  // The rhs should NOT be evaluated when lhs is false
  if false && sideEffect("bad1") then
    println "unreachable"
  end

  // Test short-circuit semantics for ||
  // The rhs should NOT be evaluated when lhs is true
  if true || sideEffect("bad2") then
    println "ok"
  end

  // Test short-circuit with complex rhs containing nested if/else
  val a = true
  val b = false
  if b && (if a then sideEffect("bad3") else false) then
    println "unreachable"
  end

  if a || (if b then true else sideEffect("bad4")) then
    println "ok2"
  end

  def shouldPrint(msg: String): Bool =
    println "should print"
    if b then false else sideEffect(msg)

  // Test that rhs IS evaluated when short-circuit does not apply
  if
    a && shouldPrint("good1")
  then
    println "ok3"
  end

  def shouldNotPrint(msg: String): Bool =
    println "should not print"
    if b then false else sideEffect(msg)

  if
    a || shouldNotPrint("good1")
  then
    println "ok4"
  end

  def shouldPrint2(msg: String): Bool =
    println "should print"
    if a then sideEffect(msg) else false

  if
    b || shouldPrint2("good2")
  then
    println "ok5"
  end

  def shouldNotPrint2(msg: String): Bool =
    println "should print"
    if a then sideEffect(msg) else false

  if
    b && shouldNotPrint2("good2")
  then
    println "ok6"
  end

def sideEffect(msg: String): Bool =
  println msg
  true
