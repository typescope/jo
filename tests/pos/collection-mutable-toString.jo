def main =
  // Test mutable Map.toString
  val mutMap: mutable.Map[Int, String] = { 5: "apple", 3: "banana", 8: "cherry" }
  println mutMap.toString

  val emptyMutMap: mutable.Map[String, Int] = {}
  println emptyMutMap.toString

  // Test mutable Set.toString
  val mutSet: mutable.Set[String] = { "red", "green", "blue" }
  println mutSet.toString

  val emptyMutSet: mutable.Set[String] = {}
  println emptyMutSet.toString
