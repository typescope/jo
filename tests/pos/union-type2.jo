type Option = #None | #Some(value: Int)
type Sum = # Left(value: Int) | #Right(value: Int)

type OptionSum = #None | #Some(value: Sum)

def foo(x: Sum): Int =
  match x
    case #Left n =>  n + n
    case #Right n => n * n

def main =
  val a: Sum = #Left 3
  val b: Option = #None
  val c: Option = #Some 5
  val d: OptionSum = #Some (#Right 2024)

  match c
    case #None => println 0
    case #Some n => println n

  println (foo a)

  match d
    case #None => println 0
    case #Some sum =>
      match sum
        case #Left v  =>
          println 99
          println v

        case #Right v =>
          println 100
          println v
