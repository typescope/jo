import jo.IO

type Counter = {
  def inc(): Unit
  def get(): Int
}

param counter: Counter = newCounter(0)

def newCounter(from: Int): Counter = {
  var count = from
  def inc() =
    count = count + 1

  def get() = count
}

def testCounter(): Int =
  counter.inc()
  counter.inc()
  counter.get()

def makeFun(): () => Int = () =>
  testCounter()

def main receives IO.stdout =
  println testCounter()   // 0

  println
    testCounter() allow none // 0

  println
    testCounter() allow none with counter = newCounter(4) // 0

  println
    testCounter() allow none with counter = newCounter(4) // 0

  println makeFun()()     // 0

  println
    makeFun()() with counter = newCounter(3) // 5
