interface Counter
  def inc(): Unit
  def get(): Int
end

param counter: Counter = newCounter(0)

class CounterImpl(from: Int)
  var count: Int = from

  def inc() =
    count = count + 1

  def get() = count

  view Counter
end

def newCounter(from: Int): Counter = new CounterImpl(from)

def testCounter(): Int =
  counter.inc()
  counter.inc()
  counter.get()

def makeFun(): () => Int = () =>
  testCounter()

def main receives IO.stdout =
  println testCounter()   // 0

  println
    allow none in testCounter() // 0

  println
    allow none in testCounter() with counter = newCounter(4) // 0

  println
    allow none in testCounter() with counter = newCounter(4) // 0

  println makeFun()()     // 0

  println
    makeFun()() with counter = newCounter(3) // 5
