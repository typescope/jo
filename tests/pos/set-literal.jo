// Test set construction

def main receives IO.stdout =
  // Basic set
  val s1 = Set(1, 2, 3)
  println(s1.size)
  println(s1.contains(2))
  println(s1.contains(5))

  // Set with strings
  val s2 = Set("a", "b", "c")
  println(s2.size)
  println(s2.contains("b"))

  // Empty set
  val empty: Set[Int] = Set()
  println(empty.size)

  // Single element
  val single = Set(42)
  println(single.contains(42))
