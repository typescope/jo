type Counter = object {
  def get(): Int
  def inc(): Unit
  def add(n: Int): Unit
  def reset(): Unit
  def upToEven(): Unit
}

def createCounter(init: Int): Counter = object {
  var count = init
  def get() = this.count
  def inc() = count = count + 1
  def add(n: Int) = count = count + n
  def reset() = count = 0
  def upToEven() =
    if count % 2 == 1 then add 1
}

def main =
  val c = createCounter 10
  c.inc
  c.add 10
  c.get p

  c.reset
  c.add 7
  c.upToEven
  c.get p
