type Counter = object {
  def get(): Int
  def inc(): void
  def add(n: Int): void
  def reset(): void
  def upToEven(): void
}

fun createCounter(init: Int): Counter = object {
  var count = init
  def get() = this.count
  def inc() = count <- count + 1
  def add(n: Int) = count <- count + n
  def reset() = count <- 0
  def upToEven() =
    if count % 2 == 1 then add 1
}

fun main =
  val c = createCounter 10
  c.inc
  c.add 10
  c.get p

  c.reset
  c.add 7
  c.upToEven
  c.get p
