// Test edge cases for map literals

def main receives IO.stdout =
  // Empty map
  val empty: Map[String, Int] = {}
  println(empty.size)

  // Single element map
  val single = {"key" ~ 42}
  match single.get("key")
    case Some(v) => println(v)
    case None => println("missing")

  // Nested map (map of maps)
  val nested = {"outer" ~ {"inner" ~ 100}}
  match nested.get("outer")
    case Some(innerMap) =>
      match innerMap.get("inner")
        case Some(v) => println(v)
        case None => println("missing inner")
    case None => println("missing outer")

  // Map with pair variables
  val p1 = "x" ~ 1
  val p2 = "y" ~ 2
  val fromPairs = {p1, p2}
  match fromPairs.get("x")
    case Some(v) => println(v)
    case None => println("missing")
