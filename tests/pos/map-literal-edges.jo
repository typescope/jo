// Test edge cases for map construction

def main receives IO.stdout =
  // Empty map
  val empty: Map[String, Int] = Map()
  println(empty.size)

  // Single element map
  val single = Map("key" ~ 42)
  match single.getOpt("key")
    case Some(v) => println(v)
    case None => println("missing")

  // Nested map (map of maps)
  val nested = Map("outer" ~ Map("inner" ~ 100))
  match nested.getOpt("outer")
    case Some(innerMap) =>
      match innerMap.getOpt("inner")
        case Some(v) => println(v)
        case None => println("missing inner")
    case None => println("missing outer")

  // Using pair variables
  val p1 = "x" ~ 1
  val p2 = "y" ~ 2
  val fromPairs = Map(p1, p2)
  match fromPairs.getOpt("x")
    case Some(v) => println(v)
    case None => println("missing")
