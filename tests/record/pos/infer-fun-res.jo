def foo(x: Int) = x + x


def fact(x: Int): Int =
  if 0 == x then 1
  else fact(x - 1) * x


def q(x: Int): { a: Int } =
  if 0 == x then { a: 1 }
  else
    val r = q (x - 1)
    { a: x, b: 1 + r.a }

def test2(x: Int): { a: Int } =
  q 10

def main =
  val a: Int = foo 5
  val b: Int = fact 10

  println (test2 10).a
