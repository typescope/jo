def Text(s: String): Text = s

def describe(t: Text): String =
  match t
    case [] => "empty"
    case [c] => "single: " + c
    case [first, .., last] => "first: " + first + ", last: " + last
  end

def middleInfo(t: Text): String =
  match t
    case [first, ..middle, last] =>
      "first=" + first + ", middle=" + middle.size.toString + ", last=" + last
    case _ =>
      "short"
  end

def startsWithSpaces(t: Text): String =
  match t
    case [.. while ' '] => "all spaces"
    case [..spaces while ' ', first, ..] =>
      "spaces=" + spaces.size.toString + ", first=" + first
    case _ =>
      "no spaces"
  end

def main =
  println "--- text sequence pattern ---"

  println describe("")
  println describe("x")
  println describe((Text "ab") + (Text "cd"))

  println middleInfo(Text "ab")
  println middleInfo((Text "a") + (Text "xyz") + (Text "b"))

  println startsWithSpaces("   ")
  println startsWithSpaces("  hi")
  println startsWithSpaces("hello")
