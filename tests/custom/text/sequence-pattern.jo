def describe(t: Text): String =
  match t
    case [] => "empty"
    case [c] => "single: " + c
    case [first, .., last] => "first: " + first + ", last: " + last
  end

def middleInfo(t: Text): String =
  match t
    case [first, ..middle, last] =>
      "first=" + first + ", middle=" + middle.size.toString + ", last=" + last
    case _ =>
      "short"
  end

def startsWithSpaces(t: Text): String =
  match t
    case [.. while ' '] => "all spaces"
    case [..spaces while ' ', first, ..] =>
      "spaces=" + spaces.size.toString + ", first=" + first
    case _ =>
      "no spaces"
  end

def main =
  println "--- text sequence pattern ---"

  println describe("" as Text)
  println describe("x" as Text)
  println describe((("ab" as Text) + ("cd" as Text)))

  println middleInfo("ab" as Text)
  println middleInfo((("a" as Text) + ("xyz" as Text) + ("b" as Text)))

  println startsWithSpaces("   " as Text)
  println startsWithSpaces("  hi" as Text)
  println startsWithSpaces("hello" as Text)
