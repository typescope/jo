def text(s: String): Text = s

def main =
  println "--- text iterator ---"

  val t = ((text "a") + (text "\u{1F680}") + (text "\u{4F60}")).slice(0, 3)
  val iter = t.iterator
  println iter.hasNext
  println (iter.next == 'a')
  println iter.hasNext
  println (iter.next == 0x1F680)
  println iter.hasNext
  println (iter.next == 0x4F60)
  println iter.hasNext

  val s = ((text "ab") + (text "cd") + (text "ef")).slice(1, 4)
  println s.iterator.toList.join("")

  val empty = Text.empty.iterator
  println empty.hasNext
