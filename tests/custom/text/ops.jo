def printParts(parts: List[Text]) =
  println parts.map(part => part.toString).join("|")

def Text(s: String): Text = s

def main =
  println "--- text ops ---"

  val e = Text.empty
  println e.isEmpty
  println Text.concat(Text "ab", Text "cd").toString

  val base = Text "abcde"
  println base.size
  println base.get(2)
  println base.slice(1, 3).toString

  val chain = (Text "ab") + "cd" + "ef"
  println chain.toString
  println chain.indexOf("cd")
  println chain.indexOf("cd", 3)
  println chain.indexOf("ef", -2)
  println chain.indexOf("zz")

  printParts((Text "a,b,,c").split(","))
  printParts((Text "abc").split("|"))
  printParts((Text "abc").split(""))

  val text = Text "x\ny\r\nz"
  printParts(text.lines)

  val s = Text "hello world"
  println s.startsWith("hello")
  println s.startsWith("world")
  println s.endsWith("world")
  println s.endsWith("hello")
  println s.startsWith("")
  println s.endsWith("")
  println (Text "  hi").trimStart
  println (Text "hi  ").trimEnd
  println (Text "  hi  ").trim
  println:
    (Text "   ").trim.toString == ""
  println:
    (Text "\nhi").trimStart.toString == "hi"
  println:
    (Text "hi\n").trimEnd.toString == "hi"
  println:
    (Text "\nhi\n").trim.toString == "hi"
  println:
    (Text "\r\nhi").trimStart.toString == "hi"
  println:
    (Text "hi\r\n").trimEnd.toString == "hi"
  println:
    (Text "\r\nhi\r\n").trim.toString == "hi"

  println (Text "foo bar foo").replace("foo", "qux").toString
  println (Text "aaaa").replace("aa", "b").toString
  println (Text "abc").replace("z", "x").toString
  println (Text "abc").replace("", "X").toString

  val big = (Text "ab") + (Text "cd") + (Text "ef") + (Text "gh")
  val balanced = big.rebalance
  println balanced.toString
  println balanced.slice(2, 3).toString
