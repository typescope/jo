
def main: Unit =
  val xs = py.list(1, 2)
  xs.append(3)
  xs.appendAll(py.list(4, 5))
  xs.insert(1, 9)
  println("list size = " + xs.size)
  println("list contains 4 = " + xs.contains(4))
  println("list pop = " + py.value(xs.pop()).cast[Int])
  xs.set(0, 7)
  println("list first = " + py.value(xs.get(0)).cast[Int])
  xs.clear()
  println("list cleared = " + xs.size)

  val tup = py.tuple("a", "b")
  println("tuple size = " + tup.size)
  println("tuple contains a = " + tup.contains("a"))

  val d = py.dict("x" ~ 1, "y" ~ 2)
  d.set("z", 3)
  println("dict contains y = " + d.contains("y"))
  println("dict get x = " + py.value(d.get("x")).cast[Int])
  println("dict missing = " + py.value(d.get("missing", "fallback")).cast[String])
  val d2 = d.copy()
  d2.pop("y")
  println("dict copy size = " + d2.size)
  d2.clear()
  println("dict cleared = " + d2.size)

  val sorted = py.sorted(py.list(3, 1, 2))
  println("sorted first = " + py.value(sorted.get(0)).cast[Int])
  println("py.len = " + py.len("hello"))
  println("py.str = " + py.str(42))
  println("py.ord = " + py.ord("A"))

  val bytez = py.bytes("hello")
  println("bytes size = " + bytez.size)
  println("bytes contains 101 = " + bytez.contains(101))
  println("bytes decode = " + bytez.decode())

  val enumIter: py.Iterator[py.Tuple] = py.iter(py.enumerate(py.list("a", "b")))
  val firstEnum = py.nextOf[py.Tuple](enumIter).value
  println("enum first index = " + py.value(firstEnum.get(0)).cast[Int])
  println("enum first value = " + py.value(firstEnum.get(1)).cast[String])

  val rangeIter: py.Iterator[Int] = py.iter(py.range(3))
  println("range next = " + py.nextOf[Int](rangeIter).value)

  val base = os.path.abspath("test-py-os-pathlib-tmp")
  os.makedirs(base, exist_ok = true)
  val root = pathlib.Path(base)
  val nested = pathlib.Path(base, "nested")
  nested.mkdir()
  val data = nested.joinpath("data.txt")
  println("path exists = " + root.exists())
  println("path absolute = " + root.absolute().is_dir())
  println("path expanduser = " + pathlib.Path("~").expanduser().is_dir())
  println("path write_text = " + data.write_text("abc"))
  println("path read_text = " + data.read_text())
  println("path read_bytes = " + data.read_bytes().decode())
  println("path write_bytes = " + data.write_bytes(py.bytes("xyz")))
  println("path open read = " + data.open().read())
  println("path is_file = " + data.is_file())
  println("path is_dir = " + nested.is_dir())
  println("path is_symlink = " + data.is_symlink())
  println("path resolve = " + data.resolve().name)
  val st = data.stat()
  println("path stat size = " + st.st_size)
  println("path lstat size = " + data.lstat().st_size)
  data.touch()
  val renamed = data.rename(nested.joinpath("renamed.txt"))
  println("path renamed = " + renamed.name)
  val replaced = renamed.replace(nested.joinpath("final.txt"))
  println("path replaced = " + replaced.name)
  println("path with_name = " + replaced.with_name("other.txt").name)
  println("path with_stem = " + replaced.with_stem("stemmed").name)
  println("path with_suffix = " + replaced.with_suffix(".log").suffix)
  println("path parts size = " + replaced.relative_to(root).parts.size)
  println("path suffixes size = " + replaced.suffixes.size)
  println("path anchor = " + replaced.anchor)
  println("path parent = " + replaced.parent.name)
  println("path relative = " + replaced.relative_to(root).name)
  println("path samefile = " + replaced.samefile(nested.joinpath("final.txt")))

  val globFile = nested.joinpath("glob.log")
  globFile.write_text("g")
  val globIter = nested.glob("*.log")
  println("path glob = " + py.nextOf[pathlib.Path](globIter).value.name)
  val rglobIter = root.rglob("*.log")
  println("path rglob = " + py.nextOf[pathlib.Path](rglobIter).value.name)
  val dirIter = root.iterdir()
  println("path iterdir = " + py.nextOf[pathlib.Path](dirIter).value.name)

  val link = nested.joinpath("link.txt")
  py.importModule("os").symlink(replaced.name, link)
  println("path readlink = " + link.readlink().name)
  link.unlink()
  globFile.unlink()
  replaced.unlink()
  nested.rmdir()

  println("path cwd = " + pathlib.Path.cwd().is_dir())
  println("path home = " + pathlib.Path.home().is_dir())

  root.rmdir()
