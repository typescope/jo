import jo.runtime.python.*

def main: Unit =
  val xs = py.list(1, 2)
  xs.append(3)
  xs.appendAll(py.list(4, 5))
  xs.insert(1, 9)
  println("list size = " + xs.size.toString)
  println("list contains 4 = " + xs.contains(4).toString)
  println("list pop = " + ffi.cast[Int](xs.pop()).toString)
  xs.set(0, 7)
  println("list first = " + ffi.cast[Int](xs.get(0)).toString)
  xs.clear()
  println("list cleared = " + xs.size.toString)

  val tup = py.tuple("a", "b")
  println("tuple size = " + tup.size.toString)
  println("tuple contains a = " + tup.contains("a").toString)

  val d = py.dict("x" ~ 1, "y" ~ 2)
  d.set("z", 3)
  println("dict contains y = " + d.contains("y").toString)
  println("dict get x = " + ffi.cast[Int](d.get("x")).toString)
  println("dict missing = " + ffi.cast[String](d.get("missing", "fallback")))
  val d2 = d.copy()
  d2.pop("y")
  println("dict copy size = " + d2.size.toString)
  d2.clear()
  println("dict cleared = " + d2.size.toString)

  val sorted = py.sorted(py.list(3, 1, 2))
  println("sorted first = " + ffi.cast[Int](sorted.get(0)).toString)
  println("py.len = " + py.len("hello").toString)
  println("py.str = " + py.str(42))
  println("py.ord = " + py.ord("A").toString)

  val bytez = py.bytes("hello")
  println("bytes size = " + bytez.size.toString)
  println("bytes contains 101 = " + bytez.contains(101).toString)
  println("bytes decode = " + bytez.decode())

  val enumIter: py.Iterator[py.Tuple] = py.iter(py.enumerate(py.list("a", "b")))
  val firstEnum = enumIter.next()
  println("enum first index = " + ffi.cast[Int](firstEnum.get(0)).toString)
  println("enum first value = " + ffi.cast[String](firstEnum.get(1)))

  val rangeIter: py.Iterator[Int] = py.iter(py.range(3))
  println("range next = " + rangeIter.next().toString)

  val base = tempfile.mkdtemp()
  val root = pathlib.Path(base)
  val nested = pathlib.Path(base, "nested")
  nested.mkdir()
  val data = nested.joinpath("data.txt")
  println("path exists = " + root.exists().toString)
  println("path absolute = " + root.absolute().is_dir().toString)
  println("path expanduser = " + pathlib.Path("~").expanduser().is_dir().toString)
  println("path write_text = " + data.write_text("abc").toString)
  println("path read_text = " + data.read_text())
  println("path read_bytes = " + data.read_bytes().decode())
  println("path write_bytes = " + data.write_bytes(py.bytes("xyz")).toString)
  println("path open read = " + data.open().read())
  println("path is_file = " + data.is_file().toString)
  println("path is_dir = " + nested.is_dir().toString)
  println("path is_symlink = " + data.is_symlink().toString)
  println("path resolve = " + data.resolve().name)
  val st = data.stat()
  println("path stat size = " + st.st_size.toString)
  println("path lstat size = " + data.lstat().st_size.toString)
  data.touch()
  val renamed = data.rename(nested.joinpath("renamed.txt"))
  println("path renamed = " + renamed.name)
  val replaced = renamed.replace(nested.joinpath("final.txt"))
  println("path replaced = " + replaced.name)
  println("path with_name = " + replaced.with_name("other.txt").name)
  println("path with_stem = " + replaced.with_stem("stemmed").name)
  println("path with_suffix = " + replaced.with_suffix(".log").suffix)
  println("path parts size = " + replaced.parts.size.toString)
  println("path suffixes size = " + replaced.suffixes.size.toString)
  println("path anchor = " + replaced.anchor)
  println("path parent = " + replaced.parent.name)
  println("path relative = " + replaced.relative_to(root).name)
  println("path samefile = " + replaced.samefile(nested.joinpath("final.txt")).toString)

  val globFile = nested.joinpath("glob.log")
  globFile.write_text("g")
  val globIter = nested.glob("*.log")
  println("path glob = " + globIter.next().name)
  val rglobIter = root.rglob("*.log")
  println("path rglob = " + rglobIter.next().name)
  val dirIter = root.iterdir()
  println("path iterdir = " + dirIter.next().name)

  val link = nested.joinpath("link.txt")
  ffi.call(ffi.importModule("os"), "symlink", replaced.name, link)
  println("path readlink = " + link.readlink().name)
  link.unlink()
  globFile.unlink()
  replaced.unlink()
  nested.rmdir()

  println("path cwd = " + pathlib.Path.cwd().is_dir().toString)
  println("path home = " + pathlib.Path.home().is_dir().toString)

  shutil.rmtree(base)
