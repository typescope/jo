import jo.runtime.python.*

def main: Unit =
  val prev = os.getcwd()
  val base = os.path.abspath("test-tmp-os")
  os.makedirs(base, exist_ok = true)
  println("os.getcwd before = " + pathlib.Path(prev).is_dir().toString)
  os.chdir(base)
  println("os.getcwd after = " + (os.getcwd() == base).toString)

  os.mkdir("one")
  os.makedirs("many/a/b", exist_ok = true)
  val file = py.open("one/file.txt", "w")
  file.write("hello")
  file.close()

  println("os.listdir size = " + os.listdir("one").size.toString)
  println("os.listdir first = " + os.listdir("one").get(0))
  println("os.getenv default = " + os.getenv("JO_MISSING_ENV", "fallback"))
  os.environ.set("JO_TEST_ENV", "value")
  println("os.environ contains = " + os.environ.contains("JO_TEST_ENV").toString)
  println("os.environ get = " + os.environ.get("JO_TEST_ENV"))
  println("os.environ keys contains = " + os.environ.keys().contains("JO_TEST_ENV").toString)

  println("os.path exists = " + os.path.exists("one/file.txt").toString)
  println("os.path isfile = " + os.path.isfile("one/file.txt").toString)
  println("os.path isdir = " + os.path.isdir("one").toString)
  println("os.path isabs = " + os.path.isabs(base).toString)
  println("os.path islink = " + os.path.islink("one/file.txt").toString)
  println("os.path join = " + os.path.basename(os.path.join(base, "one", "file.txt")))
  println("os.path normpath = " + os.path.normpath("one/../one/file.txt"))
  println("os.path abspath = " + os.path.basename(os.path.dirname(os.path.abspath("one/file.txt"))))
  println("os.path relpath = " + os.path.relpath("one/file.txt", "."))
  println("os.path basename = " + os.path.basename("one/file.txt"))
  println("os.path dirname = " + os.path.basename(os.path.dirname("one/file.txt")))
  val split = os.path.split("one/file.txt")
  println("os.path split = " + split.tail)
  val splitext = os.path.splitext("one/file.txt")
  println("os.path splitext = " + splitext.ext)
  println("os.path expanduser = " + (os.path.expanduser("~").size > 0).toString)
  os.environ.set("JO_PATH_PART", "part")
  println("os.path expandvars = " + os.path.expandvars("$JO_PATH_PART/file"))
  println("os.path commonpath = " + (os.path.basename(os.path.commonpath(py.list(os.path.join(base, "one"), os.path.join(base, "many")))) == os.path.basename(base)).toString)
  println("os.path getsize = " + os.path.getsize("one/file.txt").toString)

  val walkIter = os.walk(".")
  val entry = walkIter.next()
  val oneEntry = os.walk("one").next()
  println("os.walk dirpath = " + entry.dirpath)
  println("os.walk dirnames contains one = " + entry.dirnames.contains("one").toString)
  println("os.walk filenames contains file.txt = " + oneEntry.filenames.contains("file.txt").toString)

  val renamed = "one/renamed.txt"
  os.rename("one/file.txt", renamed)
  println("os.rename exists = " + os.path.exists(renamed).toString)
  os.replace(renamed, "one/final.txt")
  println("os.replace exists = " + os.path.exists("one/final.txt").toString)
  println("os.getpid positive = " + (os.getpid() > 0).toString)
  val load = os.getloadavg()
  println("os.getloadavg three = " + (load.one >= 0.0 && load.five >= 0.0 && load.fifteen >= 0.0).toString)

  os.remove("one/final.txt")
  println("os.remove exists = " + os.path.exists("one/final.txt").toString)
  os.rmdir("one")
  os.rmdir("many/a/b")
  os.rmdir("many/a")
  os.rmdir("many")
  os.chdir(prev)
  os.rmdir(base)
