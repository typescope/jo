namespace os

private def module: py.Value = py.importModule("os")
private def pathModule: py.Value = module.path

interface StatResult
  def st_ino: Int = py.value(this).st_ino.cast[Int]

  def st_dev: Int = py.value(this).st_dev.cast[Int]

  def st_mode: Int = py.value(this).st_mode.cast[Int]

  def st_size: Int = py.value(this).st_size.cast[Int]

  def st_mtime: Float = py.value(this).st_mtime.cast[Float]

  def st_atime: Float = py.value(this).st_atime.cast[Float]

  def st_ctime: Float = py.value(this).st_ctime.cast[Float]
end

interface Env
  def get(k: String, default: String = ""): String

  def set(k: String, value: String): Unit = py.value(this)[k] = value

  def contains(k: String): Bool = py.contains(this, k)

  def keys(): py.List = py.value(this).keys().cast[py.List]
end

interface LoadAvg
  def get(i: Int): Float = py.value(this)[i].cast[Float]

  def one: Float = get(0)

  def five: Float = get(1)

  def fifteen: Float = get(2)
end

//[ Result of `os.path.split`: `(head, tail)`.   //]
interface SplitResult
  def head: String = py.value(this)[0].cast[String]
  def tail: String = py.value(this)[1].cast[String]
end

//[ Result of `os.path.splitext`: `(root, ext)`.   //]
interface SplitextResult
  def root: String = py.value(this)[0].cast[String]
  def ext: String = py.value(this)[1].cast[String]
end

interface WalkEntry
  def dirpath: String = py.value(this)[0].cast[String]

  def dirnames: py.List = py.value(this)[1].cast[py.List]

  def filenames: py.List = py.value(this)[2].cast[py.List]
end

section path
  def exists(path: String): Bool = pathModule.exists(path).cast[Bool]

  def isfile(path: String): Bool = pathModule.isfile(path).cast[Bool]

  def isdir(path: String): Bool = pathModule.isdir(path).cast[Bool]

  def isabs(path: String): Bool = pathModule.isabs(path).cast[Bool]

  def islink(path: String): Bool = pathModule.islink(path).cast[Bool]

  //[ Join one or more path components.
    !
    ! `paths` are `Any` because Python accepts strings and path-like objects.
  //]
  def join(base: String, paths: ..Any): String =
    pathModule.join(base, py.splice(py.list(..paths))).cast[String]

  def normpath(path: String): String = pathModule.normpath(path).cast[String]

  def abspath(path: String): String = pathModule.abspath(path).cast[String]

  def relpath(path: String, start: String): String = pathModule.relpath(path, start).cast[String]

  def basename(path: String): String = pathModule.basename(path).cast[String]

  def dirname(path: String): String = pathModule.dirname(path).cast[String]

  def split(path: String): SplitResult = pathModule.split(path).cast[SplitResult]

  def splitext(path: String): SplitextResult = pathModule.splitext(path).cast[SplitextResult]

  def expanduser(path: String): String = pathModule.expanduser(path).cast[String]

  def expandvars(path: String): String = pathModule.expandvars(path).cast[String]

  def commonpath(paths: py.List): String = pathModule.commonpath(paths).cast[String]

  def getsize(path: String): Int = pathModule.getsize(path).cast[Int]
end

def environ: Env = module.environ.cast[Env]

def getcwd(): String = module.getcwd().cast[String]

def chdir(path: String): Unit = module.chdir(path)

def listdir(path: String = "."): py.List = module.listdir(path).cast[py.List]

def mkdir(path: String, mode: Int = 511): Unit =
  module.mkdir(path, mode)

def makedirs(path: String, mode: Int = 511, exist_ok: Bool = false): Unit =
  module.makedirs(path, mode, py.kwarg("exist_ok", exist_ok))

def remove(path: String): Unit = module.remove(path)

def rmdir(path: String): Unit = module.rmdir(path)

def replace(src: String, dst: String): Unit = module.replace(src, dst)

def unlink(path: String): Unit = module.unlink(path)

def rename(src: String, dst: String): Unit = module.rename(src, dst)

//[ Walk a directory tree.
  !
  ! Returns an iterator of `(dirpath, dirnames, filenames)` entries.
//]
def walk(top: String = ".", topdown: Bool = true, followlinks: Bool = false): py.Iterator[WalkEntry] =
  module.walk(top, py.kwarg("topdown", topdown), py.kwarg("followlinks", followlinks)).cast[py.Iterator[WalkEntry]]

def getpid(): Int = module.getpid().cast[Int]

def getenv(name: String, default: String = ""): String =
  environ.get(name, default)

def putenv(name: String, value: String): Unit = module.putenv(name, value)

def getloadavg(): LoadAvg = module.getloadavg().cast[LoadAvg]
