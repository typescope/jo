@js.interop
interface Thenable
  @js.targetName("then")
  def andThen(x: Int): Int
end

@js.interop
interface Box
  @js.property
  def size: Int
end

@js.interop
interface Entry
  @js.property
  @js.targetName("isDirectory")
  def isDir: Bool
end

def main: Unit =
  val thenable: Thenable = js.obj({"then": ((x: Any) => js.dynamic(x).asInt + 1)}).cast[Thenable]
  val box: Box = js.obj({"size": 7}).cast[Box]
  val entry: Entry = js.obj({"isDirectory": true}).cast[Entry]

  println(thenable.andThen(41))
  println(box.size)
  println(entry.isDir)
