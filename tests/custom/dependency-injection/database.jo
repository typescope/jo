// Database abstraction library
// Defines database interface using deferred functions

namespace Database

class State
  var recordCount: Int

  def State(count: Int) =
    this.recordCount = count
end

param state: State

defer def connect(host: String): String
defer def query(table: String): Int receives state
defer def insert(table: String, value: Int): Unit receives IO.stdout, state
defer def disconnect(): Unit receives IO.stdout
