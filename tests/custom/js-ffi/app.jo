def main =
  testGlobal()
  testRequire()
  testUpdateDynamic()
  testBracketAccess()
  testCast()
  testNullHandling()
  testTypeChecks()
  testTry()
  testSpread()
  testConstruct()
  testArray()
  testObj()
  testDynamic()
  testCall()
  testToString()

//[ 1. js.global + selectDynamic / callDynamic //]
def testGlobal =
  println "--- global ---"
  val math: js.Dynamic = js.global.Math
  val pi: Float = math.PI.asFloat
  println("pi = " + pi)

  val floor: Int = math.floor(2.7).asInt
  println("floor(2.7) = " + floor)

  val sqrt: Float = math.sqrt(9.0).asFloat
  println("sqrt(9) = " + sqrt)

//[ 2. js.require + selectDynamic //]
def testRequire =
  println "--- require ---"
  val path: js.Dynamic = js.require("path")
  val joined: String = path.join("/tmp", "test").asString
  println("join = " + joined)
  val sep: String = path.sep.asString
  println("sep = " + sep)

//[ 3. updateDynamic: property write on js.Dynamic //]
def testUpdateDynamic =
  println "--- updateDynamic ---"
  val obj: js.Dynamic = js.init(js.global.Object)
  obj.name = "Jo"
  val name: String = obj.name.asString
  println("name = " + name)

  obj.count = 42
  val count: Int = obj.count.asInt
  println("count = " + count)

//[ 4. getDynamic / setDynamic via bracket syntax //]
def testBracketAccess =
  println "--- bracket access ---"
  val arr: js.Dynamic = js.init(js.global.Array, 3)
  arr[0] = "hello"
  arr[1] = "world"
  val first: String = arr[0].asString
  val second: String = arr[1].asString
  println("arr[0] = " + first)
  println("arr[1] = " + second)

  val json: js.Dynamic = js.global.JSON
  val parsed: js.Dynamic = json.parse("{\"x\": 99}")
  val x: Int = parsed["x"].asInt
  println("parsed[x] = " + x)

//[ 5. cast[T] / asX conversions //]
def testCast =
  println "--- cast ---"
  val math: js.Dynamic = js.global.Math
  val pi: Float = math.PI.asFloat
  println("pi asFloat = " + pi)

  val floor: Int = math.floor(3.7).asInt
  println("floor(3.7) asInt = " + floor)

  val str: String = js.global.String.call(42).asString
  println("String(42) = " + str)

  val flag: Bool = js.global.Boolean.call(1).asBool
  println("Boolean(1) = " + flag)

//[ 6. undefined / null / nullish handling //]
def testNullHandling =
  println "--- null handling ---"
  val u: js.Dynamic = js.dynamic(js.undefined)
  println("isUndefined = " + u.isUndefined)

  val n: js.Dynamic = js.dynamic(js.null)
  println("isNull = " + n.isNull)
  println("isNullish undefined = " + u.isNullish)
  println("isNullish null = " + n.isNullish)

  val pi: js.Dynamic = js.global.Math.PI
  println("isUndefined pi = " + pi.isUndefined)

  println("top isUndefined = " + js.isUndefined(js.undefined))
  println("top isNull = " + js.isNull(js.null))
  println("top isNullish = " + js.isNullish(js.undefined))

//[ 7. typeof / isInstance / === //]
def testTypeChecks =
  println "--- type checks ---"
  val fn: js.Dynamic = js.global.Math.floor
  println("typeof function = " + (js.typeof(fn) == "function"))

  val n: js.Dynamic = js.dynamic(42)
  println("typeof number = " + (js.typeof(n) == "number"))

  val arr: js.Array = js.array(1, 2, 3)
  println("isInstance Array (top) = " + js.isInstance(arr, js.global.Array))
  println("isInstance Array (method) = " + js.dynamic(arr).isInstance(js.global.Array))

  val math: js.Dynamic = js.global.Math
  println("=== identity = " + (math === js.global.Math))
  println("=== different = " + (math === js.global.JSON))

//[ 8. js.try: success and failure //]
def testTry =
  println "--- try ---"
  match js.try(js.global.Math.sqrt(4.0).asFloat)
    case Ok(v) => println("try sqrt ok: " + v)
    case Err(_) => println "try sqrt err"

  match js.try(js.global.JSON.parse("{invalid}"))
    case Ok(_) => println "try parse ok"
    case Err(_) => println "try parse err"

//[ 9. js.spread: spread array as ...args //]
def testSpread =
  println "--- spread ---"
  val args: js.Array = js.array(1, 7, 3)
  val maxResult: Float = js.global.Math.max(js.spread(args)).asFloat
  println("max(...[1,7,3]) = " + maxResult)

//[ 10. js.init: new ctor(args) //]
def testConstruct =
  println "--- construct ---"
  val epoch: js.Dynamic = js.init(js.global.Date, 0)
  val time: Float = epoch.getTime().asFloat
  println("new Date(0).getTime() = " + time)

  val re: js.Dynamic = js.init(js.global.RegExp, "\\d+")
  val match1: Bool = re.test("abc123").asBool
  val match2: Bool = re.test("abc").asBool
  println("re.test(abc123) = " + match1)
  println("re.test(abc) = " + match2)

//[ 11. js.Array typed interface //]
def testArray =
  println "--- array ---"
  val arr: js.Array = js.array(3, 1, 4, 1, 5)
  println("size = " + arr.size)
  println("arr[0] = " + arr[0].asInt)

  arr.push(9)
  println("after push size = " + arr.size)

  val last: Int = arr.pop().asInt
  println("pop = " + last)

  println("includes 4 = " + arr.includes(4))
  println("indexOf 1 = " + arr.indexOf(1))

  val sliced: js.Array = arr.slice(1, 3)
  println("slice(1,3) size = " + sliced.size)

  val tail: js.Array = arr.slice(2)
  println("slice(2) size = " + tail.size)

  println("join = " + arr.join("-"))

  var forSum = 0
  for v in arr do forSum = forSum + v.asInt end
  println("for sum = " + forSum)

//[ 12. js.obj and js.hasOwn //]
def testObj =
  println "--- obj ---"
  val obj: js.Dynamic = js.obj("x" ~ 1, "y" ~ "hello")
  println("hasOwn x = " + js.hasOwn(obj, "x"))
  println("hasOwn z = " + js.hasOwn(obj, "z"))
  println("obj.x = " + obj.x.asInt)
  println("obj.y = " + obj.y.asString)
  println("obj[x] = " + obj["x"].asInt)
  println("obj[y] = " + obj["y"].asString)

//[ 13. js.dynamic: wrap any value back to js.Dynamic //]
def testDynamic =
  println "--- dynamic ---"
  val n: Int = 42
  val v: js.Dynamic = js.dynamic(n)
  println("value type = " + (js.typeof(v) == "number"))

  val s: String = "hello"
  val sv: js.Dynamic = js.dynamic(s)
  println("value string = " + sv.asString)

//[ 14. js.Dynamic.call: invoke value as function //]
def testCall =
  println "--- call ---"
  // Call Math.max as a function value
  val maxFn: js.Dynamic = js.global.Math.max
  val result: Float = maxFn.call(3, 7, 1).asFloat
  println("call max(3,7,1) = " + result)

  // Call Array.isArray as a function
  val isArray: js.Dynamic = js.global.Array.isArray
  val yes: Bool = isArray.call(js.array(1, 2)).asBool
  val no: Bool  = isArray.call(42).asBool
  println("call isArray(arr) = " + yes)
  println("call isArray(42) = " + no)

//[ 15. js.Dynamic.toString: convert to string via JS toString() //]
def testToString =
  println "--- toString ---"
  // toString on a number
  val n: js.Dynamic = js.dynamic(42)
  println("toString 42 = " + n.toString)

  // toString on array (gives comma-joined)
  val arr: js.Array = js.array(1, 2, 3)
  println("toString [1,2,3] = " + js.dynamic(arr).toString)
