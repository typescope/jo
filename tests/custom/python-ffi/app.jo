import jo.runtime.python.*

def main =
  // Test importModule + selectDynamic
  val math: py.Value = py.importModule("math")
  val pi: Float = math.pi.cast[Float]
  println("pi = " + pi)

  // Test callDynamic with single arg
  val floorResult: Float = math.floor(2.7).cast[Float]
  println("floor(2.7) = " + floorResult)

  // Test splice: max(*[1, 7, 3]) -> 7
  val builtins: py.Value = py.importModule("builtins")
  val maxResult: Int = builtins.max(py.splice(py.list(1, 7, 3))).cast[Int]
  println("splice max = " + maxResult)

  // Test py.isNone: re.match returns None on no match
  val re: py.Value = py.importModule("re")
  val noMatch: Any = re.callDynamic("match", "abc", "xyz")
  println("isNone(noMatch) = " + py.isNone(noMatch))

  // Test py.isNone: re.match returns a match object on success
  val yesMatch: Any = re.callDynamic("match", "abc", "abcdef")
  println("isNone(yesMatch) = " + py.isNone(yesMatch))

  // Test py.try: success
  val sqrtResult: Result[Float, py.Error] = py.try(math.sqrt(4.0).cast[Float])
  match sqrtResult
    case Ok(v) => println("try sqrt(4) = ok: " + v)
    case Err(e) => println("try sqrt(4) = err: " + e.message)

  // Test py.try: failure (ValueError from math domain error)
  match py.try(math.log(-1.0))
    case Ok(_) => println "try log(-1) = ok"
    case Err(e) => println "try log(-1) = err"

  // Test bracket get/set on a Python dict
  val d: py.Value = builtins.dict()
  d["x"] = 42
  val v: Int = d["x"].cast[Int]
  println("dict[x] = " + v)

  // Test updateDynamic / selectDynamic
  val os: py.Value = py.importModule("os")
  os.custom_attr = "hello"
  val attr: String = os.custom_attr.cast[String]
  println("setField/field = " + attr)

  // Test kwarg / kwargs
  val formatter: py.Value = py.importModule("string")
  val kwargResult: String = formatter.capwords("jo-ffi", py.kwarg("sep", "-")).cast[String]
  println("kwarg capwords = " + kwargResult)

  val kwargs = py.dict()
  kwargs.set("sep", "-")
  val kwargsResult: String = formatter.capwords("jo-ffi", py.kwargs(kwargs)).cast[String]
  println("kwargs capwords = " + kwargsResult)

  // Test isInstance
  val intCls: Any = builtins.int
  println("isInstance(42, int) = " + py.isInstance(42, intCls))

  // Test isSame
  val alias = os
  println("isSame(os, alias) = " + py.isSame(os, alias))
  println("isSame(os, math) = " + py.isSame(os, math))
