import jo.runtime.python.*

def main =
  // Test importModule + Value.field
  val math = ffi.importModule("math")
  val pi: Float = ffi.cast(ffi.field(math, "pi"))
  println("pi = " + pi.toString)

  // Test Value.call with single arg
  val floorResult: Float = ffi.cast(ffi.call(math, "floor", 2.7))
  println("floor(2.7) = " + floorResult.toString)

  // Test Value.isNone: re.match returns None on no match
  val re = ffi.importModule("re")
  val noMatch = ffi.call(re, "match", "abc", "xyz")
  println("isNone(noMatch) = " + ffi.isNone(noMatch).toString)

  // Test Value.isNone: re.match returns a match object on success
  val yesMatch = ffi.call(re, "match", "abc", "abcdef")
  println("isNone(yesMatch) = " + ffi.isNone(yesMatch).toString)

  // Test try: success
  val sqrtResult = ffi.try(ffi.cast[Float](ffi.call(math, "sqrt", 4.0)))
  match sqrtResult
    case Ok(v) => println("try sqrt(4) = ok: " + v.toString)
    case Err(e) => println("try sqrt(4) = err: " + e.message)

  // Test try: failure (ValueError from math domain error)
  match ffi.try(ffi.call(math, "log", -1.0))
    case Ok(_) => println "try log(-1) = ok"
    case Err(e) => println "try log(-1) = err"

  // Test Value.get / Value.set on a Python dict
  val builtins = ffi.importModule("builtins")
  val d = ffi.call(builtins, "dict")
  ffi.set(d, "x", 42)
  val v: Int = ffi.cast(ffi.get(d, "x"))
  println("dict[x] = " + v.toString)

  // Test setField / field
  val os = ffi.importModule("os")
  ffi.setField(os, "custom_attr", "hello")
  val attr: String = ffi.cast(ffi.field(os, "custom_attr"))
  println("setField/field = " + attr)

  // Test isInstance
  val builtins2 = ffi.importModule("builtins")
  val intCls = ffi.field(builtins2, "int")
  println("isInstance(42, int) = " + ffi.isInstance(42, intCls).toString)
