def main =
  testBasic()
  testLarge()
  testBoundary()
  testIterator()
  testMap()
  testFilter()
  testFold()
  testZip()
  testReverse()
  testFind()
  testConcat()
  testSlice()
  testPartition()
  testDistinct()
  testMinMax()
  testToString()
  testToList()

def testBasic =
  println "--- basic ---"
  var v: Vector[Int] = Vector.empty[Int]
  v = v + 10
  v = v + 20
  v = v + 30
  println v.size      // 3
  println (v.get 0)   // 10
  println (v.get 1)   // 20
  println (v.get 2)   // 30
  println v.isEmpty   // false
  println (Vector.empty[Int].isEmpty)  // true

def testLarge =
  println "--- large ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 2000 do
    v = v + i
    i = i + 1

  println v.size       // 2000
  println (v.get 0)    // 0
  println (v.get 999)  // 999
  println (v.get 1999) // 1999

  var sum = 0
  i = 0
  while i < 2000 do
    sum = sum + v.get(i)
    i = i + 1
  println sum          // 1999000

def testBoundary =
  println "--- boundary ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 35 do
    v = v + i
    i = i + 1
  println v.size      // 35
  println (v.get 31)  // 31
  println (v.get 32)  // 32
  println (v.get 34)  // 34

def testIterator =
  println "--- iterator ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 5 do
    v = v + (i * i)
    i = i + 1
  // 0, 1, 4, 9, 16
  var sum = 0
  val iter = v.iterator
  while iter.hasNext do
    sum = sum + iter.next
  println sum  // 30

def testMap =
  println "--- map ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 1
  while i <= 5 do
    v = v + i
    i = i + 1
  val doubled = v.map(x => x * 2)
  println doubled.size    // 5
  println (doubled.get 0) // 2
  println (doubled.get 4) // 10

def testFilter =
  println "--- filter ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 10 do
    v = v + i
    i = i + 1
  val evens = v.select(x => x % 2 == 0)
  println evens.size    // 5
  println (evens.get 0) // 0
  println (evens.get 4) // 8
  val odds = v.exclude(x => x % 2 == 0)
  println odds.size     // 5
  println (odds.get 0)  // 1

def testFold =
  println "--- fold ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 1
  while i <= 10 do
    v = v + i
    i = i + 1
  val sum = v.fold(0, (acc, x) => acc + x)
  println sum  // 55

def testZip =
  println "--- zip ---"
  var a: Vector[Int] = Vector.empty[Int]
  var b: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 4 do
    a = a + i
    b = b + (i * 10)
    i = i + 1
  val zipped = a.zip(b)
  println zipped.size  // 4
  val x ~ y = zipped.get(2)
  println x            // 2
  println y            // 20

  val wi = a.zipWithIndex
  val _ ~ idx = wi.get(3)
  println idx          // 3

def testReverse =
  println "--- reverse ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 1
  while i <= 5 do
    v = v + i
    i = i + 1
  val r = v.reverse
  println (r.get 0)  // 5
  println (r.get 4)  // 1

def testFind =
  println "--- find ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 10 do
    v = v + i
    i = i + 1
  val found = v.find(x => x > 5)
  match found
    case Some(n) => println n  // 6
    case None => println "none"
  println (v.exists(x => x > 8))   // true
  println (v.exists(x => x > 9))   // false
  println (v.forall(x => x >= 0))  // true
  println (v.count(x => x % 2 == 0))  // 5

def testConcat =
  println "--- concat ---"
  var a: Vector[Int] = Vector.empty[Int]
  var b: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 3 do
    a = a + i
    i = i + 1
  while i < 6 do
    b = b + i
    i = i + 1
  val c = a ++ b
  println c.size    // 6
  println (c.get 0) // 0
  println (c.get 5) // 5

def testSlice =
  println "--- slice ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 10 do
    v = v + i
    i = i + 1
  val s = v.slice(2, 4)
  println s.size    // 4
  println (s.get 0) // 2
  println (s.get 3) // 5
  println (v.take(3).size)  // 3
  println (v.drop(7).size)  // 3

def testPartition =
  println "--- partition ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 6 do
    v = v + i
    i = i + 1
  val evens ~ odds = v.partition(x => x % 2 == 0)
  println evens.size     // 3
  println odds.size      // 3
  println (evens.get 0)  // 0
  println (odds.get 0)   // 1

def testDistinct =
  println "--- distinct ---"
  var v: Vector[Int] = Vector.empty[Int]
  v = v + 1
  v = v + 2
  v = v + 1
  v = v + 3
  v = v + 2
  val d = v.distinct
  println d.size    // 3
  println (d.get 0) // 1
  println (d.get 1) // 2
  println (d.get 2) // 3

def testMinMax =
  println "--- minmax ---"
  var v: Vector[Int] = Vector.empty[Int]
  v = v + 5
  v = v + 2
  v = v + 8
  v = v + 1
  match v.minOpt
    case Some(n) => println n  // 1
    case None => println "none"
  match v.maxOpt
    case Some(n) => println n  // 8
    case None => println "none"
  match (Vector.empty[Int].minOpt)
    case Some(_) => println "some"
    case None => println "none"  // none

def testToString =
  println "--- tostring ---"
  var v: Vector[Int] = Vector.empty[Int]
  v = v + 1
  v = v + 2
  v = v + 3
  println v  // [1, 2, 3]

def testToList =
  println "--- tolist ---"
  var v: Vector[Int] = Vector.empty[Int]
  var i = 0
  while i < 5 do
    v = v + (i + 1)
    i = i + 1
  val l = v.toList
  println l.size    // 5
  println (l.get 0) // 1
  println (l.get 4) // 5
