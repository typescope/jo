def main =
  testToList

def testToList =
  println "--- range.toList ---"
  println (1 to 5).toList
  println (1 until 5).toList
  println (2 to 10 step 2).toList
  println (1 until 10 step 3).toList
  println (5 to 1 step -1).toList
  println (5 until 1 step -2).toList
  println (1 to 5 step -1).toList
  println (5 to 1 step 1).toList
  println (5 until 5).toList
