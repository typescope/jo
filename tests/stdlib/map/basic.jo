def main =
  testIsEmpty()
  testKeySet()
  testMapValues()
  testFind()
  testMerge()

def testIsEmpty =
  println "--- map.isEmpty ---"
  val empty = Map.empty[Int, String]
  val m = Map(1 ~ "one", 2 ~ "two")

  println empty.isEmpty
  println m.isEmpty

def testKeySet =
  println "--- map.keySet ---"
  val empty = Map.empty[Int, String]
  val m = Map(3 ~ "three", 1 ~ "one", 2 ~ "two")

  println empty.keySet
  println m.keySet

def testMapValues =
  println "--- map.mapValues ---"
  val empty = Map.empty[Int, String]
  val m = Map(1 ~ "a", 2 ~ "bb", 3 ~ "ccc")

  println empty.mapValues(s => s.size)
  println m.mapValues(s => s.size)

def testFind =
  println "--- map.find ---"
  val empty = Map.empty[Int, String]
  val m = Map(1 ~ "one", 2 ~ "two", 3 ~ "three")

  println empty.find((k, v) => k > 0)
  println m.find((k, v) => v.size == 3)
  println m.find((k, v) => k == 4)

def testMerge =
  println "--- map.merge ---"
  val left = Map(1 ~ 10, 2 ~ 20, 3 ~ 30)
  val right = Map(2 ~ 7, 3 ~ 9, 4 ~ 11)
  val empty = Map.empty[Int, Int]

  println left.merge(right, (k, a, b) => a + b)
  println left.merge(right, (k, a, b) => a - b)
  println left.merge(empty, (k, a, b) => a + b)
  println empty.merge(right, (k, a, b) => a + b)
