def main =
  testIsEmpty()
  testGetOrDefault()
  testGetOrCompute()
  testMap()
  testToString()

def testIsEmpty =
  println "--- option.isEmpty ---"
  val noneInt: Option[Int] = None
  val someInt: Option[Int] = Some(42)

  println noneInt.isEmpty
  println someInt.isEmpty

def testGetOrDefault =
  println "--- option.getOrValue ---"
  val noneInt: Option[Int] = None
  val someInt: Option[Int] = Some(42)
  val noneString: Option[String] = None
  val someString: Option[String] = Some("jo")

  println (noneInt.getOrValue(7))
  println (someInt.getOrValue(7))
  println (noneString.getOrValue("fallback"))
  println (someString.getOrValue("fallback"))

def testGetOrCompute =
  println "--- option.getOrCompute ---"
  val noneInt: Option[Int] = None
  val someInt: Option[Int] = Some(42)

  println (noneInt.getOrCompute(() => 7))
  println (someInt.getOrCompute(() => 7))

def testMap =
  println "--- option.map ---"
  val noneInt: Option[Int] = None
  val someInt: Option[Int] = Some(42)

  println (noneInt.map(n => n + 1)).toString
  println (someInt.map(n => n + 1)).toString
  println (someInt.map(n => n.toString)).toString

def testToString =
  println "--- option.toString ---"
  val noneInt: Option[Int] = None
  val someInt: Option[Int] = Some(42)
  val noneString: Option[String] = None
  val someString: Option[String] = Some("jo")

  println noneInt.toString
  println someInt.toString
  println noneString.toString
  println someString.toString
