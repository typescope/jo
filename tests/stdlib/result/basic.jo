def main =
  testIsOk()
  testGetOrElse()
  testMap()
  testToString()

def testIsOk =
  println "--- result.isOk ---"
  val ok: Result[Int, String] = Ok(42)
  val err: Result[Int, String] = Err("oops")

  println ok.isOk
  println ok.isErr
  println err.isOk
  println err.isErr

def testGetOrElse =
  println "--- result.getOrElse ---"
  val ok: Result[Int, String] = Ok(42)
  val err: Result[Int, String] = Err("oops")

  println (ok.getOrElse(0))
  println (err.getOrElse(0))
  println (ok.getOrElse(() => 1))
  println (err.getOrElse(() => 1))

def testMap =
  println "--- result.map ---"
  val ok: Result[Int, String] = Ok(42)
  val err: Result[Int, String] = Err("oops")

  println ok.map(n => n + 1)
  println err.map(n => n + 1)
  println ok.map(n => n.toString)

def testToString =
  println "--- result.toString ---"
  val ok: Result[Int, String] = Ok(42)
  val err: Result[Int, String] = Err("oops")

  println ok.toString
  println err.toString
