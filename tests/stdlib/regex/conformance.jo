import jo.regex.*

def main =
  testBasics()
  testQuantifiers()
  testBounded()
  testLazyQuantifiers()
  testAlternation()
  testClasses()
  testEscapes()
  testAnchors()
  testFlags()
  testWordBoundaries()
  testUnicode()
  testRealistic()
  testCaptures()
  testCaptureRegression()
  testFind()

def printMatch(m: Option[Match]) =
  match m
    case Some(found) =>
      println("Some(" + found + ")")
    case None =>
      println "None"

def testBasics =
  println "--- regex conformance / basics ---"
  println `abc`.matchesExact("abc")
  println `abc`.matchesExact("abd")
  println `a.c`.matchesExact("aXc")
  println `a.c`.matchesExact("a\nc")

def testQuantifiers =
  println "--- regex conformance / quantifiers ---"
  println `a*`.matchesExact("")
  println `a*b`.matchesExact("aaab")
  println `a*b`.matchesExact("aaaaac")
  println `a+`.matchesExact("aaaa")
  println `a+`.matchesExact("")
  println `ab?c`.matchesExact("ac")
  println `ab?c`.matchesExact("abc")
  println `ab?c`.matchesExact("abbc")

def testBounded =
  println "--- regex conformance / bounded repetition ---"
  println `a{3}`.matchesExact("aaa")
  println `a{3}`.matchesExact("aa")
  println `a{2,4}`.matchesExact("aa")
  println `a{2,4}`.matchesExact("aaaa")
  println `a{2,4}`.matchesExact("aaaaa")
  println `a{3,}`.matchesExact("aaaaa")

def testLazyQuantifiers =
  println "--- regex conformance / lazy quantifiers ---"
  printMatch(`a+?`.matchFirst("baaa!"))
  printMatch(`a*?`.matchFirst("aaa"))
  println `ab??c`.matchesExact("abc")
  println `ab??c`.matchesExact("ac")
  printMatch(`a{1,3}?`.matchFirst("aaaa"))
  printMatch(`a{2,}?`.matchFirst("aaaa"))

def testAlternation =
  println "--- regex conformance / alternation and grouping ---"
  println `(ab|cd)`.matchesExact("ab")
  println `(ab|cd)`.matchesExact("cd")
  println `(ab|cd)`.matchesExact("ad")
  println `^(?:ab)+$`.matchesExact("abab")
  println `^a(?:b|c)d$`.matchesExact("acd")
  println `^a(?:b|c)d$`.matchesExact("abd")
  println `^a(?:b|c)d$`.matchesExact("aed")

def testClasses =
  println "--- regex conformance / character classes ---"
  println `[abc]`.matchesExact("a")
  println `[abc]`.matchesExact("d")
  println `[a-z]`.matchesExact("k")
  println `[a-z]`.matchesExact("K")
  println `[^a-z]`.matchesExact("K")
  println `[-a]`.matchesExact("-")
  println `[a-]`.matchesExact("-")

def testEscapes =
  println "--- regex conformance / escapes ---"
  println `\d`.matchesExact("7")
  println `\d`.matchesExact("x")
  println `\s`.matchesExact(" ")
  println `\s`.matchesExact("\t")
  println `\w`.matchesExact("A")
  println `\w`.matchesExact("_")
  println `\W`.matchesExact("-")
  println `\{`.matchesExact("{")
  println `\+`.matchesExact("+")

def testAnchors =
  println "--- regex conformance / anchors ---"
  println `^abc$`.matchesExact("abc")
  println `^abc$`.matchesExact("zabc")
  println `^abc$`.matchesExact("abcz")
  println `^a.*c$`.matchesExact("abc")
  println `^a.*c$`.matchesExact("a\nc")

def testFlags =
  println "--- regex conformance / flags ---"
  println `(?s)^a.c$`.matchesExact("a\nc")
  printMatch(`(?m)^foo$`.matchFirst("xx\nfoo\nyy"))
  println `(?i)abc`.matchesExact("ABC")

def testUnicode =
  println "--- regex conformance / unicode ---"
  println `😀`.matchesExact("😀")
  println `😀`.matchesExact("x")
  println `😀+`.matchesExact("😀😀")
  printMatch(`😀+`.matchFirst("a😀😀b"))

  if `(😀+)(b)`.matchFirst("a😀😀b") is Some(m) then
    println m[1]
    println m[2]

  val faces = `😀`.matchAll("😀x😀")
  println faces.size
  println faces[0].from
  println faces[0].length
  println faces[1].from
  println faces[1].length

  printMatch(`\w+`.matchFirst("😀abc"))

  println "--- regex conformance / unicode input with ascii regex ---"
  printMatch(`abc`.matchFirst("😀abc😀"))

  if `(a)(bc)`.matchFirst("😀abc😀") is Some(m) then
    println m[0]
    println m[1]
    println m[2]
    println m.from
    println m.length

  if `b+`.matchFirst("😀abbb😀") is Some(m2) then
    println m2
    println m2.from
    println m2.length

def testWordBoundaries =
  println "--- regex conformance / word boundaries ---"
  println `^\bfoo\b$`.matchesExact("foo")
  println `^\bfoo\b!$`.matchesExact("foo!")
  println `^!\bfoo$`.matchesExact("!foo")
  println `^\Bfoo\B$`.matchesExact("foo")
  println `^a\Bfoo\Bb$`.matchesExact("afoob")
  println `^a\Bfoo\Bb$`.matchesExact("afoo b")
  val words = `\b\w+\b`.matchAll("one two three")
  println words.size
  println words[0].text
  println words[1].text
  println words[2].text

def testRealistic =
  println "--- regex conformance / realistic patterns ---"
  println `^\d{4}-\d{2}-\d{2}$`.matchesExact("2026-02-18")
  println `^\d{4}-\d{2}-\d{2}$`.matchesExact("2026-2-18")
  println `^\w+$`.matchesExact("INFO_42")
  println `^\w+$`.matchesExact("INFO-42")
  println `^\w+=\w+$`.matchesExact("k=v")
  println `^\w+=\w+$`.matchesExact("k =v")

def testCaptures =
  println "--- regex conformance / captures ---"
  if `(\d{4})-(\d{2})-(\d{2})`.matchFirst("xx2026-02-19yy") is Some(m) then
    println m[0]
    println m[1]
    println m[2]
    println m[3]

  if `(a*)`.matchFirst("") is Some(m1) then
    println m1.isGroupMatched(1)
    println m1[1]

  if `(a)?`.matchFirst("") is Some(m2) then
    println m2.isGroupMatched(1)

def testCaptureRegression =
  println "--- regex conformance / capture regression ---"

  if `^(a)*$`.matchFirst("aaa") is Some(m1) then
    println m1[1]

  if `^((a)*)$`.matchFirst("aa") is Some(m2) then
    println m2[1]
    println m2[2]

  if `^(a)(b)?$`.matchFirst("ab") is Some(m3) then
    println m3[1]
    println m3.isGroupMatched(2)
    println m3[2]

  if `^(a)(b)?$`.matchFirst("a") is Some(m4) then
    println m4[1]
    println m4.isGroupMatched(2)

  if `^((a)?b)*$`.matchFirst("abab") is Some(m5) then
    println m5[1]
    println m5[2]

  if `^(a*)(b)$`.matchFirst("aaab") is Some(m6) then
    println m6[1]
    println m6[2]

def testFind =
  println "--- regex conformance / find ---"
  printMatch(`\w+`.matchFirst("..abc!!"))
  printMatch(`\w+`.matchFirst("..ab 12!!x"))
  if `\w+`.matchFirst("..abc!!") is Some(m1) then
    println m1

  printMatch(`a+`.matchFirst("baaa!"))
  printMatch(`a+?`.matchFirst("baaa!"))
  // println `\b!`.matchFirst("a!")
  printMatch(`^abc$`.matchFirst("zabcx"))
  val parts = `\w+`.matchAll("..ab 12!!x")
  println parts.size
  println parts[0]
  println parts[1]
  println parts[2]

  val zero = `a*`.matchAll("bbb")
  println zero.size
  println zero[0].from
  println zero[0].length
  println zero[1].from
  println zero[1].length
  println zero[2].from
  println zero[2].length
  println zero[3].from
  println zero[3].length
