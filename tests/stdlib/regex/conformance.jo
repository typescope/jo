import jo.regex.*

def main =
  testBasics()
  testQuantifiers()
  testBounded()
  testAlternation()
  testClasses()
  testEscapes()
  testAnchors()
  testFlags()
  testWordBoundaries()
  testRealistic()
  testCaptures()
  testCaptureRegression()
  testFind()

def testBasics =
  println "--- regex conformance / basics ---"
  println #r"abc".matches("abc")
  println #r"abc".matches("abd")
  println #r"a.c".matches("aXc")
  println #r"a.c".matches("a\nc")

def testQuantifiers =
  println "--- regex conformance / quantifiers ---"
  println #r"a*".matches("")
  println #r"a*b".matches("aaab")
  println #r"a*b".matches("aaaaac")
  println #r"a+".matches("aaaa")
  println #r"a+".matches("")
  println #r"ab?c".matches("ac")
  println #r"ab?c".matches("abc")
  println #r"ab?c".matches("abbc")

def testBounded =
  println "--- regex conformance / bounded repetition ---"
  println #r"a{3}".matches("aaa")
  println #r"a{3}".matches("aa")
  println #r"a{2,4}".matches("aa")
  println #r"a{2,4}".matches("aaaa")
  println #r"a{2,4}".matches("aaaaa")
  println #r"a{3,}".matches("aaaaa")

def testAlternation =
  println "--- regex conformance / alternation and grouping ---"
  println #r"(ab|cd)".matches("ab")
  println #r"(ab|cd)".matches("cd")
  println #r"(ab|cd)".matches("ad")
  println #r"^(?:ab)+$".matches("abab")
  println #r"^a(?:b|c)d$".matches("acd")
  println #r"^a(?:b|c)d$".matches("abd")
  println #r"^a(?:b|c)d$".matches("aed")

def testClasses =
  println "--- regex conformance / character classes ---"
  println #r"[abc]".matches("a")
  println #r"[abc]".matches("d")
  println #r"[a-z]".matches("k")
  println #r"[a-z]".matches("K")
  println #r"[^a-z]".matches("K")
  println #r"[-a]".matches("-")
  println #r"[a-]".matches("-")

def testEscapes =
  println "--- regex conformance / escapes ---"
  println #r"\d".matches("7")
  println #r"\d".matches("x")
  println #r"\s".matches(" ")
  println #r"\s".matches("\t")
  println #r"\w".matches("A")
  println #r"\w".matches("_")
  println #r"\W".matches("-")
  println #r"\{".matches("{")
  println #r"\+".matches("+")

def testAnchors =
  println "--- regex conformance / anchors ---"
  println #r"^abc$".matches("abc")
  println #r"^abc$".matches("zabc")
  println #r"^abc$".matches("abcz")
  println #r"^a.*c$".matches("abc")
  println #r"^a.*c$".matches("a\nc")

def testFlags =
  println "--- regex conformance / flags ---"
  println #r[s]"^a.c$".matches("a\nc")
  println #r[m]"^foo$".findFirst("xx\nfoo\nyy")
  println #r[i]"abc".matches("ABC")

def testWordBoundaries =
  println "--- regex conformance / word boundaries ---"
  println #r"^\bfoo\b$".matches("foo")
  println #r"^\bfoo\b!$".matches("foo!")
  println #r"^!\bfoo$".matches("!foo")
  println #r"^\Bfoo\B$".matches("foo")
  println #r"^a\Bfoo\Bb$".matches("afoob")
  println #r"^a\Bfoo\Bb$".matches("afoo b")

def testRealistic =
  println "--- regex conformance / realistic patterns ---"
  println #r"^\d{4}-\d{2}-\d{2}$".matches("2026-02-18")
  println #r"^\d{4}-\d{2}-\d{2}$".matches("2026-2-18")
  println #r"^\w+$".matches("INFO_42")
  println #r"^\w+$".matches("INFO-42")
  println #r"^\w+=\w+$".matches("k=v")
  println #r"^\w+=\w+$".matches("k =v")

def testCaptures =
  println "--- regex conformance / captures ---"
  if #r"(\d{4})-(\d{2})-(\d{2})".findFirst("xx2026-02-19yy") is Some(m) then
    println m[0]
    println m[1]
    println m[2]
    println m[3]

  if #r"(a*)".findFirst("") is Some(m1) then
    println m1.isGroupMatched(1)
    println m1[1]

  if #r"(a)?".findFirst("") is Some(m2) then
    println m2.isGroupMatched(1)

def testCaptureRegression =
  println "--- regex conformance / capture regression ---"

  if #r"^(a)*$".findFirst("aaa") is Some(m1) then
    println m1[1]

  if #r"^((a)*)$".findFirst("aa") is Some(m2) then
    println m2[1]
    println m2[2]

  if #r"^(a)(b)?$".findFirst("ab") is Some(m3) then
    println m3[1]
    println m3.isGroupMatched(2)
    println m3[2]

  if #r"^(a)(b)?$".findFirst("a") is Some(m4) then
    println m4[1]
    println m4.isGroupMatched(2)

  if #r"^((a)?b)*$".findFirst("abab") is Some(m5) then
    println m5[1]
    println m5[2]

  if #r"^(a*)(b)$".findFirst("aaab") is Some(m6) then
    println m6[1]
    println m6[2]

def testFind =
  println "--- regex conformance / find ---"
  println #r"\w+".findFirst("..abc!!")
  println #r"\w+".findFirst("..ab 12!!x")
  println #r"\b!".findFirst("a!")
  println #r"^abc$".findFirst("zabcx")
  println #r"a*".findAll("bbb").size
