def testRealistic =
  println "--- regex conformance / realistic patterns ---"
  println #r"^\d{4}-\d{2}-\d{2}$".matchesExact("2026-02-18")
  println #r"^\d{4}-\d{2}-\d{2}$".matchesExact("2026-2-18")
  println #r"^\w+$".matchesExact("INFO_42")
  println #r"^\w+$".matchesExact("INFO-42")
  println #r"^\w+=\w+$".matchesExact("k=v")
  println #r"^\w+=\w+$".matchesExact("k =v")

def testCaptures =
  println "--- regex conformance / captures ---"
  if #r"(\d{4})-(\d{2})-(\d{2})".matchFirst("xx2026-02-19yy") is m: Match then
    println m[0]
    println m[1]
    println m[2]
    println m[3]

  if #r"(a*)".matchFirst("") is m1: Match then
    println m1.isGroupMatched(1)
    println m1[1]

  if #r"(a)?".matchFirst("") is m2: Match then
    println m2.isGroupMatched(1)

def testCaptureRegression =
  println "--- regex conformance / capture regression ---"

  if #r"^(a)*$".matchFirst("aaa") is m1: Match then
    println m1[1]

  if #r"^((a)*)$".matchFirst("aa") is m2: Match then
    println m2[1]
    println m2[2]

  if #r"^(a)(b)?$".matchFirst("ab") is m3: Match then
    println m3[1]
    println m3.isGroupMatched(2)
    println m3[2]

  if #r"^(a)(b)?$".matchFirst("a") is m4: Match then
    println m4[1]
    println m4.isGroupMatched(2)

  if #r"^((a)?b)*$".matchFirst("abab") is m5: Match then
    println m5[1]
    println m5[2]

  if #r"^(a*)(b)$".matchFirst("aaab") is m6: Match then
    println m6[1]
    println m6[2]

def testFind =
  println "--- regex conformance / find ---"
  println #r"\w+".matchFirst("..abc!!")
  println #r"\w+".matchFirst("..ab 12!!x")
  if #r"\w+".matchFirst("..abc!!") is m1: Match then
    println m1

  println #r"a+".matchFirst("baaa!")
  println #r"a+?".matchFirst("baaa!")
  // println #r"\b!".matchFirst("a!")
  println #r"^abc$".matchFirst("zabcx")
  val parts = #r"\w+".matchAll("..ab 12!!x")
  println parts.size
  println parts[0]
  println parts[1]
  println parts[2]

  val zero = #r"a*".matchAll("bbb")
  println zero.size
  println zero[0].from
  println zero[0].length
  println zero[1].from
  println zero[1].length
  println zero[2].from
  println zero[2].length
  println zero[3].from
  println zero[3].length
