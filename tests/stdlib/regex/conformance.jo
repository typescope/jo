import jo.regex.*

def main =
  testBasics()
  testQuantifiers()
  testBounded()
  testLazyQuantifiers()
  testAlternation()
  testClasses()
  testEscapes()
  testAnchors()
  testFlags()
  // testWordBoundaries()
  testUnicode()
  testRealistic()
  testCaptures()
  testCaptureRegression()
  testFind()

def testBasics =
  println "--- regex conformance / basics ---"
  println #r"abc".matchesExact("abc")
  println #r"abc".matchesExact("abd")
  println #r"a.c".matchesExact("aXc")
  println #r"a.c".matchesExact("a\nc")

def testQuantifiers =
  println "--- regex conformance / quantifiers ---"
  println #r"a*".matchesExact("")
  println #r"a*b".matchesExact("aaab")
  println #r"a*b".matchesExact("aaaaac")
  println #r"a+".matchesExact("aaaa")
  println #r"a+".matchesExact("")
  println #r"ab?c".matchesExact("ac")
  println #r"ab?c".matchesExact("abc")
  println #r"ab?c".matchesExact("abbc")

def testBounded =
  println "--- regex conformance / bounded repetition ---"
  println #r"a{3}".matchesExact("aaa")
  println #r"a{3}".matchesExact("aa")
  println #r"a{2,4}".matchesExact("aa")
  println #r"a{2,4}".matchesExact("aaaa")
  println #r"a{2,4}".matchesExact("aaaaa")
  println #r"a{3,}".matchesExact("aaaaa")

def testLazyQuantifiers =
  println "--- regex conformance / lazy quantifiers ---"
  println #r"a+?".matchFirst("baaa!")
  println #r"a*?".matchFirst("aaa")
  println #r"ab??c".matchesExact("abc")
  println #r"ab??c".matchesExact("ac")
  println #r"a{1,3}?".matchFirst("aaaa")
  println #r"a{2,}?".matchFirst("aaaa")

def testAlternation =
  println "--- regex conformance / alternation and grouping ---"
  println #r"(ab|cd)".matchesExact("ab")
  println #r"(ab|cd)".matchesExact("cd")
  println #r"(ab|cd)".matchesExact("ad")
  println #r"^(?:ab)+$".matchesExact("abab")
  println #r"^a(?:b|c)d$".matchesExact("acd")
  println #r"^a(?:b|c)d$".matchesExact("abd")
  println #r"^a(?:b|c)d$".matchesExact("aed")

def testClasses =
  println "--- regex conformance / character classes ---"
  println #r"[abc]".matchesExact("a")
  println #r"[abc]".matchesExact("d")
  println #r"[a-z]".matchesExact("k")
  println #r"[a-z]".matchesExact("K")
  println #r"[^a-z]".matchesExact("K")
  println #r"[-a]".matchesExact("-")
  println #r"[a-]".matchesExact("-")

def testEscapes =
  println "--- regex conformance / escapes ---"
  println #r"\d".matchesExact("7")
  println #r"\d".matchesExact("x")
  println #r"\s".matchesExact(" ")
  println #r"\s".matchesExact("\t")
  println #r"\w".matchesExact("A")
  println #r"\w".matchesExact("_")
  println #r"\W".matchesExact("-")
  println #r"\{".matchesExact("{")
  println #r"\+".matchesExact("+")

def testAnchors =
  println "--- regex conformance / anchors ---"
  println #r"^abc$".matchesExact("abc")
  println #r"^abc$".matchesExact("zabc")
  println #r"^abc$".matchesExact("abcz")
  println #r"^a.*c$".matchesExact("abc")
  println #r"^a.*c$".matchesExact("a\nc")

def testFlags =
  println "--- regex conformance / flags ---"
  println #r[s]"^a.c$".matchesExact("a\nc")
  println #r[m]"^foo$".matchFirst("xx\nfoo\nyy")
  println #r[i]"abc".matchesExact("ABC")

def testUnicode =
  println "--- regex conformance / unicode ---"
  println #r"😀".matchesExact("😀")
  println #r"😀".matchesExact("x")
  println #r"😀+".matchesExact("😀😀")
  println #r"😀+".matchFirst("a😀😀b")

  if #r"(😀+)(b)".matchFirst("a😀😀b") is m: Match then
    println m[1]
    println m[2]

  val faces = #r"😀".matchAll("😀x😀")
  println faces.size
  println faces[0].from
  println faces[0].length
  println faces[1].from
  println faces[1].length

  println #r"\w+".matchFirst("😀abc")

  println "--- regex conformance / unicode input with ascii regex ---"
  println #r"abc".matchFirst("😀abc😀")

  if #r"(a)(bc)".matchFirst("😀abc😀") is m: Match then
    println m[0]
    println m[1]
    println m[2]
    println m.from
    println m.length

  if #r"b+".matchFirst("😀abbb😀") is m2: Match then
    println m2
    println m2.from
    println m2.length

