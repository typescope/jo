import jo.regex.*

def printMatch(m: Option[Match]) =
  match m
    case Some(found) =>
      println ("Some(" + found + ")")
    case None =>
      println "None"

def main =
  testLiteral()
  testEscapedBacktick()
  testMatching()
  testCaptures()
  testReplace()
  testStringReplace()
  testSplit()

def testLiteral =
  println "--- regex literal / toString ---"
  println `\d+`.toString
  println `(?is)a.*b`.toString

def testEscapedBacktick =
  println "--- regex escaped backtick ---"
  val r = `\``
  println r.toString
  println r.matchesExact("`")
  println r.matchesExact("a")

def testMatching =
  println "--- regex matching ---"
  val r = `\d+`
  println r.matchesExact("123")
  println r.matchesExact("a1")
  printMatch(r.matchPrefix("123abc"))
  printMatch(r.matchFirst("ab12cd"))
  printMatch(r.matchFrom("ab12cd34", 4))
  println r.matchAll("a1b22c333").size

def testCaptures =
  println "--- regex captures ---"
  if `([A-Z]+)(\d+)`.matchFirst("AB12") is Some(m) then
    println m[0]
    println m[1]
    println m[2]

  if `(\w+)(\s+\w+)?`.matchFirst("hello") is Some(opt) then
    println opt.isGroupMatched(2)

def testReplace =
  println "--- regex replace ---"
  println `\d+`.replaceAll("a1b22c333", _ => "N")
  println `(\w+)\s+(\w+)`.replaceFirst("hello world", m => m[2] + " " + m[1])

def testStringReplace =
  println "--- string regex replace ---"
  println "a1b22c333".replaceAll(`\d+`, _ => "N")
  println "hello world".replaceFirst(`(\w+)\s+(\w+)`, m => m[2] + " " + m[1])

def testSplit =
  println "--- regex split ---"

  val parts1 = `:`.split("a:b:c")
  println parts1.size
  println parts1[0]
  println parts1[1]
  println parts1[2]

  val parts2 = ``.split("abc")
  println parts2.size
  println parts2[0]
  println parts2[1]
  println parts2[2]
  println parts2[3].isEmpty
