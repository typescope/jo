import jo.regex.*

def printMatch(m: Match | None) =
  match m
    case found: Match =>
      println ("Some(" + found + ")")
    case None =>
      println "None"

def main =
  testToStringEscapes()
  testDynamicCompile()
  testNamedGroups()
  testOptionalAndEmptyCaptures()
  testZeroWidthCases()

def testToStringEscapes =
  println "--- regex advanced / toString escapes ---"
  println `\``
  println `\\n`

def testDynamicCompile =
  println "--- regex advanced / dynamic compile ---"

  match Regex.compile("\\d+")
    case d: Regex =>
      println d.matchesExact("123")
      println d.matchesExact("abc")
    case _: String => pass

  match Regex.compile("a+?")
    case r: Regex => printMatch(r.matchFirst("baaa!"))
    case _: String => pass

  match Regex.compile("(?si)abc")
    case r: Regex => println r.toString
    case _: String => pass

  match Regex.compile("(?is)abc")
    case r: Regex => println r.toString
    case _: String => pass

def testNamedGroups =
  println "--- regex advanced / named groups ---"

  if `(?<word>\w+)-(?<num>\d+)`.matchFirst("abc-42") is m: Match then
    println m["word"]
    println m["num"]
    println m.getOpt("word")

def testOptionalAndEmptyCaptures =
  println "--- regex advanced / captures ---"

  if `(a*)`.matchFirst("") is m1: Match then
    println m1.isGroupMatched(1)
    println m1[1]

  if `(a)?`.matchFirst("") is m2: Match then
    println m2.isGroupMatched(1)

def testZeroWidthCases =
  println "--- regex advanced / zero width ---"

  println ``.matchAll("abc").size

  val parts1 = `^`.split("abc")
  println parts1.size
  println parts1[0]
  println parts1[1]

  val parts2 = `$`.split("abc")
  println parts2.size
  println parts2[0]
  println parts2[1]
