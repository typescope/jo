import jo.regex.*

def main =
  testToStringEscapes()
  testValidationEdges()
  testDynamicCompile()
  testOptionalAndEmptyCaptures()
  testZeroWidthCases()

def printCheckResult(pat: String, flags: String) =
  match Regex.checkError(pat, flags)
    case None =>
      println "ok"
    case Some(_) =>
      println "err"

def testToStringEscapes =
  println "--- regex advanced / toString escapes ---"
  println #r"\""
  println #r"\\n"

def testValidationEdges =
  println "--- regex advanced / validation ---"
  printCheckResult("\\{", "")
  printCheckResult("\\", "")
  printCheckResult("a{3,2}", "")
  printCheckResult("a{3,}", "")
  printCheckResult("a+?", "")
  printCheckResult("a*?", "")
  printCheckResult("a*+", "")
  printCheckResult("\\Qabc\\E", "")
  printCheckResult("abc", "si")
  printCheckResult("abc", "is")
  printCheckResult("abc", "ss")

def testDynamicCompile =
  println "--- regex advanced / dynamic compile ---"

  val d = Regex.compile("\\d+")
  println d.matches("123")
  println d.matches("abc")

  val lazy = Regex.compile("a+?", "")
  println lazy.findFirst("baaa!")

  println Regex.compile("abc", "si").toString
  println Regex.compileValidated("abc", "is").toString

def testOptionalAndEmptyCaptures =
  println "--- regex advanced / captures ---"

  if #r"(a*)".findFirst("") is Some(m1) then
    println m1.isGroupMatched(1)
    println m1[1]

  if #r"(a)?".findFirst("") is Some(m2) then
    println m2.isGroupMatched(1)

def testZeroWidthCases =
  println "--- regex advanced / zero width ---"

  println #r"".findAll("abc").size

  val parts1 = #r"^".split("abc")
  println parts1.size
  println parts1[0]
  println parts1[1]

  val parts2 = #r"$".split("abc")
  println parts2.size
  println parts2[0]
  println parts2[1]
