import jo.regex.*

def main =
  testValid()
  testInvalid()

def checkError(source: String): String =
  match Regex.compile(source)
    case _: Regex => "None"
    case err: String => "Some(" + err + ")"

def testValid =
  println "--- regex validation / valid ---"
  println checkError("\\d+")
  println checkError("\\{")
  println checkError("a{3,}")
  println checkError("a+?")
  println checkError("a*?")
  println checkError("(?<x>a)")
  println checkError("(?si)abc")
  println checkError("(?is)abc")

def testInvalid =
  println "--- regex validation / invalid ---"
  println checkError("[abc")
  println checkError("(?z)abc")
  println checkError("(?ii)abc")
  println checkError("(?<>)")
  println checkError("(?<1x>a)")
  println checkError("(?<x-y>a)")
  println checkError("(?<x>a)(?<x>b)")
  println checkError("(abc")
  println checkError("\\")
  println checkError("a{3,2}")
  println checkError("a*+")
  println checkError("\\Qabc\\E")
  println checkError("(a)\\1")
  println checkError("(?=a)")
  println checkError("(?<=a)")
  println checkError("(?<!a)")
  println checkError("\\p{L}")
  println checkError("(?i:a)")
  println checkError("(?ss)abc")
