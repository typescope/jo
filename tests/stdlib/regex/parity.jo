import jo.regex.*

def printMatch(m: Option[Match]) =
  match m
    case Some(found) =>
      println ("Some(" + found + ")")
    case None =>
      println "None"

def main =
  testNamedGroups()
  testUnicodeInput()
  testFlagMWithoutS()
  testZeroWidth()
  testLazyQuantifiers()

def testNamedGroups =
  println "--- regex parity / named groups ---"

  if `(?<x>a)(?<y>b)`.matchFirst("ab") is Some(m1) then
    println m1[1]
    println m1[2]
    println m1["x"]
    println m1["y"]

  if `^(?<x>a)?b$`.matchFirst("b") is Some(m2) then
    println m2.isGroupMatched("x")
    println m2.getOpt("x")

  if `^(?<x>a)*$`.matchFirst("aaa") is Some(m3) then
    println m3["x"]

  if `(?<outer>(?<inner>a)b)`.matchFirst("ab") is Some(m4) then
    println m4[1]
    println m4[2]
    println m4["outer"]
    println m4["inner"]

def testUnicodeInput =
  println "--- regex parity / unicode input ---"

  val words = `\w+`.matchAll("😀ab😺cd")
  println words.size
  println words[0]
  println words[0].from
  println words[0].length
  println words[1]
  println words[1].from
  println words[1].length

  printMatch(`.`.matchFirst("😀"))

  if `abc`.matchFirst("😀abc😀") is Some(m) then
    println m[0]
    println m.from
    println m.length

def testZeroWidth =
  println "--- regex parity / zero width ---"

  val empty = ``.matchAll("😀a")
  println empty.size
  println empty[0].from
  println empty[0].length
  println empty[1].from
  println empty[1].length
  println empty[2].from
  println empty[2].length

  val parts = "😀a".splitBy(``)
  println parts.size
  println parts[0]
  println parts[1]
  println parts[2]

  println "abc".replaceAll(``, _ => "-")

def testFlagMWithoutS =
  println "--- regex parity / m without s ---"
  println `(?m)^a.c$`.matchesExact("a\nc")
  println `(?ms)^a.c$`.matchesExact("a\nc")

def testLazyQuantifiers =
  println "--- regex parity / lazy quantifiers ---"

  if `(a+?)(a+)`.matchFirst("aaaa") is Some(m1) then
    println m1[0]
    println m1[1]
    println m1[2]

  if `(a{1,2}?)(a+)`.matchFirst("aaaa") is Some(m2) then
    println m2[1]
    println m2[2]
