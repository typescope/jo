def main receives IO.stdout =
  println "=== Mutable Map (Hash Table) ==="
  println ""

  // Create empty map
  val m = mutable.Map.empty[Int, String]
  println "Empty map size: \{m.size}"
  println ""

  // Add elements
  println "=== Adding elements ==="
  m.update(1, "one")
  m.update(2, "two")
  m.update(3, "three")
  m.update(4, "four")
  m.update(5, "five")

  println "Size after adding 5 elements: \{m.size}"
  println ""

  // Get elements
  println "=== Getting elements ==="
  match m.getOpt(1)
    case Some(v) => println "get 1: \{v}"
    case None => println "get 1: Not found"

  match m.getOpt(3)
    case Some(v) => println "get 3: \{v}"
    case None => println "get 3: Not found"

  match m.getOpt(5)
    case Some(v) => println "get 5: \{v}"
    case None => println "get 5: Not found"

  match m.getOpt(10)
    case Some(v) => println "get 10: \{v}"
    case None => println "get 10: Not found"

  println ""

  // Contains
  println "=== Contains ==="
  println "contains 2: \{m.contains(2)}"
  println "contains 4: \{m.contains(4)}"
  println "contains 6: \{m.contains(6)}"
  println ""

  // GetOrElse
  println "=== GetOrElse ==="
  println "getOrElse 3 'default': \{m.getOrElse(3, "default")}"
  println "getOrElse 10 'default': \{m.getOrElse(10, "default")}"
  println ""

  // Update existing key (mutable - modifies in place)
  println "=== Update existing key ==="
  m.update(3, "THREE")
  println "After update 3 'THREE':"
  match m.getOpt(3)
    case Some(v) => println "  get 3: \{v}"
    case None => println "  get 3: Not found"

  println "  size: \{m.size}"
  println ""

  // Add method (alias for update)
  println "=== Add method ==="
  m.add(6, "six")
  println "After add 6 'six':"
  println "  size: \{m.size}"
  println "  contains 6: \{m.contains(6)}"
  println ""

  // Remove elements
  println "=== Remove elements ==="
  m.remove(3)
  m.remove(1)
  println "After removing 3 and 1:"
  println "  size: \{m.size}"
  println "  contains 1: \{m.contains(1)}"
  println "  contains 3: \{m.contains(3)}"
  println "  contains 5: \{m.contains(5)}"
  println ""

  // Remove non-existent key
  println "=== Remove non-existent key ==="
  val sizeBefore = m.size
  m.remove(100)
  println "After removing non-existent key 100:"
  println "  size unchanged: \{m.size == sizeBefore}"
  println ""

  // Fold
  println "=== Fold ==="
  val sum = m.fold(0, (acc, k, v) => acc + k)
  println "Sum of all keys: \{sum}"
  println ""

  // Iterator
  println "=== Iterator ==="
  println "All entries:"
  for k ~ v in m do
    println "  \{k} -> \{v}"
  end
  println ""

  // Clear
  println "=== Clear ==="
  m.clear()
  println "After clear:"
  println "  size: \{m.size}"
  println "  contains 2: \{m.contains(2)}"
  println ""

  // Add after clear
  println "=== Add after clear ==="
  m[100] = "hundred"
  m[200] = "two hundred"
  println "After adding 2 new elements:"
  println "  size: \{m.size}"
  match m.getOpt(100)
    case Some(v) => println "  get 100: \{v}"
    case None => println "  get 100: Not found"

  match m.getOpt(200)
    case Some(v) => println "  get 200: \{v}"
    case None => println "  get 200: Not found"

  println ""

  // Test with many elements (hash collision testing)
  println "=== Hash collision test ==="
  val m2 = mutable.Map.empty[Int, String]
  var i = 0
  while i < 50 do
    m2.add(i, "value\{i}")
    i = i + 1
  end
  println "Added 50 elements"
  println "  size: \{m2.size}"
  println "  contains 0: \{m2.contains(0)}"
  println "  contains 25: \{m2.contains(25)}"
  println "  contains 49: \{m2.contains(49)}"
  println "  contains 50: \{m2.contains(50)}"
  println ""

  println "=== All tests completed ==="
