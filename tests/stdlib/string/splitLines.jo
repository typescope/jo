def main =
  testLines()

def testLines =
  println "--- lines ---"

  val a = "".lines
  println a.size                   // 1
  println a[0]                     // (empty)

  val b = "one".lines
  println b.size                   // 1
  println b[0]                     // one

  val c = "one\ntwo".lines
  println c.size                   // 2
  println c[0]                     // one
  println c[1]                     // two

  val d = "one\r\ntwo".lines
  println d.size                   // 2
  println d[0]                     // one
  println d[1]                     // two

  val e = "one\n".lines
  println e.size                   // 2
  println e[0]                     // one
  println e[1]                     // (empty)

  val f = "\u{4F60}\u{597D}\n\u{1F680}".lines
  println f.size                   // 2
  println f[0]                     // 你好
  println f[1]                     // 🚀
