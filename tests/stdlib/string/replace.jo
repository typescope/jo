def main =
  testReplace()

def testReplace =
  println "--- replace ---"

  println "hello world".replace("world", "jo")           // hello jo
  println "aaa".replace("a", "bb")                       // bbbbbb
  println "hello".replace("xyz", "abc")                  // hello
  println "abab".replace("ab", "c")                      // cc

  // Unicode
  val cn = "\u{4F60}\u{597D}\u{4E16}\u{754C}"
  println cn.replace("\u{4E16}\u{754C}", "!")            // 你好!

  // Emoji
  val s = "I \u{2764} \u{1F680}"
  println s.replace("\u{2764}", "love")                  // I love 🚀

