def main =
  testSubstring()

def testSubstring =
  println "--- substring ---"

  // ASCII
  println "hello world".substring(0, 5)    // hello
  println "hello world".substring(6, 5)    // world
  println "hello world".substring(3, 4)    // lo w

  // BMP Unicode
  val cn = "\u{4F60}\u{597D}\u{4E16}\u{754C}"    // 你好世界
  println cn.substring(0, 2)               // 你好
  println cn.substring(2, 2)               // 世界

  // Emoji
  val s = "a\u{1F680}b\u{1F389}c"         // a🚀b🎉c
  println s.substring(1, 1)               // 🚀
  println s.substring(0, 3)               // a🚀b
  println s.substring(3, 2)               // 🎉c

