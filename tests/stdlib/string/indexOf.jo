def main =
  testIndexOf()
  testIndexOfFrom()

def testIndexOf =
  println "--- indexOf ---"

  // ASCII
  println "hello world".indexOf("world")       // 6
  println "hello world".indexOf("hello")       // 0
  println "hello world".indexOf("xyz")         // -1
  println "hello world".indexOf("o")           // 4
  println "hello world".indexOf("")            // 0

  // Not found
  println "abc".indexOf("abcd")               // -1

  // BMP Unicode
  val cn = "\u{4F60}\u{597D}\u{4E16}\u{754C}" // 你好世界
  println cn.indexOf("\u{4E16}\u{754C}")       // 2
  println cn.indexOf("\u{4F60}")               // 0
  println cn.indexOf("x")                     // -1

  // Emoji
  val s = "a\u{1F680}b\u{1F389}c"             // a🚀b🎉c
  println s.indexOf("\u{1F389}")               // 3
  println s.indexOf("b")                       // 2
  println s.indexOf("\u{1F525}")               // -1 (🔥 not in string)

def testIndexOfFrom =
  println "--- indexOf with from ---"

  // from skips earlier matches
  println "hello world".indexOf("o", 5)        // 7
  println "hello world".indexOf("o", 4)        // 4 (inclusive)
  println "hello world".indexOf("o", 8)        // -1

  // repeated pattern
  println "abcabc".indexOf("abc", 1)           // 3
  println "abcabc".indexOf("abc", 3)           // 3
  println "abcabc".indexOf("abc", 4)           // -1

  // from = 0 is the same as default
  println "hello".indexOf("ell", 0)            // 1

  // negative from treated as 0
  println "hello".indexOf("h", -5)             // 0

  // from beyond size: not found
  println "hello".indexOf("o", 10)             // -1

  // empty needle with from
  println "hello".indexOf("", 3)               // 3
  println "hello".indexOf("", 6)               // 5 (clamped to size)

  // BMP Unicode with from
  val cn = "\u{4F60}\u{597D}\u{4E16}\u{754C}"  // 你好世界
  println cn.indexOf("\u{4E16}\u{754C}", 1)    // 2
  println cn.indexOf("\u{4F60}", 1)            // -1 (passed it)

  // Emoji with from
  val s = "a\u{1F680}b\u{1F389}c"             // a🚀b🎉c
  println s.indexOf("\u{1F389}", 2)            // 3
  println s.indexOf("b", 3)                   // -1 (b is at cp 2, before from=3)
