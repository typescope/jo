def main =
  testStartsWith

def testStartsWith =
  println "--- startsWith ---"

  println "hello world".startsWith("hello")    // true
  println "hello world".startsWith("world")    // false
  println "hello world".startsWith("")         // true
  println "hi".startsWith("hello")             // false

  // Unicode
  val cn = "\u{4F60}\u{597D}\u{4E16}\u{754C}"
  println cn.startsWith("\u{4F60}\u{597D}")    // true
  println cn.startsWith("\u{4E16}")            // false

  // Emoji
  val s = "\u{1F680}abc"
  println s.startsWith("\u{1F680}")            // true
  println s.startsWith("a")                   // false

