def main =
  testEndsWith()

def testEndsWith =
  println "--- endsWith ---"

  println "hello world".endsWith("world")      // true
  println "hello world".endsWith("hello")      // false
  println "hello world".endsWith("")           // true
  println "hi".endsWith("hello")               // false

  // Unicode
  val cn = "\u{4F60}\u{597D}\u{4E16}\u{754C}"
  println cn.endsWith("\u{4E16}\u{754C}")      // true
  println cn.endsWith("\u{4F60}")              // false

  // Emoji
  val s = "abc\u{1F389}"
  println s.endsWith("\u{1F389}")              // true
  println s.endsWith("c")                     // false

