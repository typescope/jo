def main =
  testListMapSetPipeline
  testCountAndFindPipeline

def testListMapSetPipeline =
  println "--- collections.pipeline.groupBy ---"
  val words = ["a", "bb", "ccc", "dd", "eee", "f"]

  val grouped = words.groupBy(s => s.size)
  println grouped

  val counts = grouped.mapValues(xs => xs.size)
  println counts

  println grouped.keySet
  println grouped.keySet.subsetOf({ 1, 2, 3, 4 })

def testCountAndFindPipeline =
  println "--- collections.pipeline.count-find ---"
  val s = { 1, 2, 3, 4, 5, 6 }

  println s.count(x => x % 2 == 0)
  println s.find(x => x > 3)

  val evenBuckets = [1, 2, 3, 4, 5, 6]
    .groupBy((n: Int) => n % 2)
    .mapValues(xs => xs.count(n => n % 2 == 0))
  println evenBuckets
