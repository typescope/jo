rm -rf repo .build dep/.build

rm -f jo.lock dep/jo.lock

jo package --spec dep/jo.toml

mkdir -p repo/jo-core/1.0.0

cp dep/.build/jo-core/release/jo-core-v1.0.0.joy repo/jo-core/1.0.0/

jo package

unzip -Z1 .build/release-lib/release/release-lib-v1.0.0.joy | sort
: '
Greeter/Greeter.sast
meta.toml
'

unzip -Z1 .build/release-lib/release/release-lib-v1.0.0-sources.zip | sort
: '
src/Greeter.jo
'

unzip -p .build/release-lib/release/release-lib-v1.0.0.joy meta.toml
: '
namespace = "Greeter"
name = "release-lib"
jo = "1.0"
version = "1.0.0"
ffi = "none"
description = "Release test package"
authors = ["Alice <alice@example.com>", "Bob <bob@example.com>"]
homepage = "https://example.com/release-lib"
license = "MIT"
keywords = ["release", "test"]

[dependencies]
jo-core = "1.0"
'

(cd .build/release-lib/release && sha512sum -c release-lib-v1.0.0.joy.sha512)
: '
release-lib-v1.0.0.joy: OK
'

(cd .build/release-lib/release && sha512sum -c release-lib-v1.0.0-sources.zip.sha512)
: '
release-lib-v1.0.0-sources.zip: OK
'
