rm -rf repo .build dep/.build dep2/.build

rm -f jo.lock dep/jo.lock dep2/jo.lock

jo package --spec dep/jo.toml

jo package --spec dep2/jo.toml

mkdir -p repo/greeter-pkg/1.0.0 repo/alpha-pkg/1.0.0

cp dep/.build/lib/release/greeter-pkg-v1.0.0.joy repo/greeter-pkg/1.0.0/

cp dep2/.build/lib/release/alpha-pkg-v1.0.0.joy repo/alpha-pkg/1.0.0/

jo lock
: ''

cp jo.lock jo-old.lock
: ''

sed -n 's/^\(greeter-pkg = { version = "1.0.0", sha512 = "\)[0-9a-f]\+\(" }$\)/\1PLACEHOLDER\2/p' jo.lock
: '
greeter-pkg = { version = "1.0.0", sha512 = "PLACEHOLDER" }
'

cp jo.toml jo-base.toml

cp jo-updated.toml jo.toml
: ''

cp jo-old.lock jo.lock
: ''

jo build
: '
error: lock file is missing package entries for: alpha-pkg; run 'jo lock'
'

jo lock
: ''

sed -n -e 's/^\(alpha-pkg = { version = "1.0.0", sha512 = "\)[0-9a-f]\+\(" }$\)/\1PLACEHOLDER\2/p' -e 's/^\(greeter-pkg = { version = "1.0.0", sha512 = "\)[0-9a-f]\+\(" }$\)/\1PLACEHOLDER\2/p' jo.lock
: '
alpha-pkg = { version = "1.0.0", sha512 = "PLACEHOLDER" }
greeter-pkg = { version = "1.0.0", sha512 = "PLACEHOLDER" }
'

jo build
: ''

jo check
: ''

jo run
: '
Hello, Lock!
'

jo doc
: ''

cp jo-old.lock jo.lock
: ''

cp jo-base.toml jo.toml
: ''

rm -f jo-base.toml
: ''
