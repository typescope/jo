namespace ResourceCore

import jo.resource.*

param resources: Resources

def name: String = "core"

def printResource(label: String): Unit receives IO.stdout, resources =
  match resources.readText("core-assets/core.txt")
  case Ok(text) => println(label + " indirect resource = " + text.trim)
  case Err(err) => println(label + " indirect resource err = " + err)
