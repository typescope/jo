namespace ResourceLib

import ResourceCore
import jo.resource.*

param resources: Resources
param coreResources: Resources

def name: String = "lib"

def printResources(label: String): Unit receives IO.stdout, resources, coreResources =
  match resources.readText("runtime/dep-assets/dep.txt")
  case Ok(text) => println(label + " direct resource = " + text.trim)
  case Err(err) => println(label + " direct resource err = " + err)
  match resources.readText("metadata/notice.txt")
  case Ok(text) => println(label + " mapped file resource = " + text.trim)
  case Err(err) => println(label + " mapped file resource err = " + err)
  with ResourceCore.resources = coreResources in
    ResourceCore.printResource(label)
