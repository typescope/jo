import ResourceLib
import ExternalResources
import jo.resource.*
import jo.rb.resource.*

def main: Unit receives IO.stdout =
  with ResourceLib.resources = new rb.resource.ResourceBundle("resource-lib") in
    with ResourceLib.coreResources = new rb.resource.ResourceBundle("resource-core") in
      with ExternalResources.resources = new rb.resource.ResourceBundle("external") in
        ResourceLib.printResources("ruby")
        ExternalResources.printResource("ruby")
