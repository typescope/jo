rm -rf myapp
jo new myapp
: '
Created 'myapp'

You can now:
  cd myapp
  jo run
  jo run test
'
cat myapp/jo.toml
: '
jo = "{{JO_VERSION}}"

[module.app]
kind = "app"
src = ["src/"]
platform = "python"

[module.test]
kind = "app"
src = ["tests/"]
platform = "python"

dependencies = [
  { module = "app" },
]
'
cat myapp/src/Main.jo
: '
def main = println "Hello, myapp!"
'
cat myapp/tests/Main.jo
: '
namespace Test

def main = println "OK"
'
cat myapp/.gitignore
: '
.build/
'
jo run --spec myapp/jo.toml test
: '
OK
'
