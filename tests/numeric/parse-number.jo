def main =
  testIntParse()
  testFloatParse()
  testStringDelegates()

def testIntParse =
  println "--- int.parse ---"
  println Int.parse("0") is Some(0)
  println Int.parse("123") is Some(123)
  println Int.parse("+42") is Some(42)
  println Int.parse("-7") is Some(-7)
  println Int.parse("-0") is Some(0)
  println Int.parse("000") is Some(0)
  println Int.parse("00123") is Some(123)
  println Int.parse("2147483647") is Some(2147483647)
  println Int.parse("") is None
  println Int.parse("+") is None
  println Int.parse("-") is None
  println Int.parse("+-1") is None
  println Int.parse("--1") is None
  println Int.parse("12a") is None
  println Int.parse("1.0") is None
  println Int.parse(" 12") is None
  println Int.parse("12 ") is None

def testFloatParse =
  println "--- float.parse ---"
  println Float.parse("0") is Some(0.0)
  println Float.parse("123") is Some(123.0)
  println Float.parse("+1.5") is Some(1.5)
  println Float.parse("-0.25") is Some(-0.25)
  println Float.parse("-0") is Some(0.0)
  println Float.parse("000.000") is Some(0.0)
  println Float.parse("001.2500") is Some(1.25)
  println Float.parse(".5") is Some(0.5)
  println Float.parse("+.5") is Some(0.5)
  println Float.parse("-.5") is Some(-0.5)
  println Float.parse("2.") is Some(2.0)
  println Float.parse("1e2") is Some(100.0)
  println Float.parse("1E2") is Some(100.0)
  println Float.parse("1e+2") is Some(100.0)
  println Float.parse("1E-2") is Some(0.01)
  println Float.parse("1e-2") is Some(0.01)
  println Float.parse("1.25e1") is Some(12.5)
  println Float.parse("") is None
  println Float.parse(".") is None
  println Float.parse("+.") is None
  println Float.parse("-.") is None
  println Float.parse("e10") is None
  println Float.parse("+e10") is None
  println Float.parse("1e") is None
  println Float.parse("1e+") is None
  println Float.parse("1e-") is None
  println Float.parse("1.2.3") is None
  println Float.parse("--1.0") is None
  println Float.parse("1a") is None
  println Float.parse(" 1.0") is None
  println Float.parse("1.0 ") is None

def testStringDelegates =
  println "--- string delegates ---"
  println "42".toInt is Some(42)
  println "-0".toInt is Some(0)
  println "x".toInt is None
  println "3.25".toFloat is Some(3.25)
  println "+.5".toFloat is Some(0.5)
  println "x".toFloat is None
