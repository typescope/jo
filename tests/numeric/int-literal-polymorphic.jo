// Test polymorphic integer literals

def main() =
  // Int literal as Byte
  val b: Byte = 127
  println b

  // Int literal as Char
  val c: Char = 65
  println c

  // Int literal as Int
  val i: Int = 42
  println i

  // Int literal as Double
  val d: Float = 100
  println d

  // In function calls
  def takeByte(x: Byte): Int = x.toInt
  def takeChar(x: Char): Int = x.toInt
  def takeDouble(x: Float): Float = x * 2.0

  println (takeByte 50)
  println (takeChar 90)
  println (takeDouble 5)
