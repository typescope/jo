// Test polymorphic integer literals

def main() =
  // Int literal as Char
  val c: Char = 65
  println c

  // Int literal as Int
  val i: Int = 42
  println i

  // Int literal as Double
  val d: Float = 100.2
  println d

  // In function calls
  def takeChar(x: Char): Int = x.toInt
  def takeDouble(x: Float): Float = x * 2.1

  println (takeChar 90)
  println (takeDouble 5)
