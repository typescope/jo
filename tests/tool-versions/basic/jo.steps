# cannot remove active version
jo versions remove 0.10.0
: '
error: Jo 0.10.0 is the active version — run 'jo versions use <other>' first
'

# switch active, then remove old active
jo versions use 0.11.3
: '
Now using Jo 0.11.3
'

jo versions remove 0.10.0
: '
Removed Jo 0.10.0
'

jo versions list
: '
