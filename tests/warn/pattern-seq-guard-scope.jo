// Test that variables bound in guard patterns are not visible outside

def test1(list: List[Int ~ Int]) =
  match list
    // ❌ Error: a and b are bound in guard but not visible in body
    case [.. while a ~ b, ..rest] => a + b
  end

def test2(list: List[String ~ Int]) =
  match list
    // ❌ Error: name is bound in guard but not visible in body
    case [.. while name ~ age, ..rest] => name
  end

def test3(list: List[Int]) =
  match list
    // ✓ OK: matched is bound by the repeat pattern itself
    case [..matched while x, y if y == x, ..rest] => matched.size
    case _ => 0
  end

def test4(list: List[Int]) =
  match list
    // ✓ OK: rest is bound by the second repeat pattern
    case [.. while x, ..rest] => rest.size
    case _ => 0
  end

def test5(s: String ~ List[Int]) =
  match s
    case x ~ [..ys while (x if x > 0), ..] =>  // x in the guard must be fresh
    case x ~ [..ys while (y if y > x), ..] =>  // x is available
    case _ =>
