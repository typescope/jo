section TestDefer
  defer def good(x: Int): Bool

  defer def nice(x: Int): Bool = x > 60

  defer def foo(x: Int)

  defer def bar(x: Int) = x > 60

  defer pattern Neg: Partial[Int] =
    case x if x > 0

  defer type B = Int

  defer section B

  defer class C

  defer param x: Int
end

class List
  defer val x: Int

  defer def List(a: Int) = this.x = a

  defer def bar(x: Int): Int = x * 5
end
