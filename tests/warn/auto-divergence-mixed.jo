// Error: Divergence through 3-node cycle with mixed value and member candidates
// Cycle: Need Eq[Item] → try eqItem (needs Eq[Box]) → try [Box].compare (needs Eq[Item]) → cycle!

type Eq[T] = (T, T) => Bool

class Item
  val value: Int
  def Item(n: Int) = { value: n }

class Box
  val item: Item
  def Box(i: Item) = { item: i }

  // Member candidate: compare method needs Eq[Item]
  // This creates a cycle when used to resolve Eq[Box] needed by eqItem
  def compare(that: Box)(auto eq: Eq[Item] with [eqItem]): Bool =
    eq(this.item, that.item)

// Value candidate: eqItem needs Eq[Box]
// When resolving Eq[Box], it tries [Box].compare
// [Box].compare needs Eq[Item] with candidate [eqItem]
// This creates the cycle: eqItem → [Box].compare → eqItem
def eqItem(auto eq: Eq[Box] with [[Box].compare]): Eq[Item] =
  (a, b) => a.value == b.value

def testEq[T](x: T, y: T)(auto eq: Eq[T] with [eqItem]): Bool =
  eq(x, y)

def main: Unit =
  val i1 = new Item(42)
  val i2 = new Item(100)
  val result = testEq[Item](i1, i2)  // Error: cycle detected
  assert(!result, "items should not be equal")
