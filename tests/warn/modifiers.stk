auto pattern Pos: Partial[Int] =
  case x if x > 0

auto def foo(x: Int): Int = x

auto def bar(x: Int)(auto y: String): Int = x

auto param x: Int  // disallow for now

auto type A = Int

auto data Point(x: Int, y: Int)

section TestDefer
  defer def good(x: Int): Bool

  defer def nice(x: Int): Bool = x > 60

  defer def foo(x: Int)

  defer def bar(x: Int) = x > 60

  defer pattern Neg: Partial[Int] =
    case x if x > 0

  defer type B = Int

  defer section B

  defer class C

  defer param x: Int

