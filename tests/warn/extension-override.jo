// Case 1: shadows a direct class method
class Foo
  def show: String = "Foo"

extension FooOps for Foo
  def show: String = "FooOps"

type ExtFoo = Foo :+ [FooOps.show]

// Case 2: shadows a direct view method
interface Displayable
  def display: String
end

class Bar
  def display: String = "Bar"
  view Displayable
end

extension BarOps for Bar
  def display: String = "BarOps"

type ExtBar = Bar :+ [BarOps.display]

// Case 3: shadows a delegate view method
interface Loggable
  def log: String
end

class Baz(logger: Loggable)
  view Loggable = logger
end

extension BazOps for Baz
  def log: String = "BazOps"

type ExtBaz = Baz :+ [BazOps.log]

// Case 4: override marker on a method that doesn't shadow anything
class Qux
  def run: String = "Qux"

extension QuxOps for Qux
  def run: String = "QuxOps"
  def extra: String = "extra"

type ExtQux = Qux :+ [QuxOps.run!, QuxOps.extra!]
