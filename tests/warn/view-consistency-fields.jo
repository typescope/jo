// Test view consistency checking for fields
// In the delegate view design, only ABSTRACT methods from an interface are forwarded.
// Fields of the delegate object are not forwarded, so field-vs-field conflicts no
// longer arise.  The errors that remain are name clashes between class members and
// the abstract-method forwarders that the compiler synthesizes.

interface Logger
  def log(msg: String): Unit
end

class LoggerImpl
  val logLevel: Int = 0
  def log(msg: String): Unit = pass
  view Logger
end

interface Storage
  def save(data: String): Unit
end

class StorageImpl
  val capacity: Int = 100
  def save(data: String): Unit = pass
  view Storage
end

// No error: logLevel is a field on LoggerImpl, not an abstract method of Logger,
// so no forwarder is generated and no conflict occurs.
class Service1(logger: LoggerImpl)
  val logLevel: Int = 1
  view Logger = logger
end

// No error: capacity is a field on StorageImpl, not an abstract method of Storage.
class Service2(storage: StorageImpl)
  val capacity: Int = 50
  view Storage = storage
end

// No error: Logger and Counter abstract methods don't overlap.
class Logger2
  val count: Int = 0
  def log(msg: String): Unit = pass
  view Logger
end

interface Counter
  def count: Int
  def increment(): Unit
end

class Service3(logger: Logger2, counter: Counter)
  view Logger = logger
  view Counter = counter
end

// Error: class field 'format' clashes with abstract method 'format' from delegate
interface Printer
  def format(s: String): String
  def print(s: String): Unit
end

class Service4(printer: Printer)
  val format: String = "default"  // Field conflicts with method from delegate view
  view Printer = printer
end

// Error: class method 'timeout' clashes with abstract method 'timeout' from delegate
interface Config
  def timeout: Int
  def load(): Unit
end

class Service5(config: Config)
  def timeout(): Int = 60  // Method conflicts with field from delegate view
  view Config = config
end

// Error: two delegate views both forward a method named 'connection'
interface Database
  def connection: String
  def query(sql: String): Unit
end

interface Connection
  def connection(): String
  def close(): Unit
end

class Service6(db: Database, conn: Connection)
  view Database = db
  view Connection = conn
end

def main = pass
