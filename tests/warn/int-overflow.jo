// Test integer literal overflow detection

def main() =
  // Decimal overflow - exceeds Int.MaxValue (2147483647)
  val a = 2147483648

  // Negative overflow - exceeds Int.MinValue (-2147483648)
  val b = -2147483649

  // Hexadecimal overflow - more than 8 hex digits
  val c = 0x123456789

  print a
