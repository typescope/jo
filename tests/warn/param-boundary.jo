import jo.IO.stdout

param pageWidth: Int
param newLine: Bool

def pretty(s: String): Unit receives newLine, pageWidth, stdout =
  println: "pageWidth = " + pageWidth
  println: "newLine = " + newLine

def g(): Unit =
  pretty "hello, word"
  h()

def h(): Unit receives newLine, stdout = i()  // error

def i(): Unit =
  g()

def main =
  with pageWidth = 30, newLine = true in g()
