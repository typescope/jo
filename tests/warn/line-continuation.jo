union List[T] = Nil | Cons(head: T, tail: List[T])

section List
  def (l: List[T]) map[T, S](f: T => S): List[S] =
    pattern Map(res: List[S]): List[T] =
      case Nil then res = Nil
      case Cons head Map(t) then res = Cons (f head) t
    end

    match l case Map(res) => res

  def (l: List[T]) fold[T, S](zero: S, f: (S, T) => S): S =
    pattern Fold(acc: S): List[T] =
      case Nil then acc = zero
      case Cons head Fold(acc1) then acc = f acc1 head
    end

    match l case Fold(res) => res
end

section A
  section List
    def double(x: Int): Int = x + x
  end
end

def main =
  val l = Cons 4 (Cons 6 Nil)
  val sum = List> l
    | map x => x * 2
    | fold 0 (acc, i) => acc + i

  println sum
  println (A.List.double 5)
