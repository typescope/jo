def testInt(x: Int): Unit =
  match x
    case 1 =>

def testString(x: String): Unit =
  match x
    case "hello" =>

def testChar(c: Char): Unit =
  match c
    case 'a' =>

def testByte(x: Byte): Unit =
  match x
    case 8 =>

def testBool(x: Bool): Unit =
  match x
    case true =>

def testBool2(x: #P(Bool, Bool)): Unit =
  match x
    case #P true true =>
    case #P false false =>
