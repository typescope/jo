// Test that function adapter with param (context parameter) correctly propagates the context requirement

param indent: Int

class Document(content: String)

// Function that formats a Document, requiring indent context parameter
def formatDoc(doc: Document): String receives indent =
  indent.toString + ": " + doc.content

def test(s: like String with [formatDoc]): Unit =
  println s

def main =
  val doc = Document("World")
  // The context parameter is provided here
  test(doc) allow IO.stdout
