// Test that union types cannot contain multiple numeric types

// Int and Double conflict
type BadUnion1 = Int | Float

// Int and Char conflict
type BadUnion2 = Int | Char

// Byte and Float conflict
type BadUnion3 = Byte | Float

// Char and Byte conflict
type BadUnion4 = Char | Byte

// Multiple numeric types
type BadUnion5 = Int | Char | Float

// Bool and Byte conflict
type BadUnion6 = Bool | Byte

// Bool and Int conflict
type BadUnion7 = Bool | Int

// Bool and Char conflict
type BadUnion8 = Bool | Char

// Long and Int conflict
type BadUnion9 = Long | Int

// Long and Float conflict
type BadUnion10 = Long | Float

// Long and Char conflict
type BadUnion11 = Long | Char
