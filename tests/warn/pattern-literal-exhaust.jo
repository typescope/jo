def testInt(x: Int): Unit =
  match x
    case 1 =>

def testString(x: String): Unit =
  match x
    case "hello" =>

def testChar(c: Char): Unit =
  match c
    case 'a' =>

def testByte(x: Byte): Unit =
  match x
    case 8 =>

def testBool(x: Bool): Unit =
  match x
    case true =>

class Pair[S, T](left: S, right: T)

def testBool2(x: Pair[Bool, Bool]): Unit =
  match x
    case Pair true true =>
    case Pair false false =>
