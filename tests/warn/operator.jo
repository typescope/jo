def (x: Int, y: Int) ** (z: Int): Int = ...

def (x: Int) ++ (y: Int, z: Int): Int = ...

def --(x: Int, y: Int): Int = ...

def (x: Int, y: Int) !! : Int = ...


pattern (x: Int, y: Int) ** (z: Int): Int =
  case _ then x = ..., y = ..., z = ...

pattern (x: Int) ++ (y: Int, z: Int): Int =
  case _ then x = ..., y = ..., z = ...

pattern --(x: Int, y: Int): Int =
  case _ then x = ..., y = ...

pattern (x: Int, y: Int) !! : Int =
  case _ then x = ..., y = ...
