def test1(f: Int => Bool) =
  (f 3) && println "hello"

def test2(f: Int => Bool) =
  f 3 && println "hello"

def foo(x: Int, y: Int) = x + y

def (n: Int) bar(x: Int, y: Int, z: ..Int) = x + y

def qux(x: Int, y: Int, z: ..Int) = x + y

def main =
  foo 3

  foo 3 4 5

  foo(3, 4, 5)

  foo(2)

  2 bar(3)
  4 bar 3

  qux 4
  qux(3)
