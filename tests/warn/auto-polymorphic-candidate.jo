// Error: Polymorphic value candidates are not allowed

type Eq[T] = (T, T) => Bool

def eqInt: Eq[Int] = (a, b) => a == b

// This has a type parameter T - not allowed as value candidate
def eqGeneric[T](auto eq: Eq[T] with [eqInt]): Eq[List[T]] =
  (xs, ys) =>
    if xs.size != ys.size then false
    else
      var equal = true
      var i = 0
      while equal && i < xs.size do
        equal = eq(xs[i], ys[i])
        i = i + 1
      equal

// Error: eqGeneric has type parameters
def testEq[T](x: T, y: T)(auto eq: Eq[T] with [eqInt, eqGeneric]): Bool =
  eq(x, y)

def main: Unit = Unit
