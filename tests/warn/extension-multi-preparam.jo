// Extension method must have exactly one pre-parameter.

class Box(value: Int)

// Case 1: no pre-parameter
section NoPre
  def double(x: Int): Int = x + x
end

type Bad1 = Box :+ [NoPre.double]

// Case 2: multiple pre-parameters
section MultiPre
  def (a: Box, b: Int) combine: Int = a.value + b
end

type Bad2 = Box :+ [MultiPre.combine]
