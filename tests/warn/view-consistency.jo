namespace Test

// Demonstrates conflicts detected during delegate view elaboration

interface Readable
  def read(): String
end

interface Writable
  def write(data: String): Unit
end

class FileReader
  def read(): String = ...
  def write(data: String): Unit = ...
  view Readable
  view Writable
end

// Conflict Type 1: Class method clashes with forwarder synthesized for delegate view
class Processor1
  def read(): String = ...              // Class method
  view Readable = new FileReader()      // ERROR: read() forwarder conflicts with class method
end

// Conflict Type 2: Two delegate views both forward a method with the same name
interface Logger
  def write(msg: String): Unit
end

class SimpleLogger
  def write(msg: String): Unit = ...
  view Logger
end

class Processor2(fileReader: FileReader, logger: SimpleLogger)
  view Writable = fileReader           // Has abstract write()
  view Logger = logger                 // ERROR: write() forwarder conflicts
end

def main = ...
