def test1 =
  println
    10
    | +
        6 * 5
    | +
        if 3 > 2 then 1 else 0

def test2 =
    10
    | +
        6 * 5

    | +  // blank line will break the continuation
        if 3 > 2 then 1 else 0

def test3 =
  "hello" +
    10
    | +
        6 * 5
    | +
        if 3 > 2 then 1 else 0
  | + ", world!"
