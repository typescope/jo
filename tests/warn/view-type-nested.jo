// Nested view types should be invalid
// A ViewType's base type cannot itself be a ViewType

interface Logger
  def log(msg: String): Unit
end

interface Printer
  def print(msg: String): Unit
end

class Foo
  def value(): Int = 42
end

class LoggerImpl
  def log(msg: String): Unit = {}
  view Logger
end

class PrinterImpl
  def print(msg: String): Unit = {}
  view Printer
end

// First level ViewType - valid
type RichFoo = view Foo as Logger

// Nested ViewType - invalid: base type is itself a ViewType
type SuperRichFoo = view RichFoo as Printer
