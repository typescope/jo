import jo.compile.Mixed
import jo.compile.Named

def f(x: Int, y: Int, z: Int): Int = x + y + z
def g(x: Int, y: Int = 0): Int = x + y
def vararg(args: ..Int): Int = 0
def mixedVararg(args: ..Mixed[String]): String = "ok"
def namedVararg(args: ..Named[String]): String = "ok"

def main =
  // Unknown named argument
  f(x = 1, w = 2, z = 3)

  // Same named argument specified twice
  f(x = 1, y = 2, y = 3)

  // Positional after named
  f(x = 1, 2, 3)

  // Named arg for a parameter already provided positionally
  f(1, x = 2, z = 3)

  // Missing required parameter
  f(x = 1, y = 2)

  // Named arg on a lambda / function-value (not a declared function)
  val fn: (Int, Int) => Int = (a, b) => a + b
  fn(x = 1, y = 2)

  // Named arg in plain vararg (element type is not Mixed[T] or Named[T])
  vararg(x = 1, y = 2)

  // Positional after named in Mixed vararg
  mixedVararg(foo = "a", "b")

  // Duplicate named arg in Mixed vararg
  mixedVararg(foo = "a", foo = "b")

  // Positional in vararg portion of Named vararg
  namedVararg("b")

  // Splice in Named vararg
  val xs: List[String] = List("a", "b")
  namedVararg(..xs)

  // Duplicate named arg in Named vararg
  namedVararg(x = "a", x = "b")
