data List[T] = Nil | Cons(v: T, tail: List[T])

def (x: Int) :: (rest: List[Int]): Cons[Int] = Cons x rest
pattern (x: Int) :: (rest: List[Int]): Cons[Int] =
  case Cons x rest

param delta: Int
def bar(x: Int): Int = x + delta

def foo(x: Int): Int =
  x + 1 + delta

pattern Len(x: Int): List[Int] =
  case Nil with x = 0 if foo 3 > 0
  case _ :: (Len y) with x = bar y
  case _ with x = 4

def test(l: List[Int]): Unit =
  match l
    case Nil if foo 4 < 0 =>
    case (x if foo x > 3) :: (Len y) =>
    case ((x if x > 5) | (_ with x = foo 3)) :: (Len y) =>
    case _ =>
