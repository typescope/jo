// Test that member adapter with param (context parameter) correctly propagates the context requirement

param indent: Int

class Document(content: String)
  def format: String receives indent = intToStr(indent) + ": " + content
end

def test(s: like String with [.format]): Unit =
  println s

def main =
  val doc = Document("Hello")
  // The context parameter is provided here
  test(doc) allow IO.stdout
