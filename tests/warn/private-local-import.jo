// Test that private symbols are not accessible in local import scope (using ">")

section Library
  // Public type
  type PublicType = Int

  // Private type
  private type SecretType = String

  // Public function
  def publicFunc(x: Int): Int = x + 1

  // Private function
  private def secretFunc(x: Int): Int = x * 2

  section Helpers
    // Public function in section
    def helperFunc(x: Int): Int = x + 10

    // Private function in section
    private def internalFunc(x: Int): Int = x * 10
  end

  private section SecretSection
    // Function in private section
    def process(x: Int): Int = x + 100
  end
end

def testPublicAccess(): Int =
  // OK: access public members via local import
  Library> publicFunc(10)

def testPublicNested(): Int =
  // OK: access public function from public section
  Library> Helpers.helperFunc(5)

def testPrivateFunc(): Int =
  // Error: cannot access private function via local import
  Library> secretFunc(10)

def testPrivateNested(): Int =
  // Error: cannot access private function from section via local import
  Library> Helpers.internalFunc(5)

def testPrivateSection(): Int =
  // Error: cannot access members of private section via local import
  Library> SecretSection.process(10)

def main: Unit = {}
