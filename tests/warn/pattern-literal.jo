def testInt1(x: Int): Unit =
  match x
    case "hello" => pass
    case _ => pass

def testString(x: String): Unit =
  match x
    case 4 => pass
    case 'a' => pass
    case _ => pass

def testChar1(c: Char): Unit =
  match c
    case "hello" => pass
    case 1024   => pass
    case _ => pass

def testByte1(x: Byte): Unit =
  match x
    case 512 => pass
    case "x" => pass
    case _ => pass

def testBool(x: Bool): Unit =
  match x
    case 23 => pass
    case "hello" => pass
    case 'a' => pass
