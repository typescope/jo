param output: String => Unit
param input: () => String
param retry: Int

interface Runnable
  def run(): Unit receives retry
end

interface Fun
  def apply(): Unit
end

class Work
  def run() receives output, input, retry = output "run"
  view Runnable
end

class F
  def apply() receives output = output "run"
  view Fun
end

class G
  def apply() = output "run"
  view Fun
end

def main =
  val work: Runnable = new Work

  work.run()

  val f: Fun = new F

  val g: Fun = new G
