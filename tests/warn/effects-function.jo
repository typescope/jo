param output: String => Unit
param input: () => String
param retry: Int

type Runnable = {
  def run(): Unit receives retry
}

type Fun = {
  def apply(): Unit
}

def main =
  val work: Runnable = {
    def run() receives output, input, retry = output "run"
  }

  work.run()

  val f: Fun = {
    def apply() receives output = output "run"
  }

  val g: Fun = {
    def apply() = output "run"
  }
