param out: String => Unit
param in: () => String
param retry: Int

type Runnable = {
  def run(): Unit receives retry
}

type Fun = {
  def apply(): Unit
}

def main =
  val work: Runnable = {
    def run() receives out, in, retry = out "run"
  }

  work.run()

  val f: Fun = {
    def apply() receives out = out "run"
  }

  val g: Fun = {
    def apply() = out "run"
  }
