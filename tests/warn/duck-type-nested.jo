// Define adapter functions
def intToStr(x: Int): String = "converted"
def boolToStr(x: Bool): String = "bool"

// Define a duck type alias
type StringLike = String :- [intToStr, .toString]

// Try to create a duck type with a base that already has adapters
// This should produce an error
type NestedDuck = StringLike :- [boolToStr]
