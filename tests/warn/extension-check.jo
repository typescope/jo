// Case 1: method is not an extension method (no pre-parameter)
section NotExtension
  def notExtMethod(x: Int): Int = x + 1
end

type Bad1 = extend Int with NotExtension

// Case 2: base type does not conform to extension parameter type (monomorphic)
extension StringOps(it: String)
  def reverse: String = it
end

type Bad2 = extend Int with StringOps

// Case 3: base type does not conform to extension parameter type (polymorphic)
class Box[T](value: T)

section BoxOps
  def (x: Int) negate: Int = -x
  def (it: Box[T]) get[T]: T = it.value
end

type Bad3 = extend Int with BoxOps
