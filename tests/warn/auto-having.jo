// Test that having candidates appear in warning message

type Eq[T] = (T, T) => Bool
type Ord[T] = (T, T) => Int

class Item
  val value: Int
  def Item(n: Int) = { value: n }

// This will fail because it needs Ord[Item]
def eqItem(auto ord: Ord[Item]): Eq[Item] =
  (a, b) => ord(a, b) == 0

def testEq[T](x: T, y: T)(auto eq: Eq[T], ord: Ord[T]): Bool = ...

def main: Unit =
  val i1 = new Item(42)
  val i2 = new Item(100)

  // No candidates in list, provide eqItem via having
  // Should show having candidate in error when nested Ord[Item] resolution fails
  val result = testEq[Item](i1, i2) having Eq[Item] = ...
  assert(!result, "items should not be equal")
