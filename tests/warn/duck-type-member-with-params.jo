// Test that duck type member adaptation rejects members with normal parameters

class Formatter
  // This method has a normal parameter - should be rejected in member adapters
  def format(prefix: String): String = prefix + " formatted"
end

def Formatter: Formatter = new Formatter

// Duck type using member adapter .format
// Member adapters only support fields and parameterless methods
type Formattable = like String with [.format]

def process(item: Formattable): Unit =
  println item

def main =
  val fmt = Formatter
  process fmt  // Should fail: .format has normal parameters
