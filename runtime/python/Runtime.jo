namespace jo.runtime.python

//------------------------------------------------------------------------------
//
// Predef functions
//
//------------------------------------------------------------------------------

private def abort(msg: String): Bottom =
  abort "abort: intrinsified by the Python backend"

//------------------------------------------------------------------------------
//
// Array operations
//
//------------------------------------------------------------------------------

private def builtins: py.Value = py.importModule("builtins")

private section IntArray
  def create(size: Int): Array.Platform.IntArray =
    // Use builtins.list() via callDynamic instead of py.list() to avoid bootstrap
    // recursion: py.list() passes its vararg as a jo_List, and the jo_List
    // constructor calls jo_Array_RefArray for pattern matching on its size.
    val result: py.List = builtins.callDynamic("list").cast[py.List]
    var i = 0
    while i < size do
      result.append(0)
      i = i + 1
    end
    py.value(result).cast[Array.Platform.IntArray]

  def get(arr: Any, i: Int): Int = py.value(arr)[i].cast[Int]

  def size(arr: Any): Int = py.len(arr)

  def set(arr: Any, i: Int, elem: Int): Unit = py.value(arr)[i] = elem
end

private section FloatArray
  def create(size: Int): Array.Platform.FloatArray =
    // Use builtins.list() via callDynamic instead of py.list() to avoid bootstrap
    // recursion: py.list() passes its vararg as a jo_List, and the jo_List
    // constructor calls jo_Array_RefArray for pattern matching on its size.
    val result: py.List = builtins.callDynamic("list").cast[py.List]
    var i = 0
    while i < size do
      result.append(0.0)
      i = i + 1
    end
    py.value(result).cast[Array.Platform.FloatArray]

  def get(arr: Any, i: Int): Float = py.value(arr)[i].cast[Float]

  def size(arr: Any): Int = py.len(arr)

  def set(arr: Any, i: Int, elem: Float): Unit = py.value(arr)[i] = elem
end

private section ByteArray
  def create(size: Int): Array.Platform.ByteArray =
    // Use builtins.list() via callDynamic instead of py.list() to avoid bootstrap
    // recursion: py.list() passes its vararg as a jo_List, and the jo_List
    // constructor calls jo_Array_RefArray for pattern matching on its size.
    val result: py.List = builtins.callDynamic("list").cast[py.List]
    var i = 0
    while i < size do
      result.append(0)
      i = i + 1
    end
    py.value(result).cast[Array.Platform.ByteArray]

  def get(arr: Any, i: Int): Byte = py.value(arr)[i].cast[Byte]

  def size(arr: Any): Int = py.len(arr)

  def set(arr: Any, i: Int, elem: Byte): Unit = py.value(arr)[i] = elem
end

private section RefArray
  def create[T](size: Int): Array.Platform.RefArray[T] =
    // Use builtins.list() via callDynamic instead of py.list() to avoid bootstrap
    // recursion: py.list() passes its vararg as a jo_List, and the jo_List
    // constructor calls jo_Array_RefArray for pattern matching on its size.
    val result: py.List = builtins.callDynamic("list").cast[py.List]
    var i = 0
    while i < size do
      result.append(py.none)
      i = i + 1
    end
    py.value(result).cast[Array.Platform.RefArray[T]]

  def get[T](arr: Any, i: Int): T = py.value(arr)[i].cast[T]

  def size[T](arr: Any): Int = py.len(arr)

  def set[T](arr: Any, i: Int, elem: T): Unit = py.value(arr)[i] = elem
end

//------------------------------------------------------------------------------
//
// String support
//
//------------------------------------------------------------------------------

private class StringIterator
  val iter: Any
  var nextValue: py.NoneOr[Any]

  def StringIterator(iter: Any, nextValue: py.NoneOr[Any]) =
    this.iter = iter
    this.nextValue = nextValue

  view Iterator[Char]

  def hasNext: Bool = !nextValue.isNone

  def next(): Char receives none =
    assert hasNext "String iterator exhausted"
    val current = nextValue.value
    this.nextValue = py.nextOf(iter)
    py.ord(current)
end

private section StringOps
  def iterator(s: String): Iterator[Char] receives none =
    val iterPy: py.Iterator[Any] = py.iter[Any](s)
    val firstVal: py.NoneOr[Any] = py.nextOf(iterPy)
    new StringIterator(iterPy, firstVal)
end

//------------------------------------------------------------------------------
//
// Regex support
//
//------------------------------------------------------------------------------

private section RegexEngine
  def ignoreCaseFlag: Int = re.IGNORECASE

  def multilineFlag: Int = re.MULTILINE

  def dotAllFlag: Int = re.DOTALL

  def compileFlags(flags: String): Int =
    var bits = 0
    var i = 0
    while i < flags.size do
      match flags[i]
        case 'i' => bits = bits | ignoreCaseFlag
        case 'm' => bits = bits | multilineFlag
        case 's' => bits = bits | dotAllFlag
        case other => abort("Unknown regex flag: " + other)
      end
      i = i + 1
    end
    bits

  def translateNamedGroups(source: String): String =
    var out = ""
    var i = 0
    while i < source.size do
      if i + 2 < source.size
          && source[i] == '('
          && source[i + 1] == '?'
          && source[i + 2] == '<'
      then
        out = out + "(?P<"
        i = i + 3
      else
        out = out + source[i]
        i = i + 1
      end
    end
    out

  def compilePattern(source: String, flags: String): regex.Engine.Pattern =
    py.value(re.compile(translateNamedGroups(source), compileFlags(flags))).cast[regex.Engine.Pattern]

  def execPatternAt(pat: regex.Engine.Pattern, subject: String, pos: Int): regex.Match | None =
    val result: py.NoneOr[Match] = py.value(pat).search(subject, pos).cast[py.NoneOr[Match]]
    if result.isNone then
      None
    else
      val m = result.value
      val from: Int    = m.start(0)
      val text: String = m.group(0)
      val groups = Array.RefArray[String | None](m.groups().size + 1)
      var i = 0
      val len = groups.size
      while i < len do
        val g = m.group(i)
        groups[i] = if py.isNone(g) then None else g
        i = i + 1
      end
      new regex.Match(from, text.size, groups)
end

//------------------------------------------------------------------------------
//
// Context parameters
//
//------------------------------------------------------------------------------

private section ParamSupport
  type Ctx
  type Key[T]
  type Batch

  // Stub function to be replaced at backend
  // id must be an Ident pointing to the context parameter
  def paramKey[T](id: T): Key[T] receives none =
    abort "paramSymbol should be replaced by backend"

  def emptyCtx(): Ctx receives none =
    py.value(py.none).cast[Ctx]

  def getParam[T](ctx: Ctx, key: Key[T]): T receives none =
    var cur: Any = ctx
    while !py.isNone(cur) do
      if py.isSame(py.value(cur)[1], key) then
        return py.value(cur)[2].cast[T]
      end
      cur = py.value(cur)[0]
    end
    abort("Unbound parameter " + py.str(key))

  def startBatch(ctx: Ctx, count: Int): Batch receives none =
    py.value(py.list(ctx)).cast[Batch]

  def addBinding[T](batch: Batch, key: Key[T], value: T): Unit receives none =
    py.value(batch)[0] = py.tuple(py.value(batch)[0], key, value)

  def finish(batch: Batch): Ctx receives none =
    py.value(batch)[0].cast[Ctx]
end

//------------------------------------------------------------------------------
//
// I/O implementations
//
//------------------------------------------------------------------------------

private class PlatformFile(handle: io.File)
  view IO.File

  var position: Int = 0

  def close(): Unit = handle.close()

  def seek(pos: Int): Unit =
    position = pos
    handle.seek(pos)

  def hasMore(): Bool =
    handle.seek(0, 2)
    val fileSize = handle.tell()
    handle.seek(position)
    position < fileSize

  def readLine(): String =
    val line = handle.readline()
    position = handle.tell()
    val len = line.size
    // TODO: assume UNIX file ending
    if len > 0 && line.get(len - 1) == '\n' then
      line.substring(0, len - 1)
    else
      line

  def write(content: String): Unit =
    handle.write(content)
    position = handle.tell()
end

//------------------------------------------------------------------------------
//
// Program entry point
//
//------------------------------------------------------------------------------

private def start(): Unit =
  val argv = sys.argv
  val argc = argv.size
  val argList = py.list()
  var argIdx = 1
  while argIdx < argc do
    argList.append(argv[argIdx])
    argIdx = argIdx + 1
  end
  val argsArr: Array.Platform.RefArray[String] = py.value(argList).cast[Array.Platform.RefArray[String]]
  val args = new IO.Args(argsArr)

  val opener: String => IO.File =
    filePath =>
      val mode = if os.path.exists(filePath) then "r+" else "w+"
      new PlatformFile(py.open(filePath, mode))

  val stdin: () => String =
    () => py.input()

  val stdout: String => Unit =
    s => py.print(s, "")

  val stderr: String => Unit =
    s => py.print(s, "", sys.stderr)

  jo.main() with
    IO.open = opener,
    IO.stdin = stdin,
    IO.stdout = stdout,
    IO.stderr = stderr,
    IO.args = args
end
