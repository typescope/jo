namespace jo.runtime.python.io

import jo.runtime.python.*

//[ Python file object.   //]
interface File
  def read(size: Int = -1): String

  def readline(): String

  def readlines(): py.StringList

  def write(text: String): Int

  def flush(): Unit

  def close(): Unit

  def seek(pos: Int, whence: Int = 0): Int

  def tell(): Int
end
