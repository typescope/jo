namespace jo.runtime.python

interface Sys
  def argv: py.StringList = py.value(this).argv.cast[py.StringList]

  def stdin: py.Value = py.value(this).stdin

  def stdout: py.Value = py.value(this).stdout

  def stderr: py.Value = py.value(this).stderr

  def exit(code: Int): Bottom
end

def sys: Sys = py.importModule("sys").cast[Sys]
